---
import "../styles/global.css";
const { pathname } = Astro.url;
const { title = "Admin Dashboard" } = Astro.props;

const isProjectActive = pathname.includes("/admin/projects");
const isApartmentActive = pathname.includes("/admin/apartments");
const isHeroActive = pathname.includes("/admin/hero-slides"); 
const isBannerActive = pathname.includes("/admin/banners"); // 🔥 THÊM MỚI: Trạng thái active của Banner Ads động
const isUserActive = pathname.includes("/admin/users");
const isPostActive = pathname.includes("/admin/posts");
const isLeadActive = pathname.includes("/admin/leads"); 
const isConsignmentActive = pathname.includes("/admin/consignments"); 
const isTaxActive = pathname.includes("/admin/tools/tax-calc");
const isBankActive = pathname.includes("/admin/banks");
const isSettingActive = pathname.includes("/admin/settings");
const isDashboardActive = pathname === "/admin/dashboard" || pathname === "/admin/";

// 🔥 ĐỒNG BỘ MÔI TRƯỜNG: Bốc cấu hình URL API động thay thế liên kết cứng
const PUBLIC_API_BASE = import.meta.env.PUBLIC_API_BASE || "http://127.0.0.1:8000";

---

<!doctype html>
<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <script is:inline src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <style>body { font-family: "Plus Jakarta Sans", sans-serif; }</style>
  </head>
  <body class="bg-slate-50 text-slate-900 overflow-x-hidden">
    <div class="flex min-h-screen relative" id="admin-layout-root" data-api-base={PUBLIC_API_BASE}>
      
      <div id="sidebar-overlay" class="fixed inset-0 bg-slate-950/50 z-40 hidden lg:hidden opacity-0 transition-opacity duration-300"></div>

      <aside id="admin-sidebar" class="w-72 bg-slate-900 text-white flex flex-col fixed lg:sticky top-0 h-screen shadow-2xl z-50 -translate-x-full lg:translate-x-0 transition-transform duration-300 ease-in-out">
        <div class="p-6 md:p-8 overflow-y-auto flex-1">
          <div class="flex items-center justify-between mb-10">
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 bg-[#fac72e] rounded-xl flex items-center justify-center font-bold text-xl shadow-lg shadow-orange-600/20">B</div>
              <span class="text-xl font-bold tracking-tight">Administrator</span>
            </div>
            <button id="close-sidebar-btn" class="lg:hidden text-slate-400 hover:text-white p-1 rounded-lg hover:bg-slate-800 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
            </button>
          </div>

          <nav class="space-y-2">
            <a id="menu-dashboard" href="/admin/dashboard" class={`flex items-center gap-3 px-4 py-3.5 rounded-2xl transition-all duration-300 font-medium group ${isDashboardActive ? "bg-[#fac72e] text-black shadow-lg shadow-orange-600/30" : "text-slate-400 hover:bg-slate-800 hover:text-white"}`}>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v4a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v4a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v4a2 2 0 01-2 2H6a2 2 0 01-2-2v-4zM14 16a2 2 0 012-2h2a2 2 0 012 2v4a2 2 0 01-2 2h-2a2 2 0 01-2-2v-4z"></path></svg>
              Tổng quan
            </a>
            <a id="menu-hero" href="/admin/hero-slides" class={`flex items-center gap-3 px-4 py-3.5 rounded-2xl transition-all duration-300 font-medium group ${isHeroActive ? "bg-[#fac72e] text-black shadow-lg shadow-orange-600/30" : "text-slate-400 hover:bg-slate-800 hover:text-white"}`}>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5zM4 13a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1v-2zM4 21a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1v-2z" /></svg>
              Quản lý Banner
            </a>

            <a id="menu-banner" href="/admin/banners" class={`flex items-center gap-3 px-4 py-3.5 rounded-2xl transition-all duration-300 font-medium group ${isBannerActive ? "bg-[#fac72e] text-black shadow-lg shadow-orange-600/30" : "text-slate-400 hover:bg-slate-800 hover:text-white"}`}>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
              Banner Ads động
            </a>

            <a id="menu-projects" href="/admin/projects" class={`flex items-center gap-3 px-4 py-3.5 rounded-2xl transition-all duration-300 font-medium group ${isProjectActive ? "bg-[#fac72e] text-black shadow-lg shadow-orange-600/30" : "text-slate-400 hover:bg-slate-800 hover:text-white"}`}>
              <svg xmlns="http://www.w3.org/2000/xl" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5"></path></svg>
              Quản lý dự án
            </a>
            <a id="menu-apartments" href="/admin/apartments" class={`flex items-center gap-3 px-4 py-3.5 rounded-2xl transition-all duration-300 font-medium group ${isApartmentActive ? "bg-[#fac72e] text-black shadow-lg shadow-orange-600/30" : "text-slate-400 hover:bg-slate-800 hover:text-white"}`}>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path></svg>
              Quản lý căn hộ
            </a>
            <a id="menu-posts" href="/admin/posts" class={`flex items-center gap-3 px-4 py-3.5 rounded-2xl transition-all duration-300 font-medium group ${isPostActive ? "bg-[#fac72e] text-black shadow-lg shadow-orange-600/30" : "text-slate-400 hover:bg-slate-800 hover:text-white"}`}>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10l4 4v10a2 2 0 01-2 2z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 2v6h6"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 10h4M7 14h10"></path></svg>
              Quản lý bài viết
            </a>
            <a id="menu-users" href="/admin/users" class={`flex items-center gap-3 px-4 py-3.5 rounded-2xl transition-all duration-300 font-medium group ${isUserActive ? "bg-[#fac72e] text-black shadow-lg shadow-orange-600/30" : "text-slate-400 hover:bg-slate-800 hover:text-white"}`}>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"></path></svg>
              Nhân Sự
            </a>
            <a id="menu-leads" href="/admin/leads" class={`flex items-center gap-3 px-4 py-3.5 rounded-2xl transition-all duration-300 font-medium group ${isLeadActive ? "bg-[#fac72e] text-black shadow-lg shadow-orange-600/30" : "text-slate-400 hover:bg-slate-800 hover:text-white"}`}>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"></path></svg>
              Khách Hàng
            </a>
            <a id="menu-consignments" href="/admin/consignments" class={`flex items-center gap-3 px-4 py-3.5 rounded-2xl transition-all duration-300 font-medium group ${isConsignmentActive ? "bg-[#fac72e] text-black shadow-lg shadow-orange-600/30" : "text-slate-400 hover:bg-slate-800 hover:text-white"}`}>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4" /></svg>
              Quản lý ký gửi
            </a>
            <a id="menu-tax" href="/admin/tools/tax-calc" class={`flex items-center gap-3 px-4 py-3.5 rounded-2xl transition-all duration-300 font-medium group ${isTaxActive ? "bg-[#fac72e] text-black shadow-lg shadow-orange-600/30" : "text-slate-400 hover:bg-slate-800 hover:text-white"}`}>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z"></path></svg>
              Tính Thuế Phí
            </a>
            <a id="menu-banks" href="/admin/banks" class={`flex items-center gap-3 px-4 py-3.5 rounded-2xl transition-all duration-300 font-medium group ${isBankActive ? "bg-[#fac72e] text-black shadow-lg shadow-orange-600/30" : "text-slate-400 hover:bg-slate-800 hover:text-white"}`}>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h6m-6 4h6m-6 4h6"></path></svg>
              Quản lý Ngân hàng
            </a>
            <a id="menu-settings" href="/admin/settings" class={`flex items-center gap-3 px-4 py-3.5 rounded-2xl transition-all duration-300 font-medium group ${isSettingActive ? "bg-[#fac72e] text-black   shadow-lg shadow-orange-600/30" : "text-slate-400 hover:bg-slate-800 hover:text-white"}`}>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543-.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.756.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
              Cấu hình hệ thống
            </a>
          </nav>
        </div>

        <div class="mt-auto p-6 border-t border-slate-800 flex-shrink-0">
          <button id="logout-btn" class="w-full mt-4 flex items-center justify-center gap-2 px-4 py-2.5 rounded-xl bg-slate-800 hover:bg-red-500/10 hover:text-red-500 transition-all text-sm font-medium">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path></svg>
            Đăng xuất
          </button>
        </div>
      </aside>

      <main class="flex-1 flex flex-col min-w-0 w-full">
        <header class="h-20 bg-white border-b border-slate-200 flex items-center justify-between px-6 md:px-10 sticky top-0 z-30">
          <div class="flex items-center gap-4">
            <button id="open-sidebar-btn" class="lg:hidden p-2 rounded-xl border border-slate-200 bg-slate-50 hover:bg-slate-100 text-slate-600 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" /></svg>
            </button>
            <h2 class="text-base md:text-lg font-semibold text-slate-800 truncate">Hệ thống quản lý</h2>
          </div>
          
          <div class="flex items-center gap-4 relative">
            <button id="notification-btn" class="relative group focus:outline-none">
              <span id="notification-badge" class="hidden absolute -top-1 -right-1 w-4 h-4 bg-red-500 text-[10px] font-bold flex items-center justify-center rounded-full text-white border-2 border-white animate-pulse">0</span>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-slate-400 group-hover:text-orange-500 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"></path></svg>
            </button>
            <div id="notification-dropdown" class="hidden absolute right-0 top-full mt-4 w-72 md:w-80 bg-white rounded-3xl shadow-2xl border border-slate-100 z-50 overflow-hidden">
              <div class="p-5 border-b border-slate-50 flex justify-between items-center">
                <h4 class="font-black text-slate-800 uppercase text-xs tracking-widest">Thông báo mới</h4>
                <button id="mark-all-read" class="text-[10px] font-bold text-blue-600 hover:underline">Đánh dấu đã đọc</button>
              </div>
              <div id="notification-list" class="max-h-[400px] overflow-y-auto"></div>
            </div>
          </div>
        </header>

        <div class="p-4 sm:p-6 md:p-10 overflow-y-auto bg-slate-50/50 flex-1 w-full">
          <slot />
        </div>
      </main>
    </div>

    <script is:inline>
      const openSidebarBtn = document.getElementById("open-sidebar-btn");
      const closeSidebarBtn = document.getElementById("close-sidebar-btn");
      const adminSidebar = document.getElementById("admin-sidebar");
      const sidebarOverlay = document.getElementById("sidebar-overlay");

      const notifyBtn = document.getElementById("notification-btn");
      const notifyDropdown = document.getElementById("notification-dropdown");
      const notifyBadge = document.getElementById("notification-badge");
      const notifyList = document.getElementById("notification-list");
      const markReadBtn = document.getElementById("mark-all-read");

      const layoutRoot = document.getElementById("admin-layout-root");
      const API_BASE = layoutRoot ? layoutRoot.getAttribute("data-api-base") : "http://127.0.0.1:8000";

      // 🔥 LUỒNG KIỂM TRA PHÂN QUYỀN MENU ĐỘNG (DỰA TRÊN LOCALSTORAGE)
      function applyRoleMenuPrivileges() {
        const userRole = localStorage.getItem('user_role') || localStorage.getItem('admin_role') || localStorage.getItem('role') || '';
        const roleClean = userRole.toLowerCase().trim();

        const menuDashboard = document.getElementById('menu-dashboard');
        const menuHero = document.getElementById('menu-hero');
        const menuBanner = document.getElementById('menu-banner'); // 🔥 Tóm node mục Banner mới tạo
        const menuProjects = document.getElementById('menu-projects');
        const menuApartments = document.getElementById('menu-apartments');
        const menuPosts = document.getElementById('menu-posts');
        const menuUsers = document.getElementById('menu-users');
        const menuLeads = document.getElementById('menu-leads');
        const menuConsignments = document.getElementById('menu-consignments');
        const menuTax = document.getElementById('menu-tax');
        const menuBanks = document.getElementById('menu-banks');
        const menuSettings = document.getElementById('menu-settings');

        // 1. Trường hợp là Môi giới/Broker: Ẩn sạch, cấm sờ vào Banner Ads
        if (roleClean.includes('môi giới') || roleClean === 'moi_gioi' || roleClean === 'broker') {
          if (menuHero) menuHero.classList.add('hidden');
          if (menuBanner) menuBanner.classList.add('hidden'); // 🔥 ẨN KHỎI MÔI GIỚI
          if (menuProjects) menuProjects.classList.add('hidden');
          if (menuPosts) menuPosts.classList.add('hidden');
          if (menuUsers) menuUsers.classList.add('hidden');
          if (menuLeads) menuLeads.classList.add('hidden');
          if (menuConsignments) menuConsignments.classList.add('hidden');
          if (menuBanks) menuBanks.classList.add('hidden');
          if (menuSettings) menuSettings.classList.add('hidden');
        } 
        // 2. Trường hợp là Quản lý/Manager: Được xem Leads, Căn hộ, Tin tức... nhưng CẤM xem Banner Ads
        else if (roleClean.includes('quản lý') || roleClean === 'quan_ly' || roleClean === 'manager') {
          if (menuHero) menuHero.classList.add('hidden');
          if (menuBanner) menuBanner.classList.add('hidden'); // 🔥 ẨN KHỎI TRƯỞNG PHÒNG/QUAN LÝ
          if (menuProjects) menuProjects.classList.add('hidden');
          if (menuUsers) menuUsers.classList.add('hidden');
          if (menuSettings) menuSettings.classList.add('hidden');
        }
        // 3. Toàn bộ các quyền Admin tối cao -> Bỏ qua lệnh nén, hiển thị đầy đủ 100%!
      }

      applyRoleMenuPrivileges();

      // 📱 TOGGLE SIDEBAR MOBILE
      function toggleMobileSidebar(open) {
        if (open) {
          adminSidebar?.classList.remove("-translate-x-full");
          sidebarOverlay?.classList.remove("hidden");
          setTimeout(() => sidebarOverlay?.classList.add("opacity-100"), 10);
          document.body.classList.add("overflow-hidden");
        } else {
          adminSidebar?.classList.add("-translate-x-full");
          sidebarOverlay?.classList.remove("opacity-100");
          setTimeout(() => sidebarOverlay?.classList.add("hidden"), 300);
          document.body.classList.remove("overflow-hidden");
        }
      }

      openSidebarBtn?.addEventListener("click", () => toggleMobileSidebar(true));
      closeSidebarBtn?.addEventListener("click", () => toggleMobileSidebar(false));
      sidebarOverlay?.addEventListener("click", () => toggleMobileSidebar(false));

      // 🟡 POPUP THÔNG BÁO QUẢ CHUÔNG
      notifyBtn?.addEventListener("click", (e) => {
        e.stopPropagation();
        if (!notifyDropdown?.classList.toggle("hidden")) fetchNotifications();
      });
      document.addEventListener("click", () => notifyDropdown?.classList.add("hidden"));
      document.getElementById("logout-btn")?.addEventListener("click", () => {
        localStorage.clear(); window.location.replace("/admin");
      });

      markReadBtn?.addEventListener("click", async (e) => {
        e.stopPropagation();
        try {
          const token = localStorage.getItem('admin_token'); if (!token) return;
          const res = await fetch(`${API_BASE}/api/notifications/mark-all-read`, { method: "POST", headers: { 'Authorization': `Bearer ${token}` } });
          const data = await res.json();
          if (data.success) {
            Swal.fire({ icon: 'success', title: 'Thành công', text: 'Đã xóa toàn bộ huy hiệu thông báo chưa đọc.', timer: 1500, showConfirmButton: false });
            updateUnreadBadge(); fetchNotifications(); 
          }
        } catch (err) {}
      });

      async function updateUnreadBadge() {
        try {
          const token = localStorage.getItem('admin_token'); if (!token) return;
          const res = await fetch(`${API_BASE}/api/notifications/unread-count`, { headers: { 'Authorization': `Bearer ${token}` } });
          const data = await res.json();
          if (notifyBadge) {
            const count = data.unreadCount || 0;
            if (count > 0) { notifyBadge.innerText = count > 99 ? "99+" : count; notifyBadge.classList.remove("hidden"); }
            else notifyBadge.classList.add("hidden");
          }
        } catch (err) {}
      }

      async function fetchNotifications() {
        try {
          const res = await fetch(`${API_BASE}/api/notifications`, { headers: { Authorization: `Bearer ${localStorage.getItem("admin_token")}` } });
          const data = await res.json(); if (!notifyList) return;
          if (data.length === 0) notifyList.innerHTML = '<p class="p-6 text-center text-slate-400 text-xs italic">Không có thông báo mới</p>';
          else notifyList.innerHTML = data.map(n => `<div class="p-4 border-b border-slate-50 ${n.isRead === 0 ? "bg-blue-50/40 font-medium" : ""}"><div class="flex justify-between items-start mb-1"><span class="text-[10px] font-black text-orange-600 uppercase tracking-wider">${n.action}</span></div><p class="text-sm text-slate-700"><b>${n.userName || 'Hệ thống'}</b>: ${n.target}</p></div>`).join("");
        } catch (err) {}
      }
      
      updateUnreadBadge(); 
      setInterval(updateUnreadBadge, 30000); 
    </script>
