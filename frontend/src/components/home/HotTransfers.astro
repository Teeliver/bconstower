---
// src/components/HotTransfers.astro
// 🔥 ĐÃ ĐỒNG BỘ: Giữ nguyên cấu hình URL mặc định hệ thống của Trung Tín
const PUBLIC_API_BASE = import.meta.env.PUBLIC_API_BASE || "http://localhost:3000";
---
<section id="hot-transfers-root" data-api-base={PUBLIC_API_BASE} class="w-full py-16 bg-white animate-fadeIn">
  <div class="max-w-7xl mx-auto px-4">
    
    <div class="w-full flex flex-col md:flex-row md:items-end justify-between mb-10 gap-4">
      <div class="space-y-2">
        <span class="text-[10px] font-black uppercase tracking-widest text-red-600 bg-red-50 px-3 py-1 rounded-md">
          Cập nhật phút trước
        </span>
        <h3 class="text-xl sm:text-2xl font-black text-slate-900 uppercase tracking-tight mt-4">
          Sang Nhượng HOT
        </h3>
        <div class="w-12 h-1 bg-red-500 rounded-full mt-2"></div>
      </div>
      
      <div class="grid grid-cols-3 md:flex md:flex-row md:items-center gap-2 w-full md:w-auto text-[10px] sm:text-[11px] font-black uppercase tracking-tight sm:tracking-wider select-none" id="hot-tabs-buttons-group">
        <button type="button" data-status="hasbook" class="hot-tab-btn w-full text-center px-1 sm:px-3 py-2 rounded-full border border-[#064e3b]/20 bg-[#064e3b]/5 text-[#064e3b] cursor-pointer focus:outline-none transition-all whitespace-nowrap">
          Đã có sổ
        </button>
        <button type="button" data-status="handedover" class="hot-tab-btn w-full text-center px-1 sm:px-3 py-2 rounded-full border border-slate-200 bg-slate-50 text-slate-400 cursor-pointer focus:outline-none transition-all whitespace-nowrap">
          Đã bàn giao
        </button>
        <button type="button" data-status="construction" class="hot-tab-btn w-full flex items-center justify-center gap-1 px-1 sm:px-3 py-2 rounded-full border border-slate-200 bg-slate-50 text-slate-400 cursor-pointer focus:outline-none transition-all whitespace-nowrap">
          <span class="w-1.5 h-1.5 rounded-full bg-red-600 shrink-0 hidden" id="construction-dot"></span> Đang xây dựng
        </button>
      </div>
    </div>

    <div id="hot-transfer-skeleton" class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-12">
      {[1,2,3,4].map(() => (
        <div class="space-y-3">
          <div class="aspect-[4/3] bg-slate-100 rounded-xl w-full"></div>
          <div class="h-4 bg-slate-100 rounded w-2/3"></div>
          <div class="h-3 bg-slate-100 rounded w-1/2"></div>
        </div>
      ))}
    </div>

    <div id="hot-transfers-grid" class="grid grid-cols-1 lg:grid-cols-3 gap-12 hidden"></div>

  </div>
</section>

<script is:inline>
  (async function initHotTransfers() {
    const root = document.getElementById('hot-transfers-root');
    if (!root) return;
    
    // 🔥 ĐỒNG BỘ MẠNG LOCALHOST: Kết nối trực diện an toàn
    const BACKEND_URL = root.getAttribute('data-api-base') || 'http://localhost:8000';
    const grid = document.getElementById('hot-transfers-grid');
    const skeleton = document.getElementById('hot-transfer-skeleton');
    const defaultImage = '/images/no-photo.jpg';

    let MASTER_APARTMENTS = [];
    let PROJECT_LOOKUP_MAP = {}; 
    let currentTab = 'hasbook'; 

    // 🔒 LỚP BẢO MẬT XSS: Khử trùng chuỗi dữ liệu public trang chủ
    const escapeHTML = (str) => {
      if (!str) return '';
      return str.replace(/[&<>"']/g, (match) => {
        const map = { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' };
        return map[match] || match;
      });
    };

    // Tìm dữ liệu bảng projects liên kết từ project_id của căn hộ
    function getProjectData(apt) {
      if (apt.project && typeof apt.project === 'object') {
        return apt.project;
      }
      const pId = apt.project_id || apt.projectId;
      if (pId && PROJECT_LOOKUP_MAP[String(pId)]) {
        return PROJECT_LOOKUP_MAP[String(pId)];
      }
      return null;
    }

    // 🔥 LOGIC MA TRẬN PHÂN LOẠI TAB THEO KHAI BÁO NGHIỆP VỤ CỦA TRUNG TÍN
    function checkStatusAndLegal(apt) {
      const proj = getProjectData(apt);
      if (!proj) return 'unknown';

      const status = String(proj.status || '').trim().toLowerCase();
      const legal = String(proj.legal || '').trim().toLowerCase();

      // Dạng 1: Đã có sổ -> Đẩy thẳng vào Tab Có Sổ (Pháp lý lưu enum chuẩn 'so_hong')
      if (legal === 'so_hong') {
        return 'hasbook';
      }
      
      // Dạng 2: Đã bàn giao nhưng chưa có sổ (ký HĐMB) -> Đẩy vào Tab Đã Bàn Giao
      if (status === 'da_ban_giao' && legal === 'hdmb' || legal === 'so_hong') {
        return 'handedover';
      }
      
      // Dạng 3: Đang xây dựng -> Đẩy vào Tab Đang Xây Dựng (Tình trạng lưu enum chuẩn 'dang_xay_dung')
      if (status === 'dang_xay_dung' && legal === 'hdmb' || legal === 'booking') {
        return 'construction';
      }
      
      return 'unknown';
    }

    function timeAgo(dateString) {
        if (!dateString) return 'Đang cập nhật';
        const now = new Date();
        const past = new Date(dateString);
        const diffInSeconds = Math.floor((now.getTime() - past.getTime()) / 1000);

        if (diffInSeconds < 60) return 'Vừa xong';
        const minutes = Math.floor(diffInSeconds / 60);
        if (minutes < 60) return `Đăng ${minutes} phút trước`;
        const hours = Math.floor(minutes / 60);
        if (hours < 24) return `Đăng ${hours} giờ trước`;
        const days = Math.floor(hours / 24);
        if (days < 30) return `Đăng ${days} ngày trước`;
        
        return `Đăng ${past.toLocaleDateString('vi-VN')}`;
    }

    // ⚡ BẢO TOÀN UI/UX GỐC 100%: Chỉ hoán đổi mác màu sắc, giữ nguyên cấu trúc layout nút bấm gốc
    function updateTabUI(activeTab) {
      const buttonsContainer = document.getElementById('hot-tabs-buttons-group');
      if (!buttonsContainer) return;
      const buttons = buttonsContainer.querySelectorAll('.hot-tab-btn');
      const dotEl = document.getElementById('construction-dot');

      buttons.forEach(b => {
        const status = b.getAttribute('data-status');
        if (status === 'hasbook') {
          b.className = "hot-tab-btn w-full text-center px-1 sm:px-3 py-2 rounded-full border border-slate-200 bg-slate-50 text-slate-400 cursor-pointer focus:outline-none transition-all whitespace-nowrap";
        } else if (status === 'handedover') {
          b.className = "hot-tab-btn w-full text-center px-1 sm:px-3 py-2 rounded-full border border-slate-200 bg-slate-50 text-slate-400 cursor-pointer focus:outline-none transition-all whitespace-nowrap";
        } else if (status === 'construction') {
          b.className = "hot-tab-btn w-full flex items-center justify-center gap-1 px-1 sm:px-3 py-2 rounded-full border border-slate-200 bg-slate-50 text-slate-400 cursor-pointer focus:outline-none transition-all whitespace-nowrap";
        }
      });
      
      if (dotEl) dotEl.classList.add('hidden');

      const activeBtn = buttonsContainer.querySelector(`[data-status="${activeTab}"]`);
      if (activeBtn) {
        if (activeTab === 'hasbook') {
          activeBtn.className = "hot-tab-btn w-full text-center px-1 sm:px-3 py-2 rounded-full border border-[#064e3b]/20 bg-[#064e3b]/5 text-[#064e3b] cursor-pointer focus:outline-none transition-all whitespace-nowrap";
        } else if (activeTab === 'handedover') {
          activeBtn.className = "hot-tab-btn w-full text-center px-1 sm:px-3 py-2 rounded-full border border-orange-200 bg-orange-50 text-orange-600 cursor-pointer focus:outline-none transition-all whitespace-nowrap";
        } else if (activeTab === 'construction') {
          activeBtn.className = "hot-tab-btn w-full flex items-center justify-center gap-1 px-1 sm:px-3 py-2 rounded-full border border-red-200 bg-red-50 text-red-600 cursor-pointer focus:outline-none transition-all whitespace-nowrap";
          if (dotEl) dotEl.classList.remove('hidden');
        }
      }
    }

    function getFilteredItems(tab) {
      return MASTER_APARTMENTS.filter(apt => {
        return checkStatusAndLegal(apt) === tab;
      });
    }

    function renderHotItems() {
      if (!grid) return;
      if (MASTER_APARTMENTS.length === 0) return;

      let filtered = getFilteredItems(currentTab);
      // Sắp xếp tăng dần theo giá bán và cắt tối đa lấy 6 sản phẩm khớp hàng lưới ô Grid thiết kế trang chủ
      const hotItems = filtered.sort((a, b) => Number(a.price) - Number(b.price)).slice(0, 6);

      if (hotItems.length === 0) {
        grid.innerHTML = `
          <div class="col-span-full text-center py-16 bg-slate-50 rounded-2xl border border-dashed border-slate-200 w-full">
            <p class="text-sm font-bold text-slate-400">Hiện tại chưa có sản phẩm ký gửi thuộc danh mục này.</p>
          </div>
        `;
        return;
      }

      grid.innerHTML = hotItems.map((apt) => {
        let itemImages = [];
        if (apt.image) {
          if (typeof apt.image === 'string') {
            if (apt.image.trim().startsWith('[') && apt.image.trim().endsWith(']')) {
              try { itemImages = JSON.parse(apt.image); } catch(e) { itemImages = [apt.image]; }
            } else { itemImages = [apt.image]; }
          } else if (Array.isArray(apt.image)) { itemImages = apt.image; }
        }

        const rawThumb = (itemImages && itemImages.length > 0) ? itemImages[0] : '';
        const thumb = rawThumb 
          ? (rawThumb.startsWith('http') ? rawThumb : (BACKEND_URL.replace(/\/$/, '') + '/' + rawThumb.replace(/^\//, ''))) 
          : defaultImage;

        const priceBillion = apt.price ? (apt.price / 1000000000).toFixed(2).replace('.', ',') : '0';
        const pricePerM2 = (apt.price && apt.area) ? Math.round((apt.price / apt.area) / 1000000) : 0;
        
        const proj = getProjectData(apt);
        const currentProjectSlug = proj && proj.slug ? proj.slug : (apt.project_slug || apt.projectSlug || 'bcons');
        const currentCreatedAt = apt.created_at || apt.createdAt;

        // Định dạng nhãn Badge đè ảnh đồng bộ chính xác theo ma trận nghiệp vụ mới
        const itemType = checkStatusAndLegal(apt);
        let labelText = 'Đang cập nhật';
        let labelClass = 'bg-slate-600/90 text-white';

        if (itemType === 'hasbook') {
          labelText = 'Đã có sổ';
          labelClass = 'bg-emerald-600/90 text-white';
        } else if (itemType === 'handedover') {
          labelText = 'Đã bàn giao';
          labelClass = 'bg-orange-500/90 text-white';
        } else if (itemType === 'construction') {
          labelText = 'Đang Xây Dựng';
          labelClass = 'bg-red-600/90 text-white';
        }

        const safeName = escapeHTML(apt.name || '');
        const rawAddress = apt.address || (proj ? proj.address : '') || (proj ? proj.location : '') || 'Đang cập nhật';
        const safeProjectSlug = escapeHTML(currentProjectSlug);
        const safeAptSlug = escapeHTML(apt.slug || '');

        return `
        <div class="relative w-full group">
          <a href="/${safeProjectSlug}/${safeAptSlug}" class="focus:outline-none">          
            <div class="relative aspect-[4/3] rounded-2xl overflow-hidden mb-3 shadow-sm border border-slate-50">
              <img src="${thumb}" onerror="this.src='${defaultImage}'" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" alt="${safeName}" />
                
                <div class="absolute top-2 left-2 px-2.5 py-1 rounded-lg text-[10px] font-black uppercase tracking-wider shadow-sm backdrop-blur-[2px] ${labelClass}">
                  ${labelText}
                </div>

                <div class="absolute bottom-2 right-2 bg-black/40 backdrop-blur-sm px-2 py-1 rounded-lg flex items-center gap-1 text-white">
                    <svg viewBox="0 0 24 24" class="w-3 h-3 fill-current opacity-80"><path d="M21 19V5c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2zM8.5 13.5l2.5 3.01L14.5 12l4.5 6H5l3.5-4.5z"/></svg>
                    <span class="text-[10px] font-bold">1/${itemImages.length || 1}</span>
                </div>
            </div>
            <div class="w-full pt-2">
              <div class="flex w-full flex-row items-center justify-between gap-x-2">
                <span class="font-extrabold text-emerald-700">${priceBillion} tỷ · <span class="text-sm font-semibold">${pricePerM2} triệu/m²</span></span>
                <span class="text-xs text-neutral-600">${timeAgo(currentCreatedAt)}</span>
              </div>
              <section class="pt-1">
                <h6 class="text-base font-bold text-neutral-900 line-clamp-1" title="${safeName}">${safeName}</h6>
                <p class="pt-0.5 text-sm text-neutral-600">${rawAddress}</p>
              </section>
            </div>

            <div class="flex flex-row flex-nowrap items-center pt-1.5">
              <div class="flex flex-row items-center">
                <div class="flex flex-row items-center gap-x-1">
                  <svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" fill="currentColor" viewBox="0 0 256 256" class="h-5 w-5 text-neutral-500"><path d="M248,112v56H112V80H216A32,32,0,0,1,248,112Z" opacity="0.2"></path><path d="M216,72H32V48a8,8,0,0,0-16,0V208a8,8,0,0,0,16,0V176H240v32a8,8,0,0,0,16,0V112A40,40,0,0,0,216,72ZM32,88h72v72H32Zm88,72V88h96a24,24,0,0,1,24,24v48Z"></path></svg>
                  <span class="whitespace-nowrap text-sm text-neutral-600">${apt.bedrooms || 0} PN</span>
                </div>
              </div>
              <div class="flex flex-row items-center">
                <div class="mx-3 h-3 w-px bg-black/10"></div>
                <div class="flex flex-row items-center gap-x-1">
                  <svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" fill="currentColor" viewBox="0 0 256 256" class="h-5 w-5 text-neutral-500"><path d="M240,104v40a48,48,0,0,1-48,48H64a48,48,0,0,1-48-48V104H136v40h64V104Z" opacity="0.2"></path><path d="M240,96H208a8,8,0,0,0-8-8H136a8,8,0,0,0-8,8H64V52A12,12,0,0,1,76,40a12.44,12.44,0,0,1,12.16,9.59,8,8,0,0,0,15.68-3.18A28.32,28.32,0,0,0,76,24,28,28,0,0,0,48,52V96H16a8,8,0,0,0-8,8v40a56.06,56.06,0,0,0,56,56v16a8,8,0,0,0,16,0V200h96v16a8,8,0,0,0,16,0V200a56.06,56.06,0,0,0,56-56V104A8,8,0,0,0,240,96Zm-48,8v32H144V104Zm40,40a40,40,0,0,1-40,40H64a40,40,0,0,1-40-40V112H128v32a8,8,0,0,0,8,8h64a8,8,0,0,0,8-8V112h24Z"></path></svg>
                  <span class="whitespace-nowrap text-sm text-neutral-600">${apt.bathrooms || 0} WC</span>
                </div>
              </div>
              <div class="flex flex-row items-center">
                <div class="mx-3 h-3 w-px bg-black/10"></div>
                <div class="flex flex-row items-center gap-x-1">
                  <svg viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-neutral-500" weight="duotone"><path opacity="0.2" fill="currentColor" d="M2.96094 2.95996H13.040939999999999V13.03996H2.96094z"></path><path d="M13.041 2.96l-3.94 3.955M9.098 2.96h3.94v3.955M2.963 13.04l3.94-3.955M6.906 13.04H2.963V9.084M13.037 9.085v3.395a.56.56 0 01-.56.56H9.099M6.902 2.96H3.521a.56.56 0 00-.56.56v3.395" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"></path></svg>
                  <span class="whitespace-nowrap text-sm text-neutral-600">${apt.area || 0} m²</span>
                </div>
              </div>
            </div>
          </a>
        </div>
        `;
      }).join('');
    }

    try {
      const res = await fetch(BACKEND_URL + "/api/apartments/hot-transfers");
      if (!res.ok) return;
      const result = await res.json();
      
      MASTER_APARTMENTS = Array.isArray(result) ? result : (result.apartments || result.data || []);

      const projectsList = result.projects || result.project_list || result.data_projects || [];
      if (Array.isArray(projectsList)) {
        projectsList.forEach(p => {
          if (p && p.id) PROJECT_LOOKUP_MAP[String(p.id)] = p;
        });
      }
      MASTER_APARTMENTS.forEach(apt => {
        if (apt.project && apt.project.id) {
          PROJECT_LOOKUP_MAP[String(apt.project.id)] = apt.project;
        }
      });

      // Đảo Tab thông minh: Nếu tab Có sổ mặc định trống hàng, tự lật sang tab có hàng thật để màn hình không bị trống
      if (getFilteredItems('hasbook').length === 0) {
        if (getFilteredItems('handedover').length > 0) { currentTab = 'handedover'; }
        else if (getFilteredItems('construction').length > 0) { currentTab = 'construction'; }
      }
      updateTabUI(currentTab);

      const buttonsContainer = document.getElementById('hot-tabs-buttons-group');
      if (buttonsContainer) {
        const buttons = buttonsContainer.querySelectorAll('.hot-tab-btn');
        buttons.forEach(btn => {
          btn.addEventListener('click', function() {
            currentTab = this.getAttribute('data-status');
            updateTabUI(currentTab);
            renderHotItems();
          });
        });
      }

      renderHotItems();

      if (skeleton) skeleton.classList.add('hidden');
      if (grid) grid.classList.remove('hidden');
    } catch (e) {
      console.error("Lỗi sập luồng tải khối sang nhượng HOT:", e);
      if (skeleton) skeleton.classList.add('hidden');
    }
  })();
</script>