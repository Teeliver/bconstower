---
// src/components/home/QuickStats.astro
// Khối số liệu thống kê phiên bản Compact - Tối ưu không gian dọc, tinh sạch thị giác
---

<section class="w-full py-14 bg-white border-b border-[#E1E7E7]/60 animate-fadeIn">
  <div class="max-w-7xl mx-auto px-5">
    
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6 md:gap-4 divide-x-0 sm:divide-x divide-[#E1E7E7]/60">
      
      <div class="text-center space-y-0.5">
        <div class="text-2xl sm:text-3xl font-black font-heading text-[#005043] tracking-tight">
          1.500+
        </div>
        <div class="text-[11px] sm:text-xs font-bold font-body text-[#686B6B] uppercase tracking-wider">
          Giỏ Hàng Chính Chủ
        </div>
      </div>

      <div class="text-center space-y-0.5">
        <div class="text-2xl sm:text-3xl font-black font-heading text-[#005043] tracking-tight">
          10+
        </div>
        <div class="text-[11px] sm:text-xs font-bold font-body text-[#686B6B] uppercase tracking-wider">
          Dự Án Bcons Vận Hành
        </div>
      </div>

      <div class="text-center space-y-0.5">
        <div class="text-2xl sm:text-3xl font-black font-heading text-[#005043] tracking-tight">
          99%
        </div>
        <div class="text-[11px] sm:text-xs font-bold font-body text-[#686B6B] uppercase tracking-wider">
          Giao Dịch Có Sổ Hồng
        </div>
      </div>

      <div class="text-center space-y-0.5">
        <div class="text-2xl sm:text-3xl font-black font-heading text-[#005043] tracking-tight">
          24/7
        </div>
        <div class="text-[11px] sm:text-xs font-bold font-body text-[#686B6B] uppercase tracking-wider">
          Hỗ Trợ Thủ Tục Pháp Lý
        </div>
      </div>

    </div>

  </div>
</section>