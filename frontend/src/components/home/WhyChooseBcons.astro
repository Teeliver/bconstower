---
// src/components/home/WhyChooseUs.astro
// Khối lý do chọn thương hiệu bản rút gọn nâng cao - Tiết kiệm Vertical Space, text cô đọng
---

<section class="w-full py-20 bg-[#064e3b] border-b border-black/5 animate-fadeIn">
  <div class="max-w-7xl mx-auto px-5">
    
    <div class="w-full flex flex-col items-center text-center mb-8">
      <!-- Badge chuyển từ nền xanh chữ vàng sang nền Đen chữ Vàng Bcons -->
      <span class="text-[9px] font-black uppercase tracking-widest bg-[#fac72e] text-black px-2.5 py-1 rounded mb-1.5 font-heading">
        Năng Lực Cốt Lõi
      </span>
      <!-- Tiêu đề lớn chuyển sang Đen đậm tương phản cao -->
      <h3 class="text-lg sm:text-xl font-bold font-heading text-white uppercase tracking-tight">
        Vì Sao Chọn Chúng Tôi?
      </h3>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
      
      <!-- Card 1: Giỏ Hàng Realtime -->
      <div class="p-5 bg-white rounded-2xl shadow-sm border border-black/5 flex flex-col justify-center space-y-1.5 hover:shadow-md transition-shadow duration-300">
        <div class="flex items-center gap-2.5">
          <!-- Icon Box chuyển sang nền Đen chữ Vàng Bcons -->
          <div class="w-8 h-8 rounded-lg bg-[#fac72e] text-black flex items-center justify-center shrink-0 shadow-sm">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 1121.21 15H19M9 11l3 3L22 4"/></svg>
          </div>
          <h4 class="text-[16px] md:text-[16px] lg:text-[14px] font-bold font-heading text-[#1E1E1E] uppercase tracking-tight">Giỏ Hàng Realtime</h4>
        </div>
        <p class="text-[16px] md:text-[14px] lg:text-[14px] font-body text-[#686B6B] font-medium leading-relaxed pl-9">
          Đồng bộ kho sản phẩm nội bộ chính xác từng giây.
        </p>
      </div>

      <!-- Card 2: Hàng Chính Chủ -->
      <div class="p-5 bg-white rounded-2xl shadow-sm border border-black/5 flex flex-col justify-center space-y-1.5 hover:shadow-md transition-shadow duration-300">
        <div class="flex items-center gap-2.5">
          <div class="w-8 h-8 rounded-lg bg-[#fac72e] text-black flex items-center justify-center shrink-0 shadow-sm">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
          </div>
          <h4 class="text-[16px] md:text-[16px] lg:text-[14px] font-bold font-heading text-[#1E1E1E] uppercase tracking-tight">Hàng Chính Chủ</h4>
        </div>
        <p class="text-[16px] md:text-[14px] lg:text-[14px] font-body text-[#686B6B] font-medium leading-relaxed pl-9">
          Xác thực trực tiếp với chủ nhà, nói không với tin ảo.
        </p>
      </div>

      <!-- Card 3: Đòn Bẩy Tài Chính -->
      <div class="p-5 bg-white rounded-2xl shadow-sm border border-black/5 flex flex-col justify-center space-y-1.5 hover:shadow-md transition-shadow duration-300">
        <div class="flex items-center gap-2.5">
          <div class="w-8 h-8 rounded-lg bg-[#fac72e] text-black flex items-center justify-center shrink-0 shadow-sm">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5"/></svg>
          </div>
          <h4 class="text-[16px] md:text-[16px] lg:text-[14px] font-bold font-heading text-[#1E1E1E] uppercase tracking-tight">Đòn Bẩy Tài Chính</h4>
        </div>
        <p class="text-[16px] md:text-[14px] lg:text-[14px] font-body text-[#686B6B] font-medium leading-relaxed pl-9">
          Hỗ trợ gói vay 70 - 80% với biên độ lãi suất ưu đãi.
        </p>
      </div>

      <!-- Card 4: Pháp Lý Vững Vàng -->
      <div class="p-5 bg-white rounded-2xl shadow-sm border border-black/5 flex flex-col justify-center space-y-1.5 hover:shadow-md transition-shadow duration-300">
        <div class="flex items-center gap-2.5">
          <div class="w-8 h-8 rounded-lg bg-[#fac72e] text-black flex items-center justify-center shrink-0 shadow-sm">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
          </div>
          <h4 class="text-[16px] md:text-[16px] lg:text-[14px] font-bold font-heading text-[#1E1E1E] uppercase tracking-tight">Pháp Lý Vững Vàng</h4>
        </div>
        <p class="text-[16px] md:text-[14px] lg:text-[14px] font-body text-[#686B6B] font-medium leading-relaxed pl-9">
          Kiểm duyệt quy hoạch nghiêm ngặt, bàn giao sổ nhanh.
        </p>
      </div>

    </div>

  </div>
</section>