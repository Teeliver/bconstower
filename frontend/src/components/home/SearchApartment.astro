---
// src/components/SearchApartment.astro
// Thành phần Bộ lọc Mega Search Bar cao cấp - Đồng bộ 100% cấu trúc BHOMES UI/UX Design System
---

<div class="w-full relative z-30 mt-8 px-4 max-w-[1440px] mx-auto" id="search-bar-root">
  <form 
    action="/can-ho" 
    method="GET" 
    class="w-full bg-white rounded-2xl md:rounded-xl shadow-xl border border-[#E1E7E7]/80 p-4 md:py-3 md:pl-6 md:pr-3 flex flex-col md:flex-row items-center gap-3 md:gap-2 transition-all duration-300 animate-fadeIn"
  >
    <!-- BIẾN ẨN ĐỂ FORM SUBMIT DATA CHUẨN ENDPOINT URL -->
    <input type="hidden" name="price" id="submit-price" value="" />
    <input type="hidden" name="rooms" id="submit-rooms" value="" />
    
    <!-- 1. Ô NHẬP LIỆU (INPUT TEXT): Giữ nguyên bản 100%, tuyệt đối không đổi UI/UX -->
    <div class="w-full md:flex-1 flex items-center gap-3.5 px-3 py-4 md:border-r border-[#E1E7E7]">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#005043" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="flex-shrink-0 opacity-90">
        <circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line>
      </svg>
      <div class="flex-1 min-w-0 text-left">
        <label for="search-keyword" class="block text-[12px] md:text-[14px] font-black uppercase text-[#686B6B] tracking-widest mb-0.5 font-heading">Bạn muốn tìm gì?</label>
        <input 
          type="text" 
          id="search-keyword"
          name="keyword" 
          placeholder="Nhập tên dự án, căn hộ hoặc vị trí..." 
          class="w-full bg-transparent text-sm font-bold text-[#1E1E1E] placeholder-[#686B6B]/40 focus:outline-none border-none p-0 m-0 font-body"
        />
      </div>
    </div>

    <!-- 2. Ô KHOẢNG GIÁ: Thiết kế Custom Dropdown cao cấp -->
    <div class="w-full md:w-[24%] flex items-center gap-3.5 px-3 py-1.5 md:border-r border-[#E1E7E7] relative custom-dropdown-root">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#005043" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" class="flex-shrink-0 opacity-90">
        <line x1="12" y1="1" x2="12" y2="23"></line><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path>
      </svg>
      <div class="flex-1 text-left relative pr-4 cursor-pointer dropdown-trigger select-none">
        <span class="block text-[12px] md:text-[14px] font-black uppercase text-[#686B6B] tracking-widest mb-0.5 font-heading">Khoảng giá tài chính</span>
        <div class="text-sm font-bold text-[#1E1E1E] truncate font-body current-value">Tất cả mức giá</div>
        <svg class="absolute right-0 bottom-1 w-3.5 h-3.5 text-[#686B6B] opacity-70 transition-transform duration-300 arrow-icon" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
      </div>

      <!-- Khung đổ Option kính mờ bo góc nghệ thuật -->
      <div class="absolute top-[105%] left-0 w-full min-w-[220px] bg-white rounded-xl shadow-2xl border border-slate-100 py-1.5 hidden opacity-0 translate-y-2 transition-all duration-200 z-50 dropdown-menu-list">
        <div class="option-item px-4 py-2.5 text-sm font-bold text-slate-700 hover:bg-[#FFC94A]/10 hover:text-[#114232] cursor-pointer transition-colors" data-value="">Tất cả mức giá</div>
        <div class="option-item px-4 py-2.5 text-sm font-bold text-slate-700 hover:bg-[#FFC94A]/10 hover:text-[#114232] cursor-pointer transition-colors" data-value="under-1.5">Dưới 1.5 tỷ</div>
        <div class="option-item px-4 py-2.5 text-sm font-bold text-slate-700 hover:bg-[#FFC94A]/10 hover:text-[#114232] cursor-pointer transition-colors" data-value="1.5-2">1.5 - 2.0 tỷ</div>
        <div class="option-item px-4 py-2.5 text-sm font-bold text-slate-700 hover:bg-[#FFC94A]/10 hover:text-[#114232] cursor-pointer transition-colors" data-value="2-2.5">2.0 - 2.5 tỷ</div>
        <div class="option-item px-4 py-2.5 text-sm font-bold text-slate-700 hover:bg-[#FFC94A]/10 hover:text-[#114232] cursor-pointer transition-colors" data-value="2.5-3">2.5 - 3.0 tỷ</div>
        <div class="option-item px-4 py-2.5 text-sm font-bold text-slate-700 hover:bg-[#FFC94A]/10 hover:text-[#114232] cursor-pointer transition-colors" data-value="above-3">Trên 3 tỷ</div>
      </div>
    </div>

    <!-- 3. Ô CĂN HỘ: Thiết kế Custom Dropdown cao cấp -->
    <div class="w-full md:w-[22%] flex items-center gap-3.5 px-3 py-1.5 relative custom-dropdown-root">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#005043" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" class="flex-shrink-0 opacity-90">
        <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline>
      </svg>
      <div class="flex-1 text-left relative pr-4 cursor-pointer dropdown-trigger select-none">
        <span class="block text-[12px] md:text-[14px] font-black uppercase text-[#686B6B] tracking-widest mb-0.5 font-heading">Thiết kế căn hộ</span>
        <div class="text-sm font-bold text-[#1E1E1E] truncate font-body current-value">Tất cả phòng ngủ</div>
        <svg class="absolute right-0 bottom-1 w-3.5 h-3.5 text-[#686B6B] opacity-70 transition-transform duration-300 arrow-icon" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
      </div>

      <!-- Khung đổ Option kính mờ bo góc nghệ thuật -->
      <div class="absolute top-[105%] left-0 w-full min-w-[200px] bg-white rounded-xl shadow-2xl border border-slate-100 py-1.5 hidden opacity-0 translate-y-2 transition-all duration-200 z-50 dropdown-menu-list">
        <div class="option-item px-4 py-2.5 text-sm font-bold text-slate-700 hover:bg-[#FFC94A]/10 hover:text-[#114232] cursor-pointer transition-colors" data-value="">Tất cả phòng ngủ</div>
        <div class="option-item px-4 py-2.5 text-sm font-bold text-slate-700 hover:bg-[#FFC94A]/10 hover:text-[#114232] cursor-pointer transition-colors" data-value="1">Thiết kế 1 PN</div>
        <div class="option-item px-4 py-2.5 text-sm font-bold text-slate-700 hover:bg-[#FFC94A]/10 hover:text-[#114232] cursor-pointer transition-colors" data-value="2">Thiết kế 2 PN</div>
        <div class="option-item px-4 py-2.5 text-sm font-bold text-slate-700 hover:bg-[#FFC94A]/10 hover:text-[#114232] cursor-pointer transition-colors" data-value="3">Thiết kế 3 PN</div>
      </div>
    </div>

    <!-- NÚT TÌM KIẾM HÀNH ĐỘNG -->
    <div class="w-full md:w-auto flex-shrink-0 pt-1 md:pt-0">
      <button 
        type="submit" 
        class="w-full md:w-auto md:px-7 md:h-12 h-11 rounded-xl md:rounded-2xl bg-[#FFC94A] text-[#114232] hover:bg-[#F48223] hover:text-white font-heading font-black text-xs uppercase tracking-widest flex items-center justify-center gap-2 flex-shrink-0 cursor-pointer transition-all duration-300 shadow-sm active:scale-[0.97] focus:outline-none"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="flex-shrink-0">
          <circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line>
        </svg>
        <span>Tìm Kiếm Ngay</span>
      </button>
    </div>

  </form>
</div>

<script is:inline>
  function initCustomDropdowns() {
    const rootBox = document.getElementById('search-bar-root');
    if (!rootBox) return;

    // Khóa chống kích hoạt lặp khi Astro chuyển trang ngầm định
    if (rootBox.dataset.dropdownInitialized === 'true') return;
    rootBox.dataset.dropdownInitialized = 'true';

    const dropdownRoots = rootBox.querySelectorAll('.custom-dropdown-root');
    
    dropdownRoots.forEach((root, index) => {
      const trigger = root.querySelector('.dropdown-trigger');
      const menu = root.querySelector('.dropdown-menu-list');
      const arrow = root.querySelector('.arrow-icon');
      const textDisplay = root.querySelector('.current-value');
      const items = root.querySelectorAll('.option-item');
      
      // Định hướng map Id trường input ẩn dựa trên cấu trúc vị trí cụm để nạp value dữ liệu
      const hiddenInputId = (index === 0) ? "submit-price" : "submit-rooms";
      const hiddenInput = document.getElementById(hiddenInputId);

      if (!trigger || !menu) return;

      // 1. Click mở và ngăn chặn bong bóng sự kiện tắt tức thì
      trigger.addEventListener('click', function(e) {
        e.preventDefault();
        e.stopPropagation();
        
        // Đóng toàn bộ các dropdown khác đang mở trên trang
        dropdownRoots.forEach(otherRoot => {
          if (otherRoot !== root) {
            const otherMenu = otherRoot.querySelector('.dropdown-menu-list');
            const otherArrow = otherRoot.querySelector('.arrow-icon');
            if (otherMenu && !otherMenu.classList.contains('hidden')) {
              otherMenu.classList.add('opacity-0', 'translate-y-2');
              if (otherArrow) otherArrow.classList.remove('rotate-180');
              setTimeout(() => { otherMenu.classList.add('hidden'); }, 150);
            }
          }
        });

        const isHidden = menu.classList.contains('hidden');
        if (isHidden) {
          menu.classList.remove('hidden');
          // Delay siêu nhỏ 10ms để trình duyệt kịp tính toán khung chuyển động CSS mượt mà
          setTimeout(() => {
            menu.classList.remove('opacity-0', 'translate-y-2');
          }, 10);
          if (arrow) arrow.classList.add('rotate-180');
        } else {
          menu.classList.add('opacity-0', 'translate-y-2');
          if (arrow) arrow.classList.remove('rotate-180');
          setTimeout(() => { menu.classList.add('hidden'); }, 150);
        }
      });

      // 2. Luồng gán giá trị khi nhấp chọn Option
      items.forEach(item => {
        item.addEventListener('click', function(e) {
          e.stopPropagation();
          const selectedText = item.innerText;
          const selectedValue = item.getAttribute('data-value') || '';

          if (textDisplay) textDisplay.innerText = selectedText;
          if (hiddenInput) hiddenInput.value = selectedValue;

          // Đóng menu sau khi chọn xong
          menu.classList.add('opacity-0', 'translate-y-2');
          if (arrow) arrow.classList.remove('rotate-180');
          setTimeout(() => { menu.classList.add('hidden'); }, 150);
        });
      });
    });

    // Click bất cứ đâu ngoài màn hình tự động thu gọn dẹp hết menu đang bung
    document.addEventListener('click', function() {
      dropdownRoots.forEach(root => {
        const menu = root.querySelector('.dropdown-menu-list');
        const arrow = root.querySelector('.arrow-icon');
        if (menu && !menu.classList.contains('hidden')) {
          menu.classList.add('opacity-0', 'translate-y-2');
          if (arrow) arrow.classList.remove('rotate-180');
          setTimeout(() => { menu.classList.add('hidden'); }, 150);
        }
      });
    });
  }

  // Chạy đồng bộ nhịp đầu đón đầu vòng đời của Astro Router tĩnh
  initCustomDropdowns();
  document.addEventListener('DOMContentLoaded', initCustomDropdowns);
  document.addEventListener('astro:page-load', initCustomDropdowns);
</script>

<style>
  @import "tailwindcss";
  
  @keyframes fadeIn { 
    from { opacity: 0; transform: translateY(12px); } 
    to { opacity: 1; transform: translateY(0); } 
  }
  .animate-fadeIn { animation: fadeIn 0.45s cubic-bezier(0.16, 1, 0.3, 1) forwards; }
  
  .arrow-icon {
    transition: transform 0.25s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .rotate-180 {
    transform: rotate(180deg);
  }
</style>