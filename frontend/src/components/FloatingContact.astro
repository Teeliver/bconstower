---
// src/components/FloatingContact.astro
// Component tĩnh, 100% không crash Server-side Render

const PHONE_NUMBER = "0911502603"; // Số điện thoại liên hệ của hệ thống
const ZALO_LINK = "https://zalo.me/0911502603";
---

<div class="fixed bottom-6 left-6 z-[999] flex flex-col gap-y-3 font-sans select-none animate-fadeIn">


  <!-- Nút Chat Zalo -->
  <a 
    href={ZALO_LINK} 
    target="_blank" 
    rel="noopener noreferrer" 
    class="flex h-12 w-12 items-center justify-center rounded-full bg-[#0068ff] text-white shadow-lg transition-all duration-300 hover:scale-110 hover:shadow-xl font-black text-xl border border-white/20"
    title="Chat qua Zalo"
  >
    <span class="leading-none pb-0.5">Z</span>
  </a>

  <!-- Nút Gọi Hotline (Kèm hiệu ứng sóng xung kích nhấp nháy thu hút khách Lead) -->
  <a 
    href={`tel:${PHONE_NUMBER}`} 
    class="relative flex h-12 w-12 items-center justify-center rounded-full bg-[#fac72e] text-black shadow-lg transition-all duration-300 hover:scale-110 hover:shadow-xl group"
    title="Gọi ngay Hotline tư vấn"
  >
    <!-- Vòng tròn hiệu ứng radar lan tỏa -->
    <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-[#fac72e]/70 opacity-75"></span>
    
    <svg xmlns="http://www.w3.org/2000/xl" class="h-5 w-5 animate-pulse relative z-10" fill="currentColor" viewBox="0 0 24 24">
      <path d="M1.5 4.5C1.5 2.84315 2.84315 1.5 4.5 1.5H5.87163C6.732 1.5 7.48197 2.08556 7.69064 2.92025L8.79644 7.34343C8.97941 8.0753 8.70594 8.84555 8.10242 9.29818L6.8088 10.2684C6.67447 10.3691 6.64527 10.5167 6.683 10.6197C7.81851 13.7195 10.2805 16.1815 13.3803 17.317C13.4833 17.3547 13.6309 17.3255 13.7316 17.1912L14.7018 15.8976C15.1545 15.2941 15.9247 15.0206 16.6566 15.2036L21.0798 16.3094C21.9144 16.518 22.5 17.268 22.5 18.1284V19.5C22.5 21.1569 21.1569 22.5 19.5 22.5H17.25C8.55151 22.5 1.5 15.4485 1.5 6.75V4.5Z"/>
    </svg>
  </a>

</div>

<style>
  @keyframes fadeIn { from { opacity: 0; transform: translateY(12px); } to { opacity: 1; transform: translateY(0); } }
  .animate-fadeIn { animation: fadeIn 0.4s ease-out forwards; }
</style>