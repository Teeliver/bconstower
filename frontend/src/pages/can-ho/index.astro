      html += '</div>';
      return html;
    }).join('');

    if (FILTERED_APARTMENTS.length > VISIBLE_COUNT) {
      loadMoreContainer.classList.remove('hidden');
    } else {
      loadMoreContainer.classList.add('hidden');
    }
  }

  function applyFilters() {
    const projVal = activeFilters.project;
    const priceVal = activeFilters.price;
    const dirVal = activeFilters.direction;
    const floorVal = activeFilters.floor;
    const keywordVal = activeFilters.keyword;
    const roomsVal = activeFilters.rooms;

    FILTERED_APARTMENTS = MASTER_APARTMENTS.filter(function(apt) {
      if (keywordVal) {
        const kw = keywordVal.toLowerCase().trim();
        const aptName = String(apt.name || '').toLowerCase();
        const prName = String(apt.project_name || apt.projectName || (apt.projectInfo && apt.projectInfo.name) || '').toLowerCase();
        if (!aptName.includes(kw) && !prName.includes(kw)) return false;
      }

      if (roomsVal) {
        if (String(apt.bedrooms) !== String(roomsVal)) return false;
      }

      if (projVal !== 'all') {
        const pName = String(apt.project_name || apt.projectName || (apt.projectInfo && apt.projectInfo.name) || '').toLowerCase();
        if (!pName.includes(projVal)) return false;
      }
      
      if (priceVal === 'under-1.5' && Number(apt.price) >= 1500000000) return false;
      if (priceVal === '1.5-2' && (Number(apt.price) < 1500000000 || Number(apt.price) > 2000000000)) return false;
      if ((priceVal === 'over-2' || priceVal === 'above-3' || priceVal === '2-2.5' || priceVal === '2.5-3') && Number(apt.price) <= 2000000000) return false;

      if (dirVal !== 'all') {
        const aptDir = String(apt.direction_balcony || apt.direction || '').toLowerCase();
        if (!aptDir.includes(dirVal)) return false;
      }

      if (floorVal !== 'all') {
        const floorNum = parseInt(apt.floor) || 0;
        if (floorVal === 'low' && floorNum >= 8) return false;
        if (floorVal === 'mid' && (floorNum < 8 || floorNum > 18)) return false;
        if (floorVal === 'high' && floorNum <= 18) return false;
      }

      return true;
    });

    if (activeSort === 'price-asc') {
      FILTERED_APARTMENTS.sort(function(a, b) { return Number(a.price) - Number(b.price); });
    } else if (activeSort === 'price-desc') {
      FILTERED_APARTMENTS.sort(function(a, b) { return Number(b.price) - Number(a.price); });
    } else if (activeSort === 'area-desc') {
      FILTERED_APARTMENTS.sort(function(a, b) { return Number(b.area) - Number(a.area); });
    }

    VISIBLE_COUNT = 24;
    renderApartmentSlice();
  }

  async function loadAllApartmentsData() {
    const skeleton = document.getElementById('project-skeleton');
    try {
      // 🔥 ĐÃ ĐỒNG BỘ: Kết nối luồng qua endpoint danh mục công khai chuyên dụng vừa tạo trên Laravel
      const res = await fetch(BACKEND_URL + "/api/apartments/public-list");
      if (!res.ok) throw new Error("API sập luồng mạng");
      const result = await res.json();

      // 🧠 THÍCH ỨNG PAYLOAD KÉP: Tương thích mượt mà cả dạng mảng lồng lẫn mảng phẳng của API
      MASTER_APARTMENTS = Array.isArray(result) ? result : (result.apartments || result.data || []);
      
      if (MASTER_APARTMENTS.length > 0) {
        let firstAptImgs = [];
        const leadImgRaw = MASTER_APARTMENTS[0].image;
        if (leadImgRaw) {
          if (typeof leadImgRaw === 'string') {
            if (leadImgRaw.trim().startsWith('[') && leadImgRaw.trim().endsWith(']')) {
              try { firstAptImgs = JSON.parse(leadImgRaw); } catch(e){}
            } else { firstAptImgs = [leadImgRaw]; }
          } else if (Array.isArray(leadImgRaw)) { firstAptImgs = leadImgRaw; }
        }
        if (firstAptImgs && firstAptImgs.length > 0) {
          const leadImgPath = firstAptImgs[0];
          const fullHeroImgUrl = leadImgPath.startsWith('http') ? leadImgPath : (BACKEND_URL.replace(/\/$/, '') + '/' + leadImgPath.replace(/^\//, ''));
          const heroEl = document.getElementById('all-apartments-hero-img');
          if (heroEl) heroEl.setAttribute('src', fullHeroImgUrl);
        }
      }

      populateProjectFilterOptions();
      initCustomDropdowns();

      if (activeFilters.price && activeFilters.price !== 'all') {
        const priceDropdown = document.getElementById('dropdown-price');
        if (priceDropdown) {
          const displayVal = priceDropdown.querySelector('.display-value');
          const matchingOption = priceDropdown.querySelector(`[data-value="${activeFilters.price}"]`);
          if (displayVal) {
            if (matchingOption) {
              displayVal.textContent = matchingOption.textContent;
            } else {
              if (activeFilters.price === 'above-3' || activeFilters.price === '2-2.5' || activeFilters.price === '2.5-3') {
                displayVal.textContent = 'Trên 2 tỷ';
              }
            }
          }
        }
      }

      applyFilters();

      if (skeleton) skeleton.classList.add('hidden');

      document.getElementById('btn-load-more').addEventListener('click', function() {
        VISIBLE_COUNT += 12;
        renderApartmentSlice();
      });

    } catch (e) {
      console.error("Lỗi đồng bộ kho căn hộ tổng:", e);
      if (skeleton) skeleton.classList.add('hidden');
    }
  }

  loadAllApartmentsData();
</script>

