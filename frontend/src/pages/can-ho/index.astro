---
import MainLayout from "../../layouts/MainLayout.astro";
import Navbar from '../../components/Navbar.astro';

// 🔥 ĐỒNG BỘ HỆ THỐNG: Lấy trực tiếp biến cấu hình từ file .env của Trung Tín
const PUBLIC_API_BASE = import.meta.env.PUBLIC_API_BASE || "http://localhost:3000";
---

<MainLayout title="Toàn bộ giỏ hàng căn hộ Bcons mới nhất 2026">
  <div class="bg-white w-full overflow-x-hidden break-words min-h-screen pb-24 font-sans text-slate-800">
    
    <div class="w-full bg-[#064e3b] relative py-10 sm:py-12 animate-fadeIn overflow-hidden mt-20">
      <div class="absolute inset-0 bg-[linear-gradient(to_right,rgba(255,255,255,0.03)_1px,transparent_1px),linear-gradient(to_bottom,rgba(255,255,255,0.03)_1px,transparent_1px)] bg-[size:3rem_3rem]"></div>
      
      <div class="max-w-7xl mx-auto w-full px-4 relative z-10 grid grid-cols-1 lg:grid-cols-12 gap-8 items-center">
        <div class="lg:col-span-7 space-y-4 text-white">
          <div class="space-y-1">
            <div class="inline-flex items-center gap-1.5 px-4 py-2 rounded-md bg-white/30 text-white text-[10px] md:text-[12px] font-medium uppercase tracking-wider">
              <span class="w-1.5 h-1.5 rounded-full bg-black animate-pulse"></span>
              Kho dữ liệu tổng hợp căn hộ ký gửi toàn hệ thống 2026
            </div>
            <h1 class="text-[18px] text-[#fac72e] sm:text-3xl font-black uppercase tracking-tight leading-tight mt-4">
              Danh sách tất cả căn hộ Bcons giá tốt
            </h1>
          </div>
          <p class="text-lg sm:text-[16px] text-justify text-white max-w-xl leading-relaxed">
            Hệ thống lọc thông minh kết nối trực tiếp kho sản phẩm ký gửi, chuyển nhượng căn hộ 1PN, 2PN, 3PN diện tích đa dạng trên toàn bộ chuỗi dự án của Bcons.
          </p>
          <p class="text-lg sm:text-[16px] text-justify text-white max-w-xl leading-relaxed">
            Giỏ hàng được tổng hợp từ hàng khách hàng ký gửi và giỏ hàng từ Chủ Đầu Tư. 
          </p>
        </div>

        <div class="lg:col-span-5 w-full">
          <div class="relative aspect-[16/10] rounded-2xl overflow-hidden bg-white/10 border border-white/10 shadow-xl">
            <img src="/images/no-photo.jpg" id="all-apartments-hero-img" class="w-full h-full object-cover" alt="Tổng kho căn hộ Bcons" />
          </div>
        </div>
      </div>
    </div>

    <div class="max-w-7xl mx-auto px-4 pt-6">
      
      <div class="flex flex-wrap gap-4 mb-6 animate-fadeIn relative z-30">
        
        <div class="flex flex-col gap-1 min-w-full md:min-w-[180px]">
          <span class="text-[12px] text-slate-700 font-bold pl-1">Thuộc dự án</span>
          <div class="dropdown-container border border-slate-200 rounded-[1rem] px-4 bg-white relative flex items-center h-[48px] transition-all duration-200 cursor-pointer select-none" id="dropdown-project">
            <div class="text-sm font-bold text-slate-800 display-value">Tất cả dự án</div>
            <div class="absolute right-4 top-1/2 -translate-y-1/2 text-slate-400 pointer-events-none transition-transform duration-200 chevron-icon flex items-center">
              <svg class="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"></path></svg>
            </div>
            <div class="absolute left-0 top-[calc(100%+6px)] min-w-full w-max bg-white rounded-2xl shadow-[0_10px_30px_rgba(0,0,0,0.1)] py-1.5 hidden dropdown-menu border border-slate-100 overflow-hidden whitespace-nowrap z-50" id="menu-dynamic-projects">
              <div class="px-4 py-2.5 text-sm font-bold text-slate-700 hover:bg-slate-50 hover:text-orange-500 transition-colors cursor-pointer option-item" data-value="all">Tất cả dự án</div>
            </div>
          </div>
        </div>

        <div class="flex flex-col gap-1 min-w-full md:min-w-[180px]">
          <span class="text-[12px] text-slate-700 font-bold pl-1">Khoảng giá</span>
          <div class="dropdown-container border border-slate-200 rounded-[1rem] px-4 bg-white relative flex items-center h-[48px] transition-all duration-200 cursor-pointer select-none" id="dropdown-price">
            <div class="text-sm font-bold text-slate-800 display-value">Tất cả</div>
            <div class="absolute right-4 top-1/2 -translate-y-1/2 text-slate-400 pointer-events-none transition-transform duration-200 chevron-icon flex items-center">
              <svg class="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"></path></svg>
            </div>
            <div class="absolute left-0 top-[calc(100%+6px)] min-w-full w-max bg-white rounded-2xl shadow-[0_10px_30px_rgba(0,0,0,0.1)] py-1.5 hidden dropdown-menu border border-slate-100 overflow-hidden whitespace-nowrap z-50">
              <div class="px-4 py-2.5 text-sm font-bold text-slate-700 hover:bg-slate-50 hover:text-orange-500 transition-colors cursor-pointer option-item" data-value="all">Tất cả khoảng giá</div>
              <div class="px-4 py-2.5 text-sm font-bold text-slate-700 hover:bg-slate-50 hover:text-orange-500 transition-colors cursor-pointer option-item" data-value="under-1.5">Dưới 1,5 tỷ</div>
              <div class="px-4 py-2.5 text-sm font-bold text-slate-700 hover:bg-slate-50 hover:text-orange-500 transition-colors cursor-pointer option-item" data-value="1.5-2">1,5 - 2 tỷ</div>
              <div class="px-4 py-2.5 text-sm font-bold text-slate-700 hover:bg-slate-50 hover:text-orange-500 transition-colors cursor-pointer option-item" data-value="over-2">Trên 2 tỷ</div>
            </div>
          </div>
        </div>

        <div class="flex flex-col gap-1 min-w-full md:min-w-[180px]">
          <span class="text-[12px] text-slate-700 font-bold pl-1">Hướng nhà</span>
          <div class="dropdown-container border border-slate-200 rounded-[1rem] px-4 bg-white relative flex items-center h-[48px] transition-all duration-200 cursor-pointer select-none" id="dropdown-direction">
            <div class="text-sm font-bold text-slate-800 display-value">Tất cả</div>
            <div class="absolute right-4 top-1/2 -translate-y-1/2 text-slate-400 pointer-events-none transition-transform duration-200 chevron-icon flex items-center">
              <svg class="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"></path></svg>
            </div>
            <div class="absolute left-0 top-[calc(100%+6px)] min-w-full w-max bg-white rounded-2xl shadow-[0_10px_30px_rgba(0,0,0,0.1)] py-1.5 hidden dropdown-menu border border-slate-100 overflow-hidden whitespace-nowrap z-50">
              <div class="px-4 py-2.5 text-sm font-bold text-slate-700 hover:bg-slate-50 hover:text-orange-500 transition-colors cursor-pointer option-item" data-value="all">Tất cả hướng</div>
              <div class="px-4 py-2.5 text-sm font-bold text-slate-700 hover:bg-slate-50 hover:text-orange-500 transition-colors cursor-pointer option-item" data-value="đông">Hướng Đông / Đông Nam</div>
              <div class="px-4 py-2.5 text-sm font-bold text-slate-700 hover:bg-slate-50 hover:text-orange-500 transition-colors cursor-pointer option-item" data-value="nam">Hướng Nam</div>
              <div class="px-4 py-2.5 text-sm font-bold text-slate-700 hover:bg-slate-50 hover:text-orange-500 transition-colors cursor-pointer option-item" data-value="tây">Hướng Tây / Tây Nam</div>
              <div class="px-4 py-2.5 text-sm font-bold text-slate-700 hover:bg-slate-50 hover:text-orange-500 transition-colors cursor-pointer option-item" data-value="bắc">Hướng Bắc</div>
            </div>
          </div>
        </div>

        <div class="flex flex-col gap-1 min-w-full md:min-w-[180px]">
          <span class="text-[12px] text-slate-700 font-bold pl-1">Vị trí tầng</span>
          <div class="dropdown-container border border-slate-200 rounded-[1rem] px-4 bg-white relative flex items-center h-[48px] transition-all duration-200 cursor-pointer select-none" id="dropdown-floor">
            <div class="text-sm font-bold text-slate-800 display-value">Tất cả</div>
            <div class="absolute right-4 top-1/2 -translate-y-1/2 text-slate-400 pointer-events-none transition-transform duration-200 chevron-icon flex items-center">
              <svg class="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"></path></svg>
            </div>
            <div class="absolute left-0 top-[calc(100%+6px)] min-w-full w-max bg-white rounded-2xl shadow-[0_10px_30px_rgba(0,0,0,0.1)] py-1.5 hidden dropdown-menu border border-slate-100 overflow-hidden whitespace-nowrap z-50">
              <div class="px-4 py-2.5 text-sm font-bold text-slate-700 hover:bg-slate-50 hover:text-orange-500 transition-colors cursor-pointer option-item" data-value="all">Tất cả tầng</div>
              <div class="px-4 py-2.5 text-sm font-bold text-slate-700 hover:bg-slate-50 hover:text-orange-500 transition-colors cursor-pointer option-item" data-value="low">Tầng thấp (Dưới tầng 8)</div>
              <div class="px-4 py-2.5 text-sm font-bold text-slate-700 hover:bg-slate-50 hover:text-orange-500 transition-colors cursor-pointer option-item" data-value="mid">Tầng trung (Tầng 8 - 18)</div>
              <div class="px-4 py-2.5 text-sm font-bold text-slate-700 hover:bg-slate-50 hover:text-orange-500 transition-colors cursor-pointer option-item" data-value="high">Tầng cao (Trên tầng 18)</div>
            </div>
          </div>
        </div>

      </div>

      <nav class="flex text-[13px] text-slate-400 font-medium mb-3 animate-fadeIn">
        <a href="/" class="hover:underline">Trang chủ</a>
        <span class="mx-2 text-slate-300">&gt;</span>
        <span class="text-slate-600 font-semibold">Danh sách căn hộ tổng hợp</span>
      </nav>

      <h2 class="text-xl font-black text-slate-900 tracking-tight mb-2 animate-fadeIn">
        Mua bán căn hộ chung cư Bcons giá tốt nhất
      </h2>

      <div class="flex justify-between items-center border-b border-slate-100 pb-4 mb-6 text-sm text-slate-500 font-medium animate-fadeIn relative z-25">
        <div>Tổng cộng: <span id="results-count" class="font-bold text-slate-800">0</span> sản phẩm ký gửi</div>
        
        <div class="dropdown-container relative flex items-center gap-1 cursor-pointer select-none hover:text-slate-800 transition-colors text-slate-500 font-bold text-xs" id="dropdown-sort">
          <span>Sắp xếp: <span class="display-value font-black text-slate-700">Phù hợp nhất</span></span>
          <div class="chevron-icon transition-transform duration-200 mt-0.5">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"></path></svg>
          </div>
          <div class="absolute right-0 top-[calc(100%+6px)] min-w-full w-max bg-white rounded-xl shadow-[0_10px_30px_rgba(0,0,0,0.1)] py-1 hidden dropdown-menu border border-slate-100 overflow-hidden text-slate-700 text-left whitespace-nowrap">
            <div class="px-4 py-2 text-xs font-bold hover:bg-slate-50 hover:text-orange-500 transition-colors cursor-pointer option-item shadow-sm" data-value="all">Phù hợp nhất</div>
            <div class="px-4 py-2 text-xs font-bold hover:bg-slate-50 hover:text-orange-500 transition-colors cursor-pointer option-item shadow-sm" data-value="price-asc">Giá thấp đến cao</div>
            <div class="px-4 py-2 text-xs font-bold hover:bg-slate-50 hover:text-orange-500 transition-colors cursor-pointer option-item shadow-sm" data-value="price-desc">Giá cao đến thấp</div>
            <div class="px-4 py-2 text-xs font-bold hover:bg-slate-50 hover:text-orange-500 transition-colors cursor-pointer option-item" data-value="area-desc">Diện tích lớn nhất</div>
          </div>
        </div>
      </div>

      <div id="project-skeleton" class="grid grid-cols-2 md:grid-cols-4 gap-x-6 gap-y-8 animate-pulse">
        {[1, 2, 3, 4, 5, 6, 7, 8].map(() => (
          <div class="space-y-3">
            <div class="aspect-[4/3] bg-slate-100 rounded-xl w-full"></div>
            <div class="h-4 bg-slate-100 rounded w-2/3"></div>
            <div class="h-3 bg-slate-100 rounded w-1/2"></div>
          </div>
        ))}
      </div>

      <div id="project-apartments-grid" class="grid grid-cols-1 md:grid-cols-3 gap-x-6 gap-y-8 hidden"></div>

      <div id="load-more-container" class="w-full flex justify-center mt-16 hidden">
        <button type="button" id="btn-load-more" class="px-8 h-11 rounded-xl bg-white border border-slate-200 hover:border-[#006B5D] text-slate-700 hover:text-[#006B5D] font-bold text-xs shadow-sm transition-all duration-200 select-none cursor-pointer uppercase tracking-wider">
          Xem thêm căn hộ ký gửi
        </button>
      </div>

      <div id="empty-project-message" class="hidden text-center py-20 bg-slate-50 border border-slate-100 rounded-2xl animate-fadeIn">
        <div class="text-4xl mb-2">🏢</div>
        <p class="font-bold text-slate-700 text-sm">Không tìm thấy căn hộ phù hợp với bộ lọc hiện tại</p>
        <p class="text-xs text-slate-400 mt-1">Trung Tín hãy thử thay đổi lựa chọn khoảng giá hoặc tên dự án Bcons nhé!</p>
      </div>

    </div>
  </div>
</MainLayout>

<script define:vars={{ PUBLIC_API_BASE }}>
  const BACKEND_URL = PUBLIC_API_BASE;

  // 🔥 LUỒNG KẾT NỐI TÌM KIẾM ĐỘNG: Đọc trực tiếp các tham số bộ lọc từ Trang chủ bắn qua URL
  const urlParams = new URLSearchParams(window.location.search);
  const urlKeyword = urlParams.get('keyword') || '';
  const urlPrice = urlParams.get('price') || '';
  const urlRooms = urlParams.get('rooms') || '';

  let MASTER_APARTMENTS = [];
  let FILTERED_APARTMENTS = [];
  let VISIBLE_COUNT = 24; 

  // Quản lý trạng thái lọc động lồng ghép tham số từ Trang chủ
  let activeFilters = {
    project: 'all',
    price: urlPrice || 'all',
    direction: 'all',
    floor: 'all',
    keyword: urlKeyword, // Lưu trữ từ khóa phục vụ lọc live
    rooms: urlRooms       // Lưu trữ số phòng ngủ phục vụ lọc live
  };
  let activeSort = 'all'; 

  // 🔒 BẢO MẬT XSS TUYỆT ĐỐI: Bộ giải mã làm sạch chuỗi thô từ DB Laravel đổ về trước khi render HTML
  const escapeHTML = (str) => {
    if (!str) return '';
    return str.replace(/[&<>"']/g, (match) => {
      const map = { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' };
      return map[match] || match;
    });
  };

  function timeAgo(dateString) {
    if (!dateString) return "Mới đăng";
    const pastDate = new Date(dateString);
    const pastTime = pastDate.getTime();
    if (isNaN(pastTime)) return "Mới đăng";
    const currentTime = new Date().getTime();
    const seconds = Math.floor((currentTime - pastTime) / 1000);
    if (seconds < 5) return "Đăng 1 ngày trước";
    let interval = seconds / 86400;
    if (interval >= 1) return "Đăng " + Math.floor(interval) + " ngày trước";
    return "Đăng ngày hôm nay";
  }

  // KHỞI TẠO EVENT LẮNG NGHE DROPDOWN CHUẨN ĐÉT ĐẰNG VIỀN CAM NỔI BẬT
  function initCustomDropdowns() {
    const containers = document.querySelectorAll('.dropdown-container');
    
    containers.forEach(container => {
      container.addEventListener('click', function(e) {
        e.stopPropagation();
        const menu = this.querySelector('.dropdown-menu');
        const chevron = this.querySelector('.chevron-icon');
        const isHidden = menu.classList.contains('hidden');

        // Thu hồi toàn bộ dropdown khác
        containers.forEach(other => {
          other.querySelector('.dropdown-menu').classList.add('hidden');
          const c = other.querySelector('.chevron-icon');
          if (c) c.classList.remove('rotate-180');
          if (other.id !== 'dropdown-sort') {
            other.classList.remove('border-orange-500', 'border-2');
            other.classList.add('border-slate-200');
          }
        });

        // Bung mở menu hiện tại
        if (isHidden) {
          menu.classList.remove('hidden');
          if (chevron) chevron.classList.add('rotate-180');
          if (this.id !== 'dropdown-sort') {
            this.classList.remove('border-slate-200');
            this.classList.add('border-orange-500', 'border-2');
          }
        }
      });
    });

    // SỬ DỤNG EVENT DELEGATION: Cho phép bắt sự kiện click chọn option động
    document.addEventListener('click', function(e) {
      const containers = document.querySelectorAll('.dropdown-container');
      
      if (e.target.classList.contains('option-item')) {
        e.stopPropagation();
        const container = e.target.closest('.dropdown-container');
        const displayVal = container.querySelector('.display-value');
        const value = e.target.getAttribute('data-value');
        const text = e.target.textContent;

        displayVal.textContent = text;
        const filterKey = container.id.replace('dropdown-', '');

        if (filterKey === 'sort') {
          activeSort = value;
        } else {
          activeFilters[filterKey] = value;
        }

        applyFilters();
      }

      // Đóng toàn bộ hộp thả
      containers.forEach(container => {
        container.querySelector('.dropdown-menu').classList.add('hidden');
        const chevron = container.querySelector('.chevron-icon');
        if (chevron) chevron.classList.remove('rotate-180');
        if (container.id !== 'dropdown-sort') {
          container.classList.remove('border-orange-500', 'border-2');
          container.classList.add('border-slate-200');
        }
      });
    });
  }

  function populateProjectFilterOptions() {
    const projectMenu = document.getElementById('menu-dynamic-projects');
    
    const projectNames = [...new Set(MASTER_APARTMENTS.map(function(apt) {
      return apt.project_name || apt.projectName || (apt.projectInfo && apt.projectInfo.name) || '';
    }))].filter(Boolean);

    if (projectNames.length > 0) {
      projectMenu.innerHTML = '<div class="px-4 py-2.5 text-sm font-bold text-slate-700 hover:bg-slate-50 hover:text-orange-500 transition-colors cursor-pointer option-item" data-value="all">Tất cả dự án</div>' + 
      projectNames.map(function(name) {
        const safeMenuName = escapeHTML(name);
        return '<div class="px-4 py-2.5 text-sm font-bold text-slate-700 hover:bg-slate-50 hover:text-orange-500 transition-colors cursor-pointer option-item" data-value="' + safeMenuName.toLowerCase().trim() + '">' + safeMenuName + '</div>';
      }).join('');
    }
  }

  function renderApartmentSlice() {
    const grid = document.getElementById('project-apartments-grid');
    const loadMoreContainer = document.getElementById('load-more-container');
    const emptyBox = document.getElementById('empty-project-message');
    const resultsCountEl = document.getElementById('results-count');

    resultsCountEl.textContent = FILTERED_APARTMENTS.length.toLocaleString('vi-VN');

    if (FILTERED_APARTMENTS.length === 0) {
      grid.classList.add('hidden');
      loadMoreContainer.classList.add('hidden');
      emptyBox.classList.remove('hidden');
      return;
    }

    emptyBox.classList.add('hidden');
    grid.classList.remove('hidden');

    const itemsToRender = FILTERED_APARTMENTS.slice(0, VISIBLE_COUNT);

    grid.innerHTML = itemsToRender.map(function(apt) {
      let itemImages = [];
      if (apt.image) {
        if (typeof apt.image === 'string') {
          if (apt.image.trim().startsWith('[') && apt.image.trim().endsWith(']')) {
            try { itemImages = JSON.parse(apt.image); } catch(e) { itemImages = [apt.image]; }
          } else { itemImages = [apt.image]; }
        } else if (Array.isArray(apt.image)) { itemImages = apt.image; }
      }

      // ⚡ PHÒNG THỦ ĐƯỜNG DẪN ẢNH: Khử hoàn toàn lỗi trùng hoặc mất dấu xuyệt gạch chéo
      const rawThumb = (itemImages && itemImages.length > 0) ? itemImages[0] : '';
      const thumb = rawThumb 
        ? (rawThumb.startsWith('http') ? rawThumb : (BACKEND_URL.replace(/\/$/, '') + '/' + rawThumb.replace(/^\//, ''))) 
        : '/images/no-photo.jpg';
      
      const priceBillion = apt.price ? (apt.price / 1000000000).toFixed(2).replace('.', ',') : '0';
      const pricePerM2 = (apt.price && apt.area) ? (apt.price / apt.area / 1000000).toFixed(2).replace('.', ',') : '0';
      const realCreatedDate = apt.created_at || apt.createdAt || apt.updated_at || apt.updatedAt;
      const currentProjectSlug = apt.project_slug || apt.projectSlug || (apt.projectInfo && apt.projectInfo.slug) || 'bcons';

      // 🔒 ÁP MÀNG LỌC AN TOÀN CHỐNG TẤN CÔNG XSS ĐẦU RA HTML
      const safeName = escapeHTML(apt.name || '');
      const safeAddress = escapeHTML(apt.project_address || apt.projectAddress || apt.address || 'Bình Dương');
      const safeProjSlug = escapeHTML(currentProjectSlug);
      const safeSlug = escapeHTML(apt.slug || '');

      let html = '<div class="relative w-full">';
      html += '<a href="/' + safeProjSlug + '/' + safeSlug + '" class="focus:outline-none">';
      html += '  <div class="relative aspect-[4/3] rounded-xl overflow-hidden bg-slate-50 border border-slate-100 mb-2.5">';
      html += '    <img src="' + thumb + '" class="w-full h-full object-cover group-hover:scale-[1.02] transition-transform duration-500" alt="' + safeName + '" />';
      html += '    <div class="absolute bottom-2.5 right-2.5 bg-black/50 text-white text-[11px] px-1.5 py-0.5 rounded font-medium flex items-center gap-1">';
      html += '      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>';
      html += '      <span>1/' + (itemImages.length || 1) + '</span>';
      html += '    </div>';
      html += '  </div>';
      
      html += '  <div class="w-full pt-2">';
      html += '    <div class="flex w-full flex-row items-center justify-between gap-x-2">';
      html += '      <span class="font-extrabold text-emerald-700">'+ priceBillion + ' tỷ · ';
      html += '        <span class="text-sm font-semibold">' + pricePerM2 + ' triệu/m²</span>';
      html += '      </span>';
      html += '      <span class="text-xs text-neutral-600">' + timeAgo(realCreatedDate) + '</span>';
      html += '    </div>';
      html += '    <section class="pt-1">';
      html += '     <h6 class="text-base text-lg md:text-sm font-bold text-neutral-900 line-clamp-1" title="' + safeName + '">' + safeName + '</h6>';
      html += '     <p class="pt-0.5 text-lg md:text-sm text-neutral-600">' + safeAddress + '</p>';
      html += '    </section>';
      html += '    <div class="flex flex-row flex-nowrap items-center pt-1.5">';
      html += '      <div class="flex flex-row items-center">';
      html += '         <div class="flex flex-row items-center gap-x-1"><svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" fill="currentColor" viewBox="0 0 256 256" class="h-5 w-5 text-neutral-500"><path d="M248,112v56H112V80H216A32,32,0,0,1,248,112Z" opacity="0.2"></path><path d="M216,72H32V48a8,8,0,0,0-16,0V208a8,8,0,0,0,16,0V176H240v32a8,8,0,0,0,16,0V112A40,40,0,0,0,216,72ZM32,88h72v72H32Zm88,72V88h96a24,24,0,0,1,24,24v48Z"></path></svg><span class="whitespace-nowrap text-lg md:text-sm text-neutral-600">' + ( apt.bedrooms || 0 ) + ' PN</span></div>';
      html += '      </div>';
      html += '      <div class="flex flex-row items-center">';
      html += '         <div class="mx-3 h-3 w-px bg-black/10"></div>';
      html += '         <div class="flex flex-row items-center gap-x-1"><svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" fill="currentColor" viewBox="0 0 256 256" class="h-5 w-5 text-neutral-500"><path d="M240,104v40a48,48,0,0,1-48,48H64a48,48,0,0,1-48-48V104H136v40h64V104Z" opacity="0.2"></path><path d="M240,96H208a8,8,0,0,0-8-8H136a8,8,0,0,0-8,8H64V52A12,12,0,0,1,76,40a12.44,12.44,0,0,1,12.16,9.59,8,8,0,0,0,15.68-3.18A28.32,28.32,0,0,0,76,24,28,28,0,0,0,48,52V96H16a8,8,0,0,0-8,8v40a56.06,56.06,0,0,0,56,56v16a8,8,0,0,0,16,0V200h96v16a8,8,0,0,0,16,0V200a56.06,56.06,0,0,0,56-56V104A8,8,0,0,0,240,96Zm-48,8v32H144V104Zm40,40a40,40,0,0,1-40,40H64a40,40,0,0,1-40-40V112H128v32a8,8,0,0,0,8,8h64a8,8,0,0,0,8-8V112h24Z"></path></svg><span class="whitespace-nowrap text-lg md:text-sm text-neutral-600">' + ( apt.bathrooms || 0 ) + ' WC</span></div>';
      html += '      </div>';
      html += '      <div class="flex flex-row items-center">';
      html += '         <div class="mx-3 h-3 w-px bg-black/10"></div>';
      html += '         <div class="flex flex-row items-center gap-x-1"><svg viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-neutral-500" weight="duotone"><path opacity="0.2" fill="currentColor" d="M2.96094 2.95996H13.040939999999999V13.03996H2.96094z"></path><path d="M13.041 2.96l-3.94 3.955M9.098 2.96h3.94v3.955M2.963 13.04l3.94-3.955M6.906 13.04H2.963V9.084M13.037 9.085v3.395a.56.56 0 01-.56.56H9.099M6.902 2.96H3.521a.56.56 0 00-.56.56v3.395" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"></path></svg><span class="whitespace-nowrap text-lg md:text-sm text-neutral-600">' + (apt.area || 0) + ' m²</span></div>';
