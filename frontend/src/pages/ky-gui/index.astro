---
// src/pages/ky-gui/index.astro
import MainLayout from '../../layouts/MainLayout.astro'; 

const PUBLIC_API_BASE = import.meta.env.PUBLIC_API_BASE || "http://localhost:8000";
---

<MainLayout title="Ký Gửi Căn Hộ Bcons - Nhận Ký Gửi Bán & Cho Thuê Chính Chủ">
  
  <section class="relative max-w-[1260px] mx-2 xl:mx-auto py-14 rounded-xl bg-gradient-to-br from-[#fac72e] via-[#e2b327] to-[#d8aa21] text-white text-center mt-28">
    <div class="absolute inset-0 opacity-10 pointer-events-none" 
         style="background-image: url('https://www.transparenttextures.com/patterns/carbon-fibre.png');">
    </div>
    <div class="max-w-3xl mx-auto px-5 relative z-10 space-y-4 mt-2">
      <span class="text-[10px] font-black uppercase tracking-widest bg-white/30 backdrop-blur-sm text-black px-3 py-1.5 rounded-md inline-block">
        Thủ tục nhanh chóng - Bảo mật thông tin
      </span>
      <h1 class="text-[20px] md:text-4xl font-black uppercase tracking-tight leading-tight">
        Giỏ Hàng Ký Gửi Căn Hộ Bcons
      </h1>
      <p class="text-sm md:text-base text-white max-w-xl mx-auto font-medium leading-relaxed">
        Quý khách hàng có nhu cầu Ký gửi Bán hoặc Cho thuê căn hộ thuộc chuỗi dự án Tập đoàn Bcons, vui lòng để lại thông tin mã căn dưới đây. Chuyên viên sẽ liên hệ check thông tin ngay lập tức.
      </p>
    </div>
  </section>

  <section class="max-w-7xl mx-auto px-2 relative z-20" id="consignment-root" data-api-base={PUBLIC_API_BASE}>
    <div class="bg-amber-50/60 p-6 rounded-3xl border border-amber-100 space-y-3 mt-12 mb-4">
        <h4 class="text-base font-black uppercase tracking-wider text-amber-800 flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-orange-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" /></svg>
            Lưu ý chuẩn bị hồ sơ
        </h4>
        <p class="text-[14px] text-justify text-amber-900/80 font-bold leading-relaxed">
            Để đẩy nhanh quy trình chuyển nhượng hoặc cho thuê căn hộ, quý chủ nhà vui lòng chuẩn bị sẵn hình ảnh: <b>Hợp đồng mua bán (HĐMB)</b> hoặc <b>Sổ hồng chính chủ</b>, kèm theo biên bản bàn giao căn hộ (nếu có).
        </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start mb-10">
      
      <div class="lg:col-span-7 xl:col-span-8 bg-white rounded-3xl p-6 md:p-8 shadow-2xl border border-slate-100">
        <form id="consignment-form" class="space-y-6">
          <h3 class="text-base font-black text-slate-800 uppercase tracking-wide border-b border-slate-100 pb-3 flex items-center gap-2">
            <span class="w-2 h-5 bg-[#e2b327] rounded-sm"></span> 1. Thông tin liên hệ chủ nhà
          </h3>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label class="block text-[10px] font-black uppercase tracking-wider text-slate-400 mb-1.5 ml-1">Họ và tên chủ sở hữu *</label>
              <input type="text" id="owner-name" required placeholder="Nguyễn Văn A" class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:outline-none focus:border-[#064e3b] text-sm font-bold bg-slate-50 text-slate-900 transition-all focus:bg-white" />
            </div>
            <div>
              <label class="block text-[10px] font-black uppercase tracking-wider text-slate-400 mb-1.5 ml-1">Số điện thoại / Zalo liên hệ *</label>
              <input type="tel" id="owner-phone" required placeholder="0911502603" class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:outline-none focus:border-[#064e3b] text-sm font-bold bg-slate-50 text-slate-900 transition-all focus:bg-white" />
            </div>
          </div>

          <h3 class="text-base font-black text-slate-800 uppercase tracking-wide border-b border-slate-100 pb-3 pt-4 flex items-center gap-2">
            <span class="w-2 h-5 bg-[#e2b327] rounded-sm"></span> 2. Thông tin chi tiết căn hộ
          </h3>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label class="block text-[10px] font-black uppercase tracking-wider text-slate-400 mb-1.5 ml-1">Nhu cầu ký gửi</label>
              <select id="apartment-type" class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:outline-none focus:border-[#064e3b] text-sm font-bold bg-slate-50 text-slate-900 cursor-pointer">
                <option value="ban">Cần Ký Gửi Bán Căn Hộ</option>
                <option value="cho_thue">Cần Ký Gửi Cho Thuê</option>
              </select>
            </div>

            <div>
              <label class="block text-[10px] font-black uppercase tracking-wider text-slate-400 mb-1.5 ml-1">Thuộc Dự án Bcons *</label>
              <select id="apartment-project" required class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:outline-none focus:border-[#064e3b] text-sm font-bold bg-slate-50 text-slate-900 cursor-pointer">
                <option value="">-- Chọn dự án căn hộ --</option>
              </select>
            </div>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label class="block text-[10px] font-black uppercase tracking-wider text-slate-400 mb-1.5 ml-1">Mã căn hộ (Block - Tầng - Số căn) *</label>
              <input type="text" id="apartment-code" required placeholder="Ví dụ: Block A - Tầng 15 - Căn 08" class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:outline-none focus:border-[#064e3b] text-sm font-bold bg-slate-50 text-slate-900 transition-all focus:bg-white" />
            </div>
            <div>
              <label class="block text-[10px] font-black uppercase tracking-wider text-slate-400 mb-1.5 ml-1">Giá thu nét mong muốn (Bao thuế phí/Bao lỗ)</label>
              <input type="text" id="apartment-price" placeholder="Ví dụ: 1.85 Tỷ thu nét" class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:outline-none focus:border-[#064e3b] text-sm font-bold bg-slate-50 text-slate-900 transition-all focus:bg-white" />
            </div>
          </div>

          <div>
            <label class="block text-[10px] font-black uppercase tracking-wider text-slate-400 mb-1.5 ml-1">Mô tả tình trạng nội thất / View hướng</label>
            <textarea id="apartment-notes" rows="4" placeholder="Ví dụ: Căn góc view hồ bơi tầng cao, bàn giao nội thất cơ bản chủ đầu tư, đã đóng 70% tiến độ, có hỗ trợ vay ngân hàng..." class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:outline-none focus:border-[#064e3b] text-sm font-bold bg-slate-50 text-slate-900 transition-all focus:bg-white outline-none resize-none"></textarea>
          </div>

          <button type="submit" id="submit-btn" class="w-full py-4 rounded-xl bg-black text-[#e2b327] font-black text-sm uppercase tracking-widest hover:bg-emerald-950 transition-all duration-300 shadow-xl flex items-center justify-center gap-2 cursor-pointer mt-4">
            Gửi Hồ Sơ Ký Gửi Ngay
          </button>
        </form>

        <div id="alert-msg" class="hidden mt-4 p-4 rounded-xl text-center text-xs font-bold animate-fadeIn"></div>
      </div>

      <div class="lg:col-span-5 xl:col-span-4 space-y-5">
        
        <div class="bg-white p-6 rounded-3xl border border-slate-100 shadow-lg space-y-4">
          <h4 class="text-base font-black uppercase tracking-wider text-[#064e3b] flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-orange-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01" /></svg>
            Quy trình tiếp nhận 3 bước
          </h4>
          <ol class="space-y-3.5 text-[14px] text-slate-600 font-bold text-justify">
            <li class="flex gap-3 items-start">
              <span class="w-5 h-5 bg-[#d8aa21] text-black rounded-full flex items-center justify-center text-[10px] font-black shrink-0 mt-0.5">1</span>
              <span><b>Xác thực thông tin:</b> Chuyên viên liên hệ kiểm tra tính chuẩn xác của mã căn, hướng view và tiến độ thanh toán của sản phẩm trong vòng 15 phút.</span>
            </li>
            <li class="flex gap-3 items-start">
              <span class="w-5 h-5 bg-[#d8aa21] text-black rounded-full flex items-center justify-center text-[10px] font-black shrink-0 mt-0.5">2</span>
              <span><b>Định giá tối ưu:</b> Phân tích dữ liệu giỏ hàng và chuyển nhượng thực tế tại dự án để tư vấn mốc giá thanh khoản nhanh nhất cho chủ nhà.</span>
            </li>
            <li class="flex gap-3 items-start">
              <span class="w-5 h-5 bg-[#d8aa21] text-black rounded-full flex items-center justify-center text-[10px] font-black shrink-0 mt-0.5">3</span>
              <span><b>Phân phối siêu tốc:</b> Đưa thông tin sản phẩm tiếp cận nhanh đến 1000+ khách hàng có sẵn nhu cầu lập tức.</span>
            </li>
          </ol>
        </div>

        <div class="bg-[#e2b327] p-6 rounded-3xl text-white shadow-lg space-y-4">
          <h4 class="text-base font-black uppercase tracking-wider text-white flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
            Cam kết dịch vụ chính chủ
          </h4>
          <ul class="space-y-3 text-[14px] text-white font-medium text-justify">
            <li class="flex items-center gap-2.5 text-black">
              <span class="text-black font-black">✓</span>
              <span><b>Tuyệt đối không kê giá:</b> Bán đúng giá chủ nhà mong muốn thu nét, minh bạch trong quá trình đàm phán mua bán.</span>
            </li>
            <li class="flex items-center gap-2.5 text-black">
              <span class="text-black font-black">✓</span>
              <span><b>Bảo mật thông tin:</b> Không rò rỉ số điện thoại, danh tính chủ hộ. Tránh tình trạng bị spam cuộc gọi làm phiền.</span>
            </li>
            <li class="flex items-center gap-2.5 text-black">
              <span class="text-black font-black">✓</span>
              <span><b>Hỗ trợ pháp lý toàn diện:</b> Chuyên viên hỗ trợ trọn gói thủ tục sang tên, hồ sơ vay ngân hàng, thuế thu nhập cá nhân tại phòng công chứng từ A - Z.</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>
</MainLayout>

<script>
  async function setupConsignmentPage() {
    const root = document.getElementById('consignment-root');
    const form = document.getElementById('consignment-form') as HTMLFormElement | null;
    const projectSelect = document.getElementById('apartment-project') as HTMLSelectElement | null;
    if (!root || !form) return;

    if (form.dataset.listenerAttached === 'true') return;
    form.dataset.listenerAttached = 'true';

    const BACKEND_URL = root.getAttribute('data-api-base') || 'http://localhost:8000';
    const btn = document.getElementById('submit-btn') as HTMLButtonElement | null;
    const alertMsg = document.getElementById('alert-msg');

    // 🔥 LUỒNG ĐỘNG: Kéo quỹ tên dự án từ Laravel về render vào dropdown chọn dự án ký gửi
    if (projectSelect && projectSelect.children.length <= 1) {
      try {
        const res = await fetch(`${BACKEND_URL}/api/projects-list`);
        if (res.ok) {
          const result = await res.json();
          const projects = result.data || [];
          projects.forEach((proj: any) => {
            const opt = document.createElement('option');
            opt.value = proj.title;
            opt.textContent = proj.title;
            projectSelect.appendChild(opt);
          });
        }
      } catch (err) {
        console.error("Lỗi kéo danh sách dự án: ", err);
      }
    }

    // Lắng nghe sự kiện Submit Form
    form.addEventListener('submit', async function(e) {
      e.preventDefault();
      if (!btn) return;

      const name = (document.getElementById('owner-name') as HTMLInputElement).value.trim();
      const phone = (document.getElementById('owner-phone') as HTMLInputElement).value.trim();
      const type = (document.getElementById('apartment-type') as HTMLSelectElement).value;
      const project = (document.getElementById('apartment-project') as HTMLSelectElement).value;
      const apartment_code = (document.getElementById('apartment-code') as HTMLInputElement).value.trim();
      const price = (document.getElementById('apartment-price') as HTMLInputElement).value.trim();
      const notes = (document.getElementById('apartment-notes') as HTMLTextAreaElement).value.trim();

      btn.disabled = true;
      btn.innerText = "HỆ THỐNG ĐANG TIẾP NHẬN HỒ SƠ...";
      if (alertMsg) alertMsg.className = "hidden";

      try {
        const res = await fetch(`${BACKEND_URL}/api/consignments`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
          body: JSON.stringify({ name, phone, type, project, apartment_code, price, notes, source: 'Form Web Ky Gui' })
        });

        const result = await res.json();

        if (res.ok && result.success) {
          if (alertMsg) {
            alertMsg.className = "mt-4 p-4 rounded-xl text-center text-xs font-bold bg-emerald-50 text-emerald-600 border border-emerald-100 animate-fadeIn";
            alertMsg.innerText = result.message || "🎉 Ký gửi thành công! Chuyên viên sẽ gọi điện xác thực căn hộ ngay.";
          }
          form.reset();
        } else {
          throw new Error(result.message || "Không thể thực hiện ký gửi lúc này.");
        }

      } catch(err: any) {
        if (alertMsg) {
          alertMsg.className = "mt-4 p-4 rounded-xl text-center text-xs font-bold bg-red-50 text-red-600 border border-red-100 animate-fadeIn";
          alertMsg.innerText = err.message || "⚠️ Hệ thống bận! Quý khách vui lòng thử lại sau ít phút.";
        }
      } finally {
        btn.disabled = false;
        btn.innerText = "GỬI HỒ SƠ KÝ GỬI NGAY";
      }
    });
  }

  // Khởi chạy đồng bộ mượt mà ở cả lượt tải đầu tiên và khi đổi trang qua View Transitions
  setupConsignmentPage();
  document.addEventListener('astro:page-load', setupConsignmentPage);
</script>

<style>
  @keyframes fadeIn { 
    from { opacity: 0; transform: translateY(8px); } 
    to { opacity: 1; transform: translateY(0); } 
  }
  .animate-fadeIn { animation: fadeIn 0.4s ease-out forwards; }
</style>