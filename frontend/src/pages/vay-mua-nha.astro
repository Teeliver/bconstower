---
// src/pages/vay-mua-nha.astro
// Giao diện công khai tính toán khoản vay kèm Banner Hero lớn, bọc trong MainLayout
import MainLayout from '../layouts/MainLayout.astro';

const API_BASE_URL = import.meta.env.PUBLIC_API_BASE || "http://localhost:3000";
---

<MainLayout title="Gói Vay Mua Nhà Ưu Đãi - Hệ Thống Bất Động Sản Bcons">
  <!-- <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet" /> -->

  <div class="relative bg-gradient-to-br from-[#fac72e] via-[#e2b327] to-[#d8aa21] overflow-hidden w-full font-body text-white py-16 md:py-28 px-4 sm:px-6 lg:px-8 shadow-xl">
    <div class="absolute inset-0 opacity-10 pointer-events-none" 
         style="background-image: url('https://www.transparenttextures.com/patterns/carbon-fibre.png');">
    </div>

    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-12 gap-12 items-center relative z-10">
      
      <div class="lg:col-span-7 space-y-6 text-left mt-10">
        <span class="inline-flex items-center gap-1.5 text-xs font-bold uppercase tracking-widest px-4 py-2 rounded-full bg-white/30 text-black backdrop-blur-sm">
          Mới cải tiến
        </span>
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold tracking-tight leading-tight md:leading-none text-white uppercase">
          Mua nhà ưng ý,<br class="hidden sm:inline" /> Khoản vay hợp lý
        </h1>
        <p class="text-base sm:text-lg text-black max-w-xl leading-relaxed">
          Chúng tôi cung cấp những ưu đãi tốt nhất từ mạng lưới ngân hàng liên kết chiến lược của Bcons, giúp bạn dễ dàng chạm đến tổ ấm mơ ước một cách an toàn tài chính.
        </p>
        <div class="flex flex-wrap items-center gap-4 pt-2">
          <button type="button" id="open-consult-modal-btn" class="px-8 py-4 bg-white hover:bg-slate-100 text-slate-900 font-medium rounded-2xl shadow-lg transition-all active:scale-95 cursor-pointer uppercase">
            Đăng ký tư vấn
          </button>
          <a href="#calculator-root" class="px-8 py-4 border-2 border-white/30 hover:border-white hover:bg-white/5 text-white font-medium rounded-2xl transition-all active:scale-95 flex items-center gap-2 uppercase">
            Tính toán khoản vay
          </a>
        </div>
      </div>

      <div class="lg:col-span-5 hidden lg:block relative min-h-[420px] w-full select-none">
        
        <div id="float-badge-1" class="absolute bg-white text-slate-800 p-2 rounded-2xl shadow-xl border border-slate-100 flex items-center gap-2.5 animate-bounce rotate-3" style="animation-duration: 4s; top: 8%; left: 2%;">
          <div class="w-12 h-12 flex items-center justify-center border border-slate-200 rounded-xl overflow-hidden bg-white flex-shrink-0 shadow-sm">
            <span class="text-[9px] font-bold text-slate-400">Logo</span>
          </div>
          <div class="flex flex-col pr-1 text-left"><span class="text-xs font-extrabold text-slate-800 whitespace-nowrap">BIDV</span><span class="text-[10px] font-bold text-emerald-600 font-mono">--%</span></div>
        </div>

        <div id="float-badge-2" class="absolute bg-white text-slate-800 p-2 rounded-2xl shadow-xl border border-slate-100 flex items-center gap-2.5 animate-bounce -rotate-6" style="animation-duration: 4.6s; top: 10%; right: 4%;">
          <div class="w-12 h-12 flex items-center justify-center border border-slate-200 rounded-xl overflow-hidden bg-white flex-shrink-0 shadow-sm">
            <span class="text-[9px] font-bold text-slate-400">Logo</span>
          </div>
          <div class="flex flex-col pr-1 text-left"><span class="text-xs font-extrabold text-slate-800 whitespace-nowrap">Vietcombank</span><span class="text-[10px] font-bold text-emerald-600 font-mono">--%</span></div>
        </div>

        <div id="float-badge-3" class="absolute bg-white text-slate-800 p-2 rounded-2xl shadow-xl border border-slate-100 flex items-center gap-2.5 animate-bounce rotate-6" style="animation-duration: 5.2s; top: 38%; left: 8%;">
          <div class="w-12 h-12 flex items-center justify-center border border-slate-200 rounded-xl overflow-hidden bg-white flex-shrink-0 shadow-sm">
            <span class="text-[9px] font-bold text-slate-400">Logo</span>
          </div>
          <div class="flex flex-col pr-1 text-left"><span class="text-xs font-extrabold text-slate-800 whitespace-nowrap">ACB Bank</span><span class="text-[10px] font-bold text-emerald-600 font-mono">--%</span></div>
        </div>

        <div id="float-badge-4" class="absolute bg-white text-slate-800 p-2 rounded-2xl shadow-xl border border-slate-100 flex items-center gap-2.5 animate-bounce -rotate-2" style="animation-duration: 4.4s; top: 44%; right: 10%;">
          <div class="w-12 h-12 flex items-center justify-center border border-slate-200 rounded-xl overflow-hidden bg-white flex-shrink-0 shadow-sm">
            <span class="text-[9px] font-bold text-slate-400">Logo</span>
          </div>
          <div class="flex flex-col pr-1 text-left"><span class="text-xs font-extrabold text-slate-800 whitespace-nowrap">TPBank</span><span class="text-[10px] font-bold text-emerald-600 font-mono">--%</span></div>
        </div>

        <div id="float-badge-5" class="absolute bg-white text-slate-800 p-2 rounded-2xl shadow-xl border border-slate-100 flex items-center gap-2.5 animate-bounce rotate-[12deg]" style="animation-duration: 5.8s; bottom: 8%; left: 12%;">
          <div class="w-12 h-12 flex items-center justify-center border border-slate-200 rounded-xl overflow-hidden bg-white flex-shrink-0 shadow-sm">
            <span class="text-[9px] font-bold text-slate-400">Logo</span>
          </div>
          <div class="flex flex-col pr-1 text-left"><span class="text-xs font-extrabold text-slate-800 whitespace-nowrap">VIB Bank</span><span class="text-[10px] font-bold text-emerald-600 font-mono">--%</span></div>
        </div>

        <div id="float-badge-6" class="absolute bg-white text-slate-800 p-2 rounded-2xl shadow-xl border border-slate-100 flex items-center gap-2.5 animate-bounce -rotate-3" style="animation-duration: 5s; bottom: 22%; right: 2%;">
          <div class="w-12 h-12 flex items-center justify-center border border-slate-200 rounded-xl overflow-hidden bg-white flex-shrink-0 shadow-sm">
            <span class="text-[9px] font-bold text-slate-400">Logo</span>
          </div>
          <div class="flex flex-col pr-1 text-left"><span class="text-xs font-extrabold text-slate-800 whitespace-nowrap">MB Bank</span><span class="text-[10px] font-bold text-emerald-600 font-mono">--%</span></div>
        </div>

        <div id="float-badge-7" class="absolute bg-white text-slate-800 p-2 rounded-2xl shadow-xl border border-slate-100 flex items-center gap-2.5 animate-bounce rotate-2" style="animation-duration: 5.6s; top: 24%; left: 45%;">
          <div class="w-12 h-12 flex items-center justify-center border border-slate-200 rounded-xl overflow-hidden bg-white flex-shrink-0 shadow-sm">
            <span class="text-[9px] font-bold text-slate-400">Logo</span>
          </div>
          <div class="flex flex-col pr-1 text-left"><span class="text-xs font-extrabold text-slate-800 whitespace-nowrap">VietinBank</span><span class="text-[10px] font-bold text-emerald-600 font-mono">--%</span></div>
        </div>
      </div>

    </div>
  </div>

  <div id="calculator-root" class="max-w-7xl mx-auto font-body py-16 px-4 sm:px-6 lg:px-8 scroll-mt-6">
    
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      
      <div class="lg:col-span-1 space-y-6">
        
        <div class="p-6 rounded-xl shadow-xl space-y-5 bg-neutral-50" style="background-color: #efefef; color: #000000;">
          <h3 class="text-lg font-bold border-b pb-3 flex items-center gap-2 uppercase" style="border-color: rgba(255, 255, 255, 0.2);">
            Thông tin dòng vốn
          </h3>
          
          <div class="space-y-2 text-left">
            <label class="block text-sm font-bold ml-1" style="color: #000000;">Giá trị căn hộ (VNĐ) <span class="text-orange-300">*</span></label>
            <input type="text" id="input-house-value" value="2.000.000.000" class="w-full px-6 py-4 bg-white border-2 border-transparent rounded-2xl outline-none focus:border-orange-500 transition-all font-mono font-bold text-slate-800 shadow-inner" placeholder="Nhập giá trị căn hộ..." />
          </div>

          <div class="space-y-2 text-left">
            <label class="block text-sm font-bold ml-1" style="color: #000000;">Tỷ lệ vay vốn (%) <span class="text-orange-300">*</span></label>
            <input type="number" id="input-loan-ratio" min="10" max="80" value="70" class="w-full px-6 py-4 bg-white border-2 border-transparent rounded-2xl outline-none focus:border-orange-500 transition-all font-mono font-bold text-slate-800 shadow-inner" placeholder="Ví dụ: 70" />
            <p class="text-[11px] italic ml-1" style="color: #292929;">Hỗ trợ vay tối đa từ 10% đến 80% giá trị căn hộ</p>
          </div>

          <div class="space-y-2 text-left">
            <label class="block text-sm font-bold ml-1" style="color: #000000;">Thời hạn vay (Năm) <span class="text-orange-300">*</span></label>
            <input type="number" id="input-loan-term" min="5" max="35" value="20" class="w-full px-6 py-4 bg-white border-2 border-transparent rounded-2xl outline-none focus:border-orange-500 transition-all font-mono font-bold text-slate-800 shadow-inner" placeholder="Ví dụ: 20" />
            <p id="txt-bank-term-note" class="text-[11px] italic ml-1" style="color: #292929;">Kỳ hạn vay linh hoạt từ 5 đến 35 năm</p>
          </div>
        </div>

        <div class="bg-white p-6 rounded-xl shadow-xl shadow-slate-100/70 border border-slate-100 space-y-4">
          <h3 class="text-lg font-bold text-slate-800 border-b border-slate-50 pb-3 flex items-center gap-2 uppercase">
            Ngân hàng liên kết
          </h3>
          
          <button type="button" id="mobile-bank-trigger" class="w-full flex lg:hidden items-center justify-between p-4 bg-slate-50 border-2 border-slate-200 rounded-2xl font-bold text-slate-700 focus:outline-none transition-all">
            <div id="mobile-active-bank-content" class="flex items-center gap-3">
              <span class="text-xs text-slate-400 font-medium">Bấm để chọn ngân hàng...</span>
            </div>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 transition-transform duration-300" id="mobile-bank-arrow" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          
          <div id="bank-selector-container" class="hidden lg:block space-y-3 mt-3 lg:mt-0 max-h-[350px] overflow-y-auto lg:max-h-none lg:overflow-visible pr-1 transition-all">
            <div class="text-center py-6 text-slate-400 italic text-xs animate-pulse">Đang tải dữ liệu lãi suất ngân hàng mới nhất...</div>
          </div>
        </div>
      </div>

      <div class="lg:col-span-2 space-y-6">
        
        <div class="text-white p-8 rounded-xl grid grid-cols-1 sm:grid-cols-3 gap-6 relative overflow-hidden">
          <div class="absolute -right-10 -bottom-10 w-40 h-40 bg-orange-600/10 rounded-full blur-3xl"></div>
          
          <div class="space-y-1 z-10">
            <span class="text-[10px] uppercase font-black tracking-widest text-black">Số tiền cần vay</span>
            <div id="summary-loan-amount" class="text-xl font-black text-orange-500">0 đ</div>
          </div>
          <div class="space-y-1 z-10">
            <span class="text-[10px] uppercase font-black tracking-widest text-black">Gốc lãi tháng đầu</span>
            <div id="summary-first-month" class="text-xl font-black text-black">0 đ</div>
          </div>
          <div class="space-y-1 z-10">
            <span class="text-[10px] uppercase font-black tracking-widest text-black">Tổng lãi phải trả</span>
            <div id="summary-total-interest" class="text-xl font-black" style="color: #114232;">0 đ</div>
          </div>
        </div>

        <div class="bg-white rounded-xl shadow-xl shadow-slate-100/70 border border-slate-200 overflow-hidden">
          <div class="p-6 border-b border-slate-100 bg-slate-50/50">
            <h3 class="text-base font-bold text-slate-800 flex items-center gap-2 uppercase">
              Lịch thanh toán chi tiết (Phương thức gốc đều, lãi giảm dần)
            </h3>
          </div>
          
          <div class="overflow-x-auto">
            <table class="w-full text-left text-sm">
              <thead class="bg-slate-100 border-b border-slate-200">
                <tr>
                  <th class="px-6 py-4 font-bold text-slate-700 text-xs uppercase tracking-wider text-center">Kỳ hạn</th>
                  <th class="px-6 py-4 font-bold text-slate-700 text-xs uppercase tracking-wider">Tiền gốc/Tháng</th>
                  <th class="px-6 py-4 font-bold text-slate-700 text-xs uppercase tracking-wider">Tiền lãi/Tháng</th>
                  <th class="px-6 py-4 font-bold text-slate-700 text-xs uppercase tracking-wider">Tổng gốc + lãi</th>
                  <th class="px-6 py-4 font-bold text-slate-700 text-xs uppercase tracking-wider text-right">Dư nợ còn lại</th>
                </tr>
              </thead>
              <tbody id="payment-schedule-tbody" class="divide-y divide-slate-100 text-slate-700 font-Inter tabular-nums">
                <tr>
                  <td colspan="5" class="p-10 text-center text-slate-400 italic">Đang bốc cấu hình dữ liệu khoản vay...</td>
                </tr>
              </tbody>
            </table>
          </div>

          <div id="show-more-container" class="p-4 bg-slate-50 border-t border-slate-100 text-center hidden">
            <button id="btn-show-more" type="button" class="inline-flex items-center gap-2 px-6 py-3 bg-white hover:bg-slate-100 border border-slate-200 text-slate-700 text-xs font-bold tracking-wider rounded-xl transition-all shadow-sm cursor-pointer focus:outline-none">
              Xem đầy đủ lịch trả nợ (<span id="txt-hidden-count">0</span> tháng còn lại)
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-slate-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </button>
          </div>
        </div>

      </div>
    </div>
  </div>

  <!-- 📞 🔥 ĐÃ CẬP NHẬT: THIẾT KẾ POPUP KHỚP 100% CẤU TRÚC VÀ PLACEHOLDER TRONG FILE IMAGE_C18EC9.JPG -->
  <div id="consult-bank-modal" class="fixed inset-0 bg-slate-950/60 backdrop-blur-sm z-50 hidden items-center justify-center p-4 opacity-0 transition-all duration-300 mt-16">
    <div class="bg-white w-full max-w-[640px] rounded-2xl shadow-2xl border border-slate-100 p-8 md:p-10 transform scale-95 transition-transform duration-300 relative text-slate-800">
      
      <!-- Khối tiêu đề căn giữa chuẩn ảnh -->
      <div class="text-center mb-8">
        <h3 class="text-xl font-bold text-[#1e293b] uppercase tracking-tight">ĐĂNG KÝ NHẬN TƯ VẤN</h3>
        <p class="text-[11px] text-slate-400 font-medium mt-2">* Cam kết tuyệt đối bảo mật thông tin khách hàng 100%.</p>
      </div>

      <form id="consult-bank-lead-form" class="space-y-5">
        <div class="text-left">
          <label class="block text-xs font-bold text-slate-500 uppercase mb-2 tracking-wide">CĂN HỘ QUAN TÂM</label>
          <input type="text" id="modal-interest" readonly class="w-full px-4 py-3.5 bg-slate-50 border border-slate-200 rounded-xl outline-none font-bold text-slate-600 cursor-not-allowed text-sm" value="Vay mua nhà - Hệ thống Bcons" />
        </div>
        
        <div class="text-left">
          <label class="block text-xs font-bold text-slate-500 uppercase mb-2 tracking-wide">HỌ VÀ TÊN KHÁCH HÀNG <span class="text-red-500">*</span></label>
          <!-- Gắn nhãn placeholder đúng mô tả ảnh -->
          <input type="text" id="modal-fullname" required class="w-full px-4 py-3.5 bg-white border border-slate-200 rounded-xl outline-none focus:border-slate-400 transition-all text-sm font-medium text-slate-800" placeholder="Ví dụ: Nguyễn Văn Tín" />
        </div>
        
        <div class="text-left">
          <label class="block text-xs font-bold text-slate-500 uppercase mb-2 tracking-wide">SỐ ĐIỆN THOẠI LIÊN HỆ <span class="text-red-500">*</span></label>
          <!-- Gắn nhãn placeholder đúng mô tả ảnh -->
          <input type="tel" id="modal-phone" required class="w-full px-4 py-3.5 bg-white border border-slate-200 rounded-xl outline-none focus:border-slate-400 transition-all text-sm font-medium text-slate-800 font-mono" placeholder="Ví dụ: 0911502603" />
        </div>
        
        <div class="text-left">
          <label class="block text-xs font-bold text-slate-500 uppercase mb-2 tracking-wide">GHI CHÚ YÊU CẦU THÊM</label>
          <!-- Gắn nhãn placeholder đúng mô tả ảnh -->
          <textarea id="modal-note" rows="3" class="w-full px-4 py-3.5 bg-white border border-slate-200 rounded-xl outline-none focus:border-slate-400 transition-all text-sm font-medium text-slate-800 resize-none" placeholder="Cần tư vấn giá, lịch xem nhà..."></textarea>
        </div>

        <!-- Cụm nút bấm căn giữa kết hợp mã màu xanh đặc trưng #006551 và xám dịu của Bcons -->
        <div class="flex items-center justify-center gap-4 pt-4">
          <button type="submit" id="modal-submit-btn" class="px-6 py-3 bg-black hover:bg-[#005241] text-[#fac72e] font-bold rounded-lg transition-all active:scale-95 text-sm shadow-md cursor-pointer whitespace-nowrap">
            Gửi yêu cầu ngay
          </button>
          <button type="button" id="close-consult-modal-btn" class="px-6 py-3 bg-[#8ba2b5] hover:bg-[#778d9f] text-white font-bold rounded-lg transition-all active:scale-95 text-sm shadow-md cursor-pointer whitespace-nowrap">
            Hủy bỏ
          </button>
        </div>
        
        <p id="modal-msg" class="text-center text-xs font-bold p-3 rounded-xl hidden animate-pulse"></p>
      </form>
    </div>
  </div>
</MainLayout>

<script>
  const API_BASE_URL = import.meta.env.PUBLIC_API_BASE || "http://localhost:3000";

  const inputHouseValue = document.getElementById('input-house-value') as HTMLInputElement;
  const inputLoanRatio = document.getElementById('input-loan-ratio') as HTMLInputElement;
  const inputLoanTerm = document.getElementById('input-loan-term') as HTMLInputElement;
  const txtBankTermNote = document.getElementById('txt-bank-term-note') as HTMLElement;

  const bankContainer = document.getElementById('bank-selector-container') as HTMLElement;
  const scheduleTbody = document.getElementById('payment-schedule-tbody') as HTMLElement;
  
  const mobileBankTrigger = document.getElementById('mobile-bank-trigger');
  const mobileActiveContent = document.getElementById('mobile-active-bank-content');
  const mobileBankArrow = document.getElementById('mobile-bank-arrow');

  const showMoreContainer = document.getElementById('show-more-container') as HTMLElement;
  const btnShowMore = document.getElementById('btn-show-more') as HTMLButtonElement;
  const txtHiddenCount = document.getElementById('txt-hidden-count') as HTMLElement;

  const smrLoanAmount = document.getElementById('summary-loan-amount') as HTMLElement;
  const smrFirstMonth = document.getElementById('summary-first-month') as HTMLElement;
  const smrTotalInterest = document.getElementById('summary-total-interest') as HTMLElement;

  const openConsultModalBtn = document.getElementById('open-consult-modal-btn');
  const closeConsultModalBtn = document.getElementById('close-consult-modal-btn');
  const consultBankModal = document.getElementById('consult-bank-modal') as HTMLDivElement;
  const consultBankLeadForm = document.getElementById('consult-bank-lead-form') as HTMLFormElement;
  const modalSubmitBtn = document.getElementById('modal-submit-btn') as HTMLButtonElement;
  const modalMsg = document.getElementById('modal-msg') as HTMLParagraphElement;
  const modalInterestInput = document.getElementById('modal-interest') as HTMLInputElement;

  let listBanks: any[] = [];
  let selectedBank: any = null;

  function formatVND(num: number): string {
    return new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(num).replace('₫', 'đ');
  }

  function formatNumberString(val: string): string {
    const clean = val.replace(/\D/g, '');
    if (!clean) return '';
    return parseInt(clean, 10).toLocaleString('vi-VN');
  }

  function toggleConsultModal(open: boolean) {
    if (!consultBankModal) return;
    if (open) {
      // Khi bấm mở popup, tự động cập nhật tên Ngân hàng đang chọn vào ô Căn hộ / Gói vay quan tâm
      if (modalInterestInput) {
        modalInterestInput.value = selectedBank ? `Gói vay mua nhà - ${selectedBank.name}` : 'Gói vay mua nhà - Bcons';
      }
      consultBankModal.classList.remove('hidden');
      consultBankModal.classList.add('flex');
      setTimeout(() => {
        consultBankModal.classList.remove('opacity-0');
        consultBankModal.querySelector('div')?.classList.remove('scale-95');
      }, 10);
    } else {
      consultBankModal.classList.add('opacity-0');
      consultBankModal.querySelector('div')?.classList.add('scale-95');
      setTimeout(() => {
        consultBankModal.classList.remove('flex');
        consultBankModal.classList.add('hidden');
        consultBankLeadForm?.reset();
        modalMsg?.classList.add('hidden');
      }, 300);
    }
  }

  openConsultModalBtn?.addEventListener('click', () => toggleConsultModal(true));
  closeConsultModalBtn?.addEventListener('click', () => toggleConsultModal(false));
  consultBankModal?.addEventListener('click', (e) => {
    if (e.target === consultBankModal) toggleConsultModal(false);
  });

  consultBankLeadForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!modalSubmitBtn || !modalMsg) return;

    modalSubmitBtn.disabled = true;
    modalSubmitBtn.innerText = "ĐANG GỬI...";
    modalMsg.classList.add('hidden');

    const fullname = (document.getElementById('modal-fullname') as HTMLInputElement).value;
    const phone = (document.getElementById('modal-phone') as HTMLInputElement).value;
    const note = (document.getElementById('modal-note') as HTMLInputElement).value;

    const selectedBankName = selectedBank ? selectedBank.name : 'Chưa chọn';
    const calculatedLoanValue = smrLoanAmount?.innerText || '0đ';
    const fullNoteWithContext = `[Nguồn: Tư vấn vay bank] - Cần vay: ${calculatedLoanValue} tại ngân hàng: ${selectedBankName}. Ghi chú: ${note}`;

    try {
      const res = await fetch(`${API_BASE_URL}/api/leads`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        body: JSON.stringify({
          name: fullname,
          fullname: fullname,
          phone: phone,
          email: '',
          note: fullNoteWithContext,
          source: 'Tư vấn vay bank' // 🔥 ĐẢM BẢO TUYỆT ĐỐI: Giữ nguyên nguồn phân bổ luồng
        })
      });

      const data = await res.json();

      if (res.ok && data.success) {
        modalMsg.className = "text-center text-xs font-bold p-3 rounded-xl bg-emerald-50 text-emerald-600 border border-emerald-200/50";
        modalMsg.innerText = "🎉 Gửi yêu cầu tư vấn thành công!";
        modalMsg.classList.remove('hidden');
        setTimeout(() => toggleConsultModal(false), 2000);
      } else {
        throw new Error(data.message || "Lỗi truyền tải.");
      }
    } catch (err: any) {
      modalMsg.className = "text-center text-xs font-bold p-3 rounded-xl bg-red-50 text-red-600 border border-red-200/50";
      modalMsg.innerText = `⚠️ Lỗi: ${err.message || 'Kết nối thất bại.'}`;
      modalMsg.classList.remove('hidden');
    } finally {
      modalSubmitBtn.disabled = false;
      modalSubmitBtn.innerText = "Gửi yêu cầu ngay";
    }
  });

  mobileBankTrigger?.addEventListener('click', () => {
    bankContainer.classList.toggle('hidden');
    mobileBankArrow?.classList.toggle('rotate-180');
  });

  async function loadBanksData() {
    try {
      const res = await fetch(`${API_BASE_URL}/api/banks`);
      listBanks = await res.json();
      
      if (!Array.isArray(listBanks) || listBanks.length === 0) {
        bankContainer.innerHTML = `<div class="text-center py-4 text-slate-400 text-xs">Hệ thống đang cập nhật các gói lãi suất mới.</div>`;
        return;
      }

      bankContainer.innerHTML = '';
      listBanks.forEach((bank, idx) => {
        const item = document.createElement('div');
        item.className = `bank-item border-2 rounded-2xl p-4 flex items-center justify-between cursor-pointer transition-all duration-200 ${idx === 0 ? 'border-orange-500 bg-orange-50/20 shadow-sm' : 'border-slate-100 bg-white hover:border-orange-500/40 hover:shadow-md'}`;
        
        const logoUrl = bank.logo ? (bank.logo.startsWith('http') ? bank.logo : `${API_BASE_URL}${bank.logo}`) : 'https://placehold.co/120x50?text=Bank';

        item.innerHTML = `
          <div class="flex items-center gap-3 min-w-0">
            <div class="w-16 h-12 flex items-center justify-center border border-slate-100 rounded-xl overflow-hidden bg-white p-1 flex-shrink-0 shadow-sm">
              <img src="${logoUrl}" class="max-w-full max-h-full object-contain" onerror="this.src='https://placehold.co/120x50?text=Bank'"/>
            </div>
            <div class="flex flex-col justify-center min-w-0 text-left">
              <div class="min-w-full font-bold text-slate-800 text-sm leading-tight">${bank.name}</div>
              <div class="text-[11px] text-slate-400 font-medium mt-1">Ưu đãi: <b style="color: #059669;">${bank.preferentialRate || bank.preferential_rate}%</b></div>
              <div class="text-[11px] text-slate-400 font-medium mt-1">Thả nổi: <b style="color: #059669;">${bank.floatingRate || bank.floating_rate}%</b></div>
            </div>
          </div>
        `;
        
        item.addEventListener('click', () => {
          document.querySelectorAll('.bank-item').forEach(el => {
            el.classList.remove('border-orange-500', 'bg-orange-50/20', 'shadow-sm');
            el.classList.add('border-slate-100', 'bg-white', 'hover:border-orange-500/40', 'hover:shadow-md');
          });
          
          item.classList.remove('border-slate-100', 'bg-white', 'hover:border-orange-500/40', 'hover:shadow-md');
          item.classList.add('border-orange-500', 'bg-orange-50/20', 'shadow-sm');
          selectedBank = bank;
          
          const maxBankTerm = parseInt(bank.maxTerm || bank.max_term || 35, 10);
          inputLoanTerm.max = maxBankTerm.toString();
          txtBankTermNote.innerText = `Ngân hàng này hỗ trợ vay tối đa ${maxBankTerm} năm`;
          
          if (parseInt(inputLoanTerm.value, 10) > maxBankTerm) {
            inputLoanTerm.value = maxBankTerm.toString();
          }

          if (mobileActiveContent) {
            mobileActiveContent.innerHTML = `
              <div class="w-10 h-7 flex items-center justify-center bg-white border border-slate-200 rounded-lg overflow-hidden flex-shrink-0">
                <img src="${logoUrl}" class="max-w-full max-h-full object-contain p-0.5" />
              </div>
              <span class="text-xs font-bold text-slate-800 truncate max-w-[180px]">${bank.name}</span>
            `;
          }

          if (window.innerWidth < 1024) {
            bankContainer.classList.add('hidden');
            mobileBankArrow?.classList.remove('rotate-180');
          }

          calculateLoan();
        });

        bankContainer.appendChild(item);
      });

      for (let i = 1; i <= 7; i++) {
        const badgeElement = document.getElementById(`float-badge-${i}`);
        const bankData = listBanks[i - 1]; 
        
        if (badgeElement && bankData) {
          const logoUrl = bankData.logo ? (bankData.logo.startsWith('http') ? bankData.logo : `${API_BASE_URL}${bankData.logo}`) : 'https://placehold.co/100x100?text=Bank';
          badgeElement.innerHTML = `
            <div class="w-18 h-18 flex items-center justify-center rounded-xl overflow-hidden bg-white flex-shrink-0">
              <img src="${logoUrl}" class="max-w-full max-h-full object-contain p-0.5" onerror="this.src='https://placehold.co/100x100?text=B'" />
            </div>
          `;
        }
      }

      selectedBank = listBanks[0];
      const initialMax = parseInt(selectedBank.maxTerm || selectedBank.max_term || 35, 10);
      txtBankTermNote.innerText = `Ngân hàng này hỗ trợ vay tối đa ${initialMax} năm`;
      
      if (mobileActiveContent && selectedBank) {
        const initialLogo = selectedBank.logo ? (selectedBank.logo.startsWith('http') ? selectedBank.logo : `${API_BASE_URL}${selectedBank.logo}`) : 'https://placehold.co/120x50?text=Bank';
        mobileActiveContent.innerHTML = `
          <div class="w-10 h-7 flex items-center justify-center bg-white border border-slate-200 rounded-lg overflow-hidden flex-shrink-0">
            <img src="${initialLogo}" class="max-w-full max-h-full object-contain p-0.5" />
          </div>
          <span class="text-xs font-bold text-slate-800 truncate max-w-[180px]">${selectedBank.name}</span>
        `;
      }

      calculateLoan();

    } catch (err) {
      bankContainer.innerHTML = `<div class="text-center py-4 text-red-500 text-xs font-bold">⚠️ Không thể đồng bộ biểu phí lãi suất từ tổng đài Bcons.</div>`;
    }
  }

  function calculateLoan() {
    if (!selectedBank) return;

    const rawHouseValue = inputHouseValue.value.replace(/\D/g, '');
    const houseValue = parseFloat(rawHouseValue) || 0;
    
    let loanRatio = parseFloat(inputLoanRatio.value) || 0;
    if (loanRatio > 80) { loanRatio = 80; inputLoanRatio.value = "80"; }
    if (loanRatio < 0) { loanRatio = 0; inputLoanRatio.value = "0"; }

    let loanTermYears = parseInt(inputLoanTerm.value, 10) || 5;
    const maxBankTerm = parseInt(selectedBank.maxTerm || selectedBank.max_term || 35, 10);
    if (loanTermYears > maxBankTerm) { loanTermYears = maxBankTerm; inputLoanTerm.value = maxBankTerm.toString(); }

    const totalMonths = loanTermYears * 12;
    const loanAmount = houseValue * (loanRatio / 100);
    
    const prefRateYear = parseFloat(selectedBank.preferentialRate || selectedBank.preferential_rate) / 100;
    const prefMonthsLimit = parseInt(selectedBank.preferentialTerm || selectedBank.preferential_term, 10) || 0;
    const floatRateYear = parseFloat(selectedBank.floatingRate || selectedBank.floating_rate) / 100;

    let remainingPrincipal = loanAmount;
    let totalInterest = 0;
    let firstMonthTotal = 0;

    let htmlTableRows = '';

    for (let month = 1; month <= totalMonths; month++) {
      const currentRateYear = month <= prefMonthsLimit ? prefRateYear : floatRateYear;
      const currentRateMonth = currentRateYear / 12;

      const principalPerMonth = loanAmount / totalMonths;
      const interestPerMonth = remainingPrincipal * currentRateMonth;
      const totalPerMonth = principalPerMonth + interestPerMonth;

      if (month === 1) firstMonthTotal = totalPerMonth;

      totalInterest += interestPerMonth;
      remainingPrincipal -= principalPerMonth;

      const isHiddenRow = month > 24;
      const rowClass = isHiddenRow ? 'month-hidden-row hidden' : '';

      htmlTableRows += `
        <tr class="hover:bg-slate-50/80 transition-all ${rowClass}">
          <td class="px-6 py-3.5 text-center font-medium text-slate-500">Tháng ${month}</td>
          <td class="px-6 py-3.5 font-medium">${formatVND(principalPerMonth)}</td>
          <td class="px-6 py-3.5 text-red-500 font-medium">${formatVND(interestPerMonth)}</td>
          <td class="px-6 py-3.5 font-medium text-slate-900">${formatVND(totalPerMonth)}</td>
          <td class="px-6 py-3.5 text-right font-medium text-blue-600">${formatVND(Math.max(0, remainingPrincipal))}</td>
        </tr>
      `;
    }

    smrLoanAmount.innerText = formatVND(loanAmount);
    smrFirstMonth.innerText = formatVND(firstMonthTotal);
    smrTotalInterest.innerText = formatVND(totalInterest);
    scheduleTbody.innerHTML = htmlTableRows;

    if (totalMonths > 24) {
      showMoreContainer.classList.remove('hidden');
      txtHiddenCount.innerText = (totalMonths - 24).toString();
    } else {
      showMoreContainer.classList.add('hidden');
    }
  }

  inputHouseValue.addEventListener('input', (e) => {
    const target = e.target as HTMLInputElement;
    target.value = formatNumberString(target.value);
    calculateLoan();
  });

  inputLoanRatio.addEventListener('input', () => { calculateLoan(); });
  inputLoanTerm.addEventListener('input', () => { calculateLoan(); });

  btnShowMore.addEventListener('click', () => {
    document.querySelectorAll('.month-hidden-row').forEach(row => {
      row.classList.remove('hidden');
    });
    showMoreContainer.classList.add('hidden');
  });

  loadBanksData();
</script>