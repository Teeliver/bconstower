            <div class="px-4 py-2 text-xs font-bold hover:bg-slate-50 hover:text-orange-500 transition-colors cursor-pointer option-item shadow-sm" data-value="price-desc">Giá cao đến thấp</div>
            <div class="px-4 py-2 text-xs font-bold hover:bg-slate-50 hover:text-orange-500 transition-colors cursor-pointer option-item" data-value="area-desc">Diện tích lớn nhất</div>
          </div>
        </div>
      </div>

      <div id="project-skeleton" class="grid grid-cols-2 md:grid-cols-4 gap-x-6 gap-y-8 animate-pulse">
        {[1, 2, 3, 4, 5, 6, 7, 8].map(() => (
          <div class="space-y-3">
            <div class="aspect-[4/3] bg-slate-100 rounded-xl w-full"></div>
            <div class="h-4 bg-slate-100 rounded w-2/3"></div>
            <div class="h-3 bg-slate-100 rounded w-1/2"></div>
          </div>
        ))}
      </div>

      <div id="project-apartments-grid" class="grid grid-cols-1 md:grid-cols-3 gap-x-6 gap-y-8 hidden"></div>

      <div id="load-more-container" class="w-full flex justify-center mt-16 hidden">
        <button type="button" id="btn-load-more" class="px-8 h-11 rounded-xl bg-white border border-slate-200 hover:border-[#006B5D] text-slate-700 hover:text-[#006B5D] font-bold text-xs shadow-sm transition-all duration-200 select-none cursor-pointer uppercase tracking-wider">
          Xem thêm căn hộ ký gửi
        </button>
      </div>

      <div id="empty-project-message" class="hidden text-center py-20 bg-slate-50 border border-slate-100 rounded-2xl animate-fadeIn">
        <div class="text-4xl mb-2">🏢</div>
        <p class="font-bold text-slate-700 text-sm">Không tìm thấy căn hộ phù hợp với bộ lọc</p>
        <p class="text-xs text-slate-400 mt-1">Trung Tín khuyên bạn nên điều chỉnh lại khoảng giá hoặc hướng ban công xem sao nhé!</p>
      </div>

    </div>
  </div>
</MainLayout>

<script define:vars={{ projectSlug, PUBLIC_API_BASE }}>
  const BACKEND_URL = PUBLIC_API_BASE;

  let MASTER_APARTMENTS = [];
  let FILTERED_APARTMENTS = [];
  let VISIBLE_COUNT = 20;

  let activeFilters = {
    price: 'all',
    direction: 'all',
    floor: 'all'
  };

  let activeSort = 'all'; 

  const escapeHTML = (str) => {
    if (!str) return '';
    return str.replace(/[&<>"']/g, (match) => {
      const map = { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' };
      return map[match] || match;
    });
  };

  function timeAgo(dateString) {
    if (!dateString) return "Mới đăng";
    const pastDate = new Date(dateString);
    const pastTime = pastDate.getTime();
    if (isNaN(pastTime)) return "Mới đăng";
    const currentTime = new Date().getTime();
    const seconds = Math.floor((currentTime - pastTime) / 1000);
    if (seconds < 5) return "Đăng 1 ngày trước";
    let interval = seconds / 86400;
    if (interval >= 1) return "Đăng " + Math.floor(interval) + " ngày trước";
    return "Đăng ngày hôm nay";
  }

  function initCustomDropdowns() {
    const containers = document.querySelectorAll('.dropdown-container');
    
    containers.forEach(container => {
      container.addEventListener('click', function(e) {
        e.stopPropagation();
        const menu = this.querySelector('.dropdown-menu');
        const chevron = this.querySelector('.chevron-icon');
        
        const isHidden = menu.classList.contains('hidden');

        containers.forEach(other => {
          other.querySelector('.dropdown-menu').classList.add('hidden');
          const c = other.querySelector('.chevron-icon');
          if (c) c.classList.remove('rotate-180');
          if (other.id !== 'dropdown-sort') {
            other.classList.remove('border-orange-500', 'border-2');
            other.classList.add('border-slate-200');
          }
        });

        if (isHidden) {
          menu.classList.remove('hidden');
          if (chevron) chevron.classList.add('rotate-180');
          
          if (this.id !== 'dropdown-sort') {
            this.classList.remove('border-slate-200');
            this.classList.add('border-orange-500', 'border-2');
          }
        }
      });

      const options = container.querySelectorAll('.option-item');
      const displayVal = container.querySelector('.display-value');
      const filterKey = container.id.replace('dropdown-', '');

      options.forEach(option => {
        option.addEventListener('click', function(e) {
          e.stopPropagation();
          const value = this.getAttribute('data-value');
          const text = this.textContent;

          displayVal.textContent = text;

          if (filterKey === 'sort') {
            activeSort = value;
          } else {
            activeFilters[filterKey] = value;
          }

          container.querySelector('.dropdown-menu').classList.add('hidden');
          const chevron = container.querySelector('.chevron-icon');
          if (chevron) chevron.classList.remove('rotate-180');
          
          if (container.id !== 'dropdown-sort') {
            container.classList.remove('border-orange-500', 'border-2');
            container.classList.add('border-slate-200');
          }

          applyFilters();
        });
      });
    });

    document.addEventListener('click', () => {
      containers.forEach(container => {
        container.querySelector('.dropdown-menu').classList.add('hidden');
        const chevron = container.querySelector('.chevron-icon');
        if (chevron) chevron.classList.remove('rotate-180');
        if (container.id !== 'dropdown-sort') {
          container.classList.remove('border-orange-500', 'border-2');
          container.classList.add('border-slate-200');
        }
      });
    });
  }

  function renderApartmentSlice() {
    const grid = document.getElementById('project-apartments-grid');
    const loadMoreContainer = document.getElementById('load-more-container');
    const emptyBox = document.getElementById('empty-project-message');
    const resultsCountEl = document.getElementById('results-count');

    resultsCountEl.textContent = FILTERED_APARTMENTS.length.toLocaleString('vi-VN');

    if (FILTERED_APARTMENTS.length === 0) {
      grid.classList.add('hidden');
      loadMoreContainer.classList.add('hidden');
      emptyBox.classList.remove('hidden');
      return;
    }

    emptyBox.classList.add('hidden');
    grid.classList.remove('hidden');

    const itemsToRender = FILTERED_APARTMENTS.slice(0, VISIBLE_COUNT);

    grid.innerHTML = itemsToRender.map(function(apt) {
      let itemImages = [];
      if (apt.image) {
        if (typeof apt.image === 'string') {
          if (apt.image.trim().startsWith('[') && apt.image.trim().endsWith(']')) {
            try { itemImages = JSON.parse(apt.image); } catch(e) { itemImages = [apt.image]; }
          } else { itemImages = [apt.image]; }
        } else if (Array.isArray(apt.image)) { itemImages = apt.image; }
      }

      const rawThumb = (itemImages && itemImages.length > 0) ? itemImages[0] : '';
      const thumb = rawThumb 
        ? (rawThumb.startsWith('http') ? rawThumb : (BACKEND_URL.replace(/\/$/, '') + '/' + rawThumb.replace(/^\//, ''))) 
        : '/images/no-photo.jpg';
      
      const priceBillion = apt.price ? (apt.price / 1000000000).toFixed(2).replace('.', ',') : '0';
      const pricePerM2 = (apt.price && apt.area) ? (apt.price / apt.area / 1000000).toFixed(2).replace('.', ',') : '0';
      const realCreatedDate = apt.created_at || apt.createdAt || apt.updated_at || apt.updatedAt;

      const safeName = escapeHTML(apt.name || '');
      const safeProjectAddress = escapeHTML(apt.project_address || apt.projectAddress || 'Bình Dương');
      const safeSlug = escapeHTML(apt.slug || '');

      let html = '<div class="relative w-full">';
      html += '<a href="/' + escapeHTML(projectSlug) + '/' + safeSlug + '" class="focus:outline-none">';
      html += '  <div class="relative aspect-[4/3] rounded-xl overflow-hidden bg-slate-50 border border-slate-100 mb-2.5">';
      html += '    <img src="' + thumb + '" class="w-full h-full object-cover group-hover:scale-[1.02] transition-transform duration-500" alt="' + safeName + '" />';
      html += '    <div class="absolute bottom-2.5 right-2.5 bg-black/50 text-white text-[11px] px-1.5 py-0.5 rounded font-medium flex items-center gap-1">';
      html += '      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>';
      html += '      <span>1/' + (itemImages.length || 1) + '</span>';
      html += '    </div>';
      html += '  </div>';
      
      html += '  <div class="w-full pt-2">';
      html += '    <div class="flex w-full flex-row items-center justify-between gap-x-2">';
      html += '      <span class="font-extrabold text-emerald-700">';
      html += '        ' + priceBillion + ' tỷ <span class="text-slate-300 font-normal mx-0.5">·</span> <span class="text-sm font-semibold">' + pricePerM2 + ' triệu/m² </span>';
      html += '      </span>';
      html += '      <span class="text-xs text-neutral-600">' + timeAgo(realCreatedDate) + '</span>';
      html += '    </div>';
      
      html += '    <section class="pt-1">';
      html += '     <h3 class="text-base text-lg md:text-sm font-bold text-neutral-900 line-clamp-1" title="' + safeName + '">' + safeName + '</h3>';
      html += '     <p class="pt-0.5 text-lg md:text-sm text-neutral-600">' + safeProjectAddress + '</p>';
      html += '    </section>';
      
      html += '    <div class="flex flex-row flex-nowrap items-center pt-1.5">';
      html += '      <div class="flex flex-row items-center">';
      html += '         <div class="flex flex-row items-center gap-x-1"><svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" fill="currentColor" viewBox="0 0 256 256" class="h-5 w-5 text-neutral-500"><path d="M248,112v56H112V80H216A32,32,0,0,1,248,112Z" opacity="0.2"></path><path d="M216,72H32V48a8,8,0,0,0-16,0V208a8,8,0,0,0,16,0V176H240v32a8,8,0,0,0,16,0V112A40,40,0,0,0,216,72ZM32,88h72v72H32Zm88,72V88h96a24,24,0,0,1,24,24v48Z"></path></svg><span class="whitespace-nowrap text-md md:text-sm text-neutral-600"> ' + (apt.bedrooms || 0) + ' PN</span></div>';
      html += '      </div>';
      html += '      <div class="flex flex-row items-center">';
      html += '         <div class="mx-3 h-3 w-px bg-black/10"></div>';
      html += '         <div class="flex flex-row items-center gap-x-1"><svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" fill="currentColor" viewBox="0 0 256 256" class="h-5 w-5 text-neutral-500"><path d="M240,104v40a48,48,0,0,1-48,48H64a48,48,0,0,1-48-48V104H136v40h64V104Z" opacity="0.2"></path><path d="M240,96H208a8,8,0,0,0-8-8H136a8,8,0,0,0-8,8H64V52A12,12,0,0,1,76,40a12.44,12.44,0,0,1,12.16,9.59,8,8,0,0,0,15.68-3.18A28.32,28.32,0,0,0,76,24,28,28,0,0,0,48,52V96H16a8,8,0,0,0-8,8v40a56.06,56.06,0,0,0,56,56v16a8,8,0,0,0,16,0V200h96v16a8,8,0,0,0,16,0V200a56.06,56.06,0,0,0,56-56V104A8,8,0,0,0,240,96Zm-48,8v32H144V104Zm40,40a40,40,0,0,1-40,40H64a40,40,0,0,1-40-40V112H128v32a8,8,0,0,0,8,8h64a8,8,0,0,0,8-8V112h24Z"></path></svg><span class="whitespace-nowrap text-md md:text-sm text-neutral-600"> ' + (apt.bathrooms || 0) + ' WC</span></div>';
      html += '      </div>';
      html += '      <div class="flex flex-row items-center">';
      html += '         <div class="mx-3 h-3 w-px bg-black/10"></div>';
      html += '         <div class="flex flex-row items-center gap-x-1"><svg viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-neutral-500" weight="duotone"><path opacity="0.2" fill="currentColor" d="M2.96094 2.95996H13.040939999999999V13.03996H2.96094z"></path><path d="M13.041 2.96l-3.94 3.955M9.098 2.96h3.94v3.955M2.963 13.04l3.94-3.955M6.906 13.04H2.963V9.084M13.037 9.085v3.395a.56.56 0 01-.56.56H9.099M6.902 2.96H3.521a.56.56 0 00-.56.56v3.395" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"></path></svg><span class="whitespace-nowrap text-md md:text-sm text-neutral-600"> ' + (apt.area || 0) + ' m²</span></div>';
      html += '      </div>'; 
      html += '    </div>';
      html += '  </div>';
      html += '</a>';
      html += '</div>';
      return html;
    }).join('');

    if (FILTERED_APARTMENTS.length > VISIBLE_COUNT) {
      loadMoreContainer.classList.remove('hidden');
    } else {
      loadMoreContainer.classList.add('hidden');
    }
  }

  function applyFilters() {
    const priceVal = activeFilters.price;
    const dirVal = activeFilters.direction;
    const floorVal = activeFilters.floor;

    FILTERED_APARTMENTS = MASTER_APARTMENTS.filter(function(apt) {
      if (priceVal === 'under-1.5' && Number(apt.price) >= 1500000000) return false;
      if (priceVal === '1.5-2' && (Number(apt.price) < 1500000000 || Number(apt.price) > 2000000000)) return false;
      if (priceVal === 'over-2' && Number(apt.price) <= 2000000000) return false;

      if (dirVal !== 'all') {
        const aptDir = String(apt.direction_balcony || apt.direction || '').toLowerCase();
        if (!aptDir.includes(dirVal)) return false;
      }

      if (floorVal !== 'all') {
        const floorNum = parseInt(apt.floor) || 0;
        if (floorVal === 'low' && floorNum >= 8) return false;
        if (floorVal === 'mid' && (floorNum < 8 || floorNum > 18)) return false;
        if (floorVal === 'high' && floorNum <= 18) return false;
      }

      return true;
    });

    if (activeSort === 'price-asc') {
      FILTERED_APARTMENTS.sort(function(a, b) { return Number(a.price) - Number(b.price); });
    } else if (activeSort === 'price-desc') {
      FILTERED_APARTMENTS.sort(function(a, b) { return Number(b.price) - Number(a.price); });
    } else if (activeSort === 'area-desc') {
      FILTERED_APARTMENTS.sort(function(a, b) { return Number(b.area) - Number(a.area); });
    }

    VISIBLE_COUNT = 20;
    renderApartmentSlice();
  }

  async function loadProjectPageData() {
    const skeleton = document.getElementById('project-skeleton');
    try {
      const res = await fetch(BACKEND_URL + "/api/apartments/by-project?slug=" + projectSlug);
      if (!res.ok) throw new Error("API sập luồng mạng");
      const result = await res.json();

      const projectInfo = result.project_info || result.projectInfo;

      if (projectInfo) {
        const titleText = projectInfo.title || projectInfo.name || "Dự án Bcons";
        const addressText = projectInfo.address || projectInfo.location || "Dĩ An, Bình Dương";

        document.getElementById('main-project-title').textContent = titleText;
        document.getElementById('main-project-address').querySelector('span').textContent = addressText;
        document.getElementById('text-filter-khuvuc').textContent = addressText.split(',').pop().trim();
        document.getElementById('breadcrumb-project-name').textContent = titleText;
        document.getElementById('page-main-heading').textContent = "Mua căn hộ " + titleText + " mới nhất 2026";
        
        if (projectInfo.image) {
          const bannerUrl = projectInfo.image.startsWith('http') ? projectInfo.image : (BACKEND_URL.replace(/\/$/, '') + '/' + projectInfo.image.replace(/^\//, ''));
          document.getElementById('main-project-banner').setAttribute('src', bannerUrl);
        }
      }

      MASTER_APARTMENTS = Array.isArray(result.apartments) ? result.apartments : (result.data || []);
      FILTERED_APARTMENTS = MASTER_APARTMENTS;

      initCustomDropdowns();

      if (skeleton) skeleton.classList.add('hidden');
      renderApartmentSlice();

      document.getElementById('btn-load-more').addEventListener('click', function() {
        VISIBLE_COUNT += 10;
        renderApartmentSlice();
      });

    } catch (e) {
      console.error("Lỗi đồng bộ danh sách căn hộ theo dự án:", e);
      if (skeleton) skeleton.classList.add('hidden');
    }
  }

  loadProjectPageData();
</script>

