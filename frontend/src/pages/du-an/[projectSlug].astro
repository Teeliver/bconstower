---
import MainLayout from "../../layouts/MainLayout.astro";

// 🔥 BẢO MẬT & CHUẨN SEO TUYỆT ĐỐI: Đồng bộ toàn bộ slug dự án từ Laravel phục vụ đóng gói SSG tĩnh
export async function getStaticPaths() {
  const API_BASE = import.meta.env.PUBLIC_API_BASE || "http://127.0.0.1:8000";
  try {
    const res = await fetch(`${API_BASE}/api/projects`, {
      method: 'GET',
      headers: { 'Accept': 'application/json' }
    });
    
    if (res.ok) {
      const data = await res.json();
      const items = Array.isArray(data) ? data : (data && Array.isArray(data.data) ? data.data : []);
      
      if (items.length > 0) {
        return items.map((item: any) => {
          const slugValue = String(item.slug || item.project_slug || '').trim();
          return { params: { projectSlug: slugValue } };
        });
      }
    }
    return [{ params: { projectSlug: "bcons-city" } }];
  } catch (e) {
    console.error("Lỗi đồng bộ danh sách dự án phục vụ build tĩnh SEO:", e);
    return [{ params: { projectSlug: "bcons-city" } }];
  }
}

const { projectSlug } = Astro.params;
const PUBLIC_API_BASE = import.meta.env.PUBLIC_API_BASE || "http://127.0.0.1:8000";

// 🚀 KHỞI TẠO BIẾN CONFIG SEO MẶC ĐỊNH (FALLBACK)
let seoTitle = "Chi tiết dự án và Bảng giá căn hộ chung cư mới nhất";
let seoDescription = "Hệ thống giỏ hàng ký gửi chính chủ được kiểm duyệt thực tế kỹ lưỡng.";

// 🔍 ĐỒNG BỘ DỮ LIỆU TỪ API SERVER-SIDE ĐỂ PHỤC VỤ SEO GOOGLE BOT
try {
  const res = await fetch(`${PUBLIC_API_BASE}/api/apartments/by-project?slug=${projectSlug}`);
  if (res.ok) {
    const result = await res.json();
    const projectInfo = result.project_info || result.projectInfo;
    if (projectInfo) {
      const currentTitle = projectInfo.title || projectInfo.name || "";
      if (currentTitle) {
        // Ép tên dự án lên đầu tiên theo đúng yêu cầu cấu trúc SEO của bạn
        seoTitle = `${currentTitle} - Chi tiết dự án và Bảng giá căn hộ chung cư mới nhất`;
      }
      
      const landingStructure = typeof projectInfo.landing_data === 'string' ? JSON.parse(projectInfo.landing_data) : projectInfo.landing_data;
      
      // Quét đa tầng lấy mô tả tối ưu nhất của dự án từ database
      seoDescription = projectInfo.seo_description || 
                       landingStructure?.seo?.description || 
                       landingStructure?.overview?.highlights || 
                       projectInfo.description || 
                       `Thông tin chi tiết, bảng giá mới nhất và giỏ hàng ký gửi chính chủ căn hộ chung cư thuộc dự án ${currentTitle}. Liên hệ hotline 0911.502.603 để nhận file dòng tiền chi tiết.`;
    }
  }
} catch (e) {
  console.error("Lỗi đồng bộ SEO Meta Tags phía Server-side:", e);
}
