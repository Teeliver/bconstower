          </div>
          
          <div class="absolute right-0 top-[calc(100%+6px)] w-[160px] bg-white rounded-xl shadow-[0_10px_30px_rgba(0,0,0,0.1)] py-1 hidden dropdown-menu border border-slate-100 overflow-hidden text-slate-700 text-left">
            <div class="px-4 py-2 text-xs font-bold hover:bg-slate-50 hover:text-orange-500 transition-colors cursor-pointer option-item shadow-sm" data-value="all">Phù hợp nhất</div>
