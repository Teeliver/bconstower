            <div class="absolute right-4 top-1/2 -translate-y-1/2 text-slate-400 pointer-events-none transition-transform duration-200 chevron-icon flex items-center">
              <svg class="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"></path></svg>
            </div>
            <div class="absolute left-0 top-[calc(100%+6px)] w-full bg-white rounded-2xl shadow-[0_10px_30px_rgba(0,0,0,0.1)] py-1.5 hidden dropdown-menu border border-slate-100 overflow-hidden z-50">
              <div class="px-4 py-2.5 text-sm font-bold text-slate-700 hover:bg-slate-50 hover:text-orange-500 transition-colors cursor-pointer option-item" data-value="all">Tất cả</div>
