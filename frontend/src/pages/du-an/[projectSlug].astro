<script define:vars={{ projectSlug, PUBLIC_API_BASE }}>
  const BACKEND_URL = PUBLIC_API_BASE;

  let MASTER_APARTMENTS = [];
  let FILTERED_APARTMENTS = [];
  let VISIBLE_COUNT = 9;

  let activeFilters = { price: 'all', direction: 'all', floor: 'all' };
  let activeSort = 'all';

  const escapeHTML = (str) => {
    if (!str) return '';
    return str.replace(/[&<>"']/g, (match) => {
      const map = { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' };
      return map[match] || match;
    });
  };

  const getAssetUrl = (url) => {
    if (!url) return '';
    return url.startsWith('http') || url.startsWith('data:image') ? url : (BACKEND_URL.replace(/\/$/, '') + '/' + url.replace(/^\//, ''));
  };

  function timeAgo(dateString) {
    if (!dateString) return "Mới nạp";
    const pastDate = new Date(dateString);
    if (isNaN(pastDate.getTime())) return "Mới nạp";
    const seconds = Math.floor((new Date().getTime() - pastDate.getTime()) / 1000);
    const interval = seconds / 86400;
    if (interval >= 1) return "Đăng " + Math.floor(interval) + " ngày trước";
    return "Đăng hôm nay";
  }

  // =====================================================================
  // LUỒNG RENDER: 13 PHÂN KHAN LANDING PAGE NGUYÊN KHỐI DỰA TRÊN DATA LARAVEL
  // =====================================================================
  function buildProjectLandingSections(landingData, flatData) {
    if (!landingData) return;
    const visibility = landingData.visibility || {};

    // 1. SECTION 01: HERO BANNER
    if (visibility.hero !== false && landingData.hero) {
      const hero = landingData.hero;
      const el = document.getElementById('render-section-hero');
      
      if (el) {
        const safeIsRev = typeof isRev !== 'undefined' ? isRev : '';
        const bgImg = hero.bg_url ? getAssetUrl(hero.bg_url) : '/images/no-photo.jpg';
        const safeFlatData = typeof flatData !== 'undefined' ? flatData : {};
        const safeProjectSlug = typeof projectSlug !== 'undefined' ? projectSlug : '';
        const safeBackendUrl = typeof BACKEND_URL !== 'undefined' ? BACKEND_URL : '';

        el.innerHTML = `
          <div class="relative w-full min-h-[600px] lg:h-[650px] bg-gradient-to-br from-[#fac72e] via-[#e2b327] to-[#d8aa21] rounded-[30px] md:rounded-[40px] overflow-hidden flex flex-col lg:flex-row items-center shadow-2xl ${safeIsRev}">
            <div class="absolute inset-0 opacity-10 pointer-events-none" style="background-image: url('https://www.transparenttextures.com/patterns/carbon-fibre.png');"></div>

            <div class="relative z-30 w-full lg:w-1/2 px-6 py-12 md:p-10 lg:pl-16 text-white text-center lg:text-left">
              <h1 class="text-3xl md:text-4xl lg:text-5xl font-extrabold leading-[1.1] mb-2 drop-shadow-md uppercase">
                ${escapeHTML(hero.title || safeFlatData.title || '')}
              </h1>
              <p class="text-sm md:text-xl lg:text-2xl font-bold italic mb-2 text-white/90">
                ${escapeHTML(hero.subtitle || '')}
              </p>
              
              ${hero.description 
                ? `<p class="text-xs md:text-sm text-white/85 leading-relaxed font-medium mt-3 mb-5 max-w-xl text-justify line-clamp-4 md:line-clamp-none">${escapeHTML(hero.description)}</p>` 
                : `<p class="mt-2 mb-6 text-white/80 text-[12px] md:text-xs font-medium tracking-wide uppercase">Sống hiện đại tại trung tâm Phường Đông Hoà, Thành Phố Hồ Chí Minh</p>`
              }

              <div class="hidden lg:block bg-white/10 backdrop-blur-md p-6 rounded-3xl border border-white/20 shadow-xl max-w-md animate-fade-in">
                <p class="text-sm font-bold uppercase mb-4 tracking-wider text-white">Đăng ký nhận báo giá & tham quan</p>
                
                <form id="hero-lead-form" class="space-y-3">
                  <input type="text" id="hero-lf-name" required placeholder="Họ và tên" class="w-full px-4 py-3 rounded-xl bg-white/90 text-gray-800 text-sm border-2 border-transparent focus:border-[#fac72e] focus:bg-white focus:outline-none transition-all placeholder:text-gray-400 font-medium" />
                  <input type="tel" id="hero-lf-phone" required placeholder="Số điện thoại" class="w-full px-4 py-3 rounded-xl bg-white/90 text-gray-800 text-sm border-2 border-transparent focus:border-[#fac72e] focus:bg-white focus:outline-none transition-all placeholder:text-gray-400 font-medium" />
                  
                  <button type="submit" class="w-full py-3 bg-black hover:bg-gray-800 text-white font-black rounded-xl transition-all shadow-lg active:scale-95 uppercase text-xs tracking-[0.2em] mt-2 cursor-pointer">
                    ${escapeHTML(hero.btn_text || 'Gửi yêu cầu ngay')}
                  </button>

                  <div id="hero-form-msg" class="text-xs font-bold mt-3 text-center p-3 rounded-xl hidden transition-all duration-300"></div>
                </form>
                
              </div>

              <div class="lg:hidden flex flex-col gap-4 items-center">
                <a href="tel:0911502603" class="inline-block bg-[#005745] text-white px-10 py-4 rounded-full font-black uppercase text-sm tracking-widest shadow-xl active:scale-95 transition-all">
                    Nhận báo giá ngay
                </a>
              </div>
            </div>

            <div class="relative lg:absolute right-0 inset-y-0 w-full lg:w-1/2 flex items-center justify-center p-6 lg:p-0 overflow-hidden">
              <div class="relative w-full h-full flex items-center justify-center scale-90 md:scale-100">
                <img 
                  src="${bgImg}" 
                  alt="Phối cảnh ${escapeHTML(hero.title || safeFlatData.title || '')}" 
                  class="w-[300px] md:w-[450px] lg:w-[520px] h-auto object-contain z-10 drop-shadow-[0_35px_35px_rgba(0,0,0,0.5)] py-6"
                />
              </div>
            </div>
          </div>
        `;
        el.classList.remove('hidden');

        const heroFormElement = document.getElementById('hero-lead-form');
        heroFormElement?.addEventListener('submit', async function(event) {
          event.preventDefault();
          
          const nameInput = document.getElementById('hero-lf-name');
          const phoneInput = document.getElementById('hero-lf-phone');
          const submitBtn = this.querySelector('button[type="submit"]');
          const msgEl = document.getElementById('hero-form-msg');

          const nameVal = nameInput?.value?.trim();
          const phoneVal = phoneInput?.value?.trim();

          if (!nameVal || !phoneVal || !submitBtn) return;

          if (msgEl) {
            msgEl.classList.add('hidden');
            msgEl.textContent = '';
          }

          const baseBtnText = submitBtn.innerHTML;
          submitBtn.textContent = "ĐANG LƯU HỆ THỐNG...";
          submitBtn.disabled = true;

          try {
            const response = await fetch(`${safeBackendUrl}/api/leads`, {
              method: 'POST',
              headers: {
                'Content-Type': 'application/json',
                'Accept': 'application/json'
              },
              body: JSON.stringify({
                name: nameVal,
