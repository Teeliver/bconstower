---
import MainLayout from "../../layouts/MainLayout.astro";

// 🔥 BẢO MẬT & CHUẨN SEO TUYỆT ĐỐI: Đồng bộ toàn bộ slug dự án từ Laravel phục vụ đóng gói SSG tĩnh
export async function getStaticPaths() {
  const API_BASE = import.meta.env.PUBLIC_API_BASE || "http://localhost:3000";
  try {
    // Gọi API lấy toàn bộ danh sách dự án công khai để sinh cấu trúc thư mục SEO tĩnh
    const res = await fetch(`${API_BASE}/api/projects`, {
      method: 'GET',
      headers: { 'Accept': 'application/json' }
    });
    
    if (res.ok) {
      const data = await res.json();
      const items = Array.isArray(data) ? data : (data && Array.isArray(data.data) ? data.data : []);
      
      if (items.length > 0) {
        return items.map((item: any) => {
          const slugValue = String(item.slug || item.project_slug || '').trim();
          return {
            params: { projectSlug: slugValue }
          };
        });
      }
    }
    // Bản ghi fallback an toàn để tránh sập tiến trình build của Astro khi DB trống lúc đóng gói
    return [{ params: { projectSlug: "bcons-city" } }];
  } catch (e) {
    console.error("Lỗi đồng bộ danh sách dự án phục vụ build tĩnh SEO:", e);
    return [{ params: { projectSlug: "bcons-city" } }];
  }
}

const { projectSlug } = Astro.params;

// 🔥 GIỮ NGUYÊN VẸN: Lấy trực tiếp biến cấu hình hệ thống từ file .env của Trung Tín
const PUBLIC_API_BASE = import.meta.env.PUBLIC_API_BASE || "http://localhost:3000";
