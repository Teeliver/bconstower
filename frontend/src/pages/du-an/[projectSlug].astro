  // =====================================================================
  function initCustomDropdowns() {
    const containers = document.querySelectorAll('.dropdown-container');
    
    containers.forEach(container => {
      if (container.hasAttribute('data-bound')) return;
      container.setAttribute('data-bound', 'true');

      container.addEventListener('click', function(e) {
        e.stopPropagation();
        const menu = this.querySelector('.dropdown-menu');
        const chevron = this.querySelector('.chevron-icon');
        const isHidden = menu.classList.contains('hidden');

        containers.forEach(other => {
          other.querySelector('.dropdown-menu').classList.add('hidden');
          const c = other.querySelector('.chevron-icon');
          if (c) c.classList.remove('rotate-180');
          if (other.id !== 'dropdown-sort') {
            other.classList.remove('border-orange-500', 'ring-2', 'ring-orange-500/10');
            other.classList.add('border-slate-200');
          }
        });

        if (isHidden) {
          menu.classList.remove('hidden');
          if (chevron) chevron.classList.add('rotate-180');
          if (this.id !== 'dropdown-sort') {
            this.classList.remove('border-slate-200');
            this.classList.add('border-orange-500', 'ring-2', 'ring-orange-500/10');
          }
        }
      });

      const options = container.querySelectorAll('.option-item');
      const displayVal = container.querySelector('.display-value');
      const filterKey = container.id.replace('dropdown-', '');

      options.forEach(option => {
        option.addEventListener('click', function(e) {
          e.stopPropagation();
          const value = this.getAttribute('data-value');
          displayVal.textContent = this.textContent;

          if (filterKey === 'sort') {
            activeSort = value;
          } else {
            activeFilters[filterKey] = value;
          }

          container.querySelector('.dropdown-menu').classList.add('hidden');
          const chevron = container.querySelector('.chevron-icon');
          if (chevron) chevron.classList.remove('rotate-180');
          if (container.id !== 'dropdown-sort') {
            container.classList.remove('border-orange-500', 'ring-2', 'ring-orange-500/10');
            container.classList.add('border-slate-200');
          }

          applyFilters();
        });
      });
    });
  }

  document.addEventListener('click', () => {
    document.querySelectorAll('.dropdown-container').forEach(container => {
      const dm = container.querySelector('.dropdown-menu');
      if(dm) dm.classList.add('hidden');
      const chevron = container.querySelector('.chevron-icon');
      if (chevron) chevron.classList.remove('rotate-180');
      if (container.id !== 'dropdown-sort') {
        container.classList.remove('border-orange-500', 'ring-2', 'ring-orange-500/10');
        container.classList.add('border-slate-200');
      }
    });
  });

  function renderApartmentSlice() {
    const grid = document.getElementById('project-apartments-grid');
    const loadMoreContainer = document.getElementById('load-more-container');
    const emptyBox = document.getElementById('empty-project-message');
    const resultsCountEl = document.getElementById('results-count');

    if (!grid) return;
    resultsCountEl.textContent = FILTERED_APARTMENTS.length.toLocaleString('vi-VN');

    if (FILTERED_APARTMENTS.length === 0) {
      grid.classList.add('hidden');
      loadMoreContainer.classList.add('hidden');
      emptyBox.classList.remove('hidden');
      return;
    }

    emptyBox.classList.add('hidden');
    grid.classList.remove('hidden');

    const itemsToRender = FILTERED_APARTMENTS.slice(0, VISIBLE_COUNT);

    grid.innerHTML = itemsToRender.map(function(apt) {
      let itemImages = [];
      if (apt.image) {
        if (typeof apt.image === 'string') {
          if (apt.image.trim().startsWith('[') && apt.image.trim().endsWith(']')) {
            try { itemImages = JSON.parse(apt.image); } catch(e) { itemImages = [apt.image]; }
          } else { itemImages = [apt.image]; }
        } else if (Array.isArray(apt.image)) { itemImages = apt.image; }
      }

      const rawThumb = (itemImages && itemImages.length > 0) ? itemImages[0] : '';
      const thumb = rawThumb ? getAssetUrl(rawThumb) : '/images/no-photo.jpg';
      
      const priceBillion = apt.price ? (apt.price / 1000000000).toFixed(2).replace('.', ',') : '0';
      const pricePerM2 = (apt.price && apt.area) ? (apt.price / apt.area / 1000000).toFixed(2).replace('.', ',') : '0';
      const realCreatedDate = apt.created_at || apt.createdAt || apt.updated_at || apt.updatedAt;
      const safeAddress = escapeHTML(apt.project_address || apt.projectAddress || apt.address || 'Đang cập nhật');

      return `
      <div class="relative w-full">
          <a href="/${escapeHTML(projectSlug)}/${escapeHTML(apt.slug || '')}" class="focus:outline-none">
            <div class="relative aspect-[4/3] rounded-xl overflow-hidden bg-slate-50 border border-slate-100 mb-2.5">
              <img src="${thumb}" class="w-full h-full object-cover group-hover:scale-[1.02] transition-transform duration-500" alt="${escapeHTML(apt.name)}" />
              <div class="absolute bottom-2.5 right-2.5 bg-black/50 text-white text-[11px] px-1.5 py-0.5 rounded font-medium flex items-center gap-1">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                <span>1/${itemImages.length || 1}</span>
              </div>
            </div>

            <div class="w-full pt-2">
              <div class="flex w-full flex-row items-center justify-between gap-x-2">
                    <span class="font-extrabold text-emerald-700">${priceBillion} tỷ ·   <span class="text-sm font-semibold">(${pricePerM2} triệu/m²)</span></span>
                    <span class="text-xs text-neutral-600">${timeAgo(realCreatedDate)}</span>
              </div>
              <section class="pt-1">
                  <h6 class="text-base text-lg md:text-sm font-bold text-neutral-900 line-clamp-1" title="${escapeHTML(apt.name)}">${escapeHTML(apt.name)}</h6>
                  <p class="pt-0.5 text-lg md:text-sm text-neutral-600">${escapeHTML(safeAddress)}</p>
              </section>
              <div class="flex flex-row flex-nowrap items-center pt-1.5">
                <div class="flex flex-row items-center">
                   <div class="flex flex-row items-center gap-x-1"><svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" fill="currentColor" viewBox="0 0 256 256" class="h-5 w-5 text-neutral-500"><path d="M248,112v56H112V80H216A32,32,0,0,1,248,112Z" opacity="0.2"></path><path d="M216,72H32V48a8,8,0,0,0-16,0V208a8,8,0,0,0,16,0V176H240v32a8,8,0,0,0,16,0V112A40,40,0,0,0,216,72ZM32,88h72v72H32Zm88,72V88h96a24,24,0,0,1,24,24v48Z"></path></svg><span class="whitespace-nowrap text-lg md:text-sm text-neutral-600">${apt.bedrooms || 0} PN</span></div>
                </div>
                <div class="flex flex-row items-center">
                  <div class="mx-3 h-3 w-px bg-black/10"></div>
                  <div class="flex flex-row items-center gap-x-1"><svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" fill="currentColor" viewBox="0 0 256 256" class="h-5 w-5 text-neutral-500"><path d="M240,104v40a48,48,0,0,1-48,48H64a48,48,0,0,1-48-48V104H136v40h64V104Z" opacity="0.2"></path><path d="M240,96H208a8,8,0,0,0-8-8H136a8,8,0,0,0-8,8H64V52A12,12,0,0,1,76,40a12.44,12.44,0,0,1,12.16,9.59,8,8,0,0,0,15.68-3.18A28.32,28.32,0,0,0,76,24,28,28,0,0,0,48,52V96H16a8,8,0,0,0-8,8v40a56.06,56.06,0,0,0,56,56v16a8,8,0,0,0,16,0V200h96v16a8,8,0,0,0,16,0V200a56.06,56.06,0,0,0,56-56V104A8,8,0,0,0,240,96Zm-48,8v32H144V104Zm40,40a40,40,0,0,1-40,40H64a40,40,0,0,1-40-40V112H128v32a8,8,0,0,0,8,8h64a8,8,0,0,0,8-8V112h24Z"></path></svg><span class="whitespace-nowrap text-lg md:text-sm text-neutral-600">${apt.bathrooms || 0} WC</span></div>
                </div>
                <div class="flex flex-row items-center">
                  <div class="mx-3 h-3 w-px bg-black/10"></div>
                  <div class="flex flex-row items-center gap-x-1"><svg viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-neutral-500" weight="duotone"><path opacity="0.2" fill="currentColor" d="M2.96094 2.95996H13.040939999999999V13.03996H2.96094z"></path><path d="M13.041 2.96l-3.94 3.955M9.098 2.96h3.94v3.955M2.963 13.04l3.94-3.955M6.906 13.04H2.963V9.084M13.037 9.085v3.395a.56.56 0 01-.56.56H9.099M6.902 2.96H3.521a.56.56 0 00-.56.56v3.395" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"></path></svg><span class="whitespace-nowrap text-lg md:text-sm text-neutral-600">${apt.area || 0} m²</span></div>
                </div>
              </div>
            </div>
          </a>
      </div>
      `;
    }).join('');

    if (FILTERED_APARTMENTS.length > VISIBLE_COUNT) {
      loadMoreContainer.classList.remove('hidden');
    } else {
      loadMoreContainer.classList.add('hidden');
    }
  }

  function applyFilters() {
    const priceVal = activeFilters.price;
    const dirVal = activeFilters.direction;
    const floorVal = activeFilters.floor;

    FILTERED_APARTMENTS = MASTER_APARTMENTS.filter(function(apt) {
      if (priceVal === 'under-1.5' && Number(apt.price) >= 1500000000) return false;
      if (priceVal === '1.5-2' && (Number(apt.price) < 1500000000 || Number(apt.price) > 2000000000)) return false;
      if (priceVal === 'over-2' && Number(apt.price) <= 2000000000) return false;

      if (dirVal !== 'all') {
        const aptDir = String(apt.direction_balcony || apt.direction || '').toLowerCase();
        if (!aptDir.includes(dirVal)) return false;
      }

      if (floorVal !== 'all') {
        const floorNum = parseInt(apt.floor) || 0;
        if (floorVal === 'low' && floorNum >= 8) return false;
        if (floorVal === 'mid' && (floorNum < 8 || floorNum > 18)) return false;
        if (floorVal === 'high' && floorNum <= 18) return false;
      }
      return true;
    });

    if (activeSort === 'price-asc') {
      FILTERED_APARTMENTS.sort(function(a, b) { return Number(a.price) - Number(b.price); });
    } else if (activeSort === 'price-desc') {
      FILTERED_APARTMENTS.sort(function(a, b) { return Number(b.price) - Number(a.price); });
    } else if (activeSort === 'area-desc') {
      FILTERED_APARTMENTS.sort(function(a, b) { return Number(b.area) - Number(a.area); });
    }

    VISIBLE_COUNT = 9;
    renderApartmentSlice();
  }

  // LOGIC ĐÓNG/MỞ MODAL PHƯƠNG THỨC THANH TOÁN CHUẨN XÁC
  const modalEl = document.getElementById('payment-file-modal');
  const closeBtnEl = document.getElementById('close-payment-modal-btn');
  if (modalEl && closeBtnEl) {
    const closeModal = () => {
      modalEl.classList.add('opacity-0');
      modalEl.querySelector('.bg-white')?.classList.add('scale-95');
      setTimeout(() => {
        modalEl.classList.add('hidden');
        modalEl.classList.remove('flex');
      }, 200);
    };
    closeBtnEl.addEventListener('click', closeModal);
    modalEl.addEventListener('click', (e) => {
      if (e.target === modalEl) closeModal();
    });
  }

  // =====================================================================
  // LUỒNG CHÍNH: NẠP DỮ LIỆU TỪ LARAVEL API
  // =====================================================================
  async function loadProjectPageData() {
    const skeleton = document.getElementById('project-skeleton');
    try {
      const res = await fetch(BACKEND_URL + "/api/apartments/by-project?slug=" + projectSlug);
      if (!res.ok) throw new Error("API lỗi luồng kết nối mạng");
      const result = await res.json();

      const projectInfo = result.project_info || result.projectInfo;

      if (projectInfo) {
        const addressText = projectInfo.address || projectInfo.location || "Dĩ An, Bình Dương";

        const khuvucEl = document.getElementById('text-filter-khuvuc');
        if (khuvucEl) khuvucEl.textContent = addressText.split(',').pop().trim();
        
        MASTER_APARTMENTS = Array.isArray(result.apartments) ? result.apartments : (result.data || []);
        FILTERED_APARTMENTS = MASTER_APARTMENTS;

        const landingStructure = typeof projectInfo.landing_data === 'string' ? JSON.parse(projectInfo.landing_data) : projectInfo.landing_data;
        buildProjectLandingSections(landingStructure, projectInfo);
      }

      if (skeleton) skeleton.classList.add('hidden');

      const loadMoreBtn = document.getElementById('btn-load-more');
      if (loadMoreBtn) {
        loadMoreBtn.addEventListener('click', function() {
          VISIBLE_COUNT += 6;
          renderApartmentSlice();
        });
      }

    } catch (e) {
      console.error("Lỗi đồng bộ chi tiết Landing Page & Căn hộ theo dự án:", e);
      if (skeleton) skeleton.classList.add('hidden');
    }
  }

  loadProjectPageData();
</script>

<style is:global>
  @keyframes fadeIn { from { opacity: 0; transform: translateY(4px); } to { opacity: 1; transform: translateY(0); } }
  .animate-fadeIn { animation: fadeIn 0.3s ease-out forwards; }
  .rotate-180 { transform: rotate(180deg) !important; }
  .line-clamp-1 { display: -webkit-box; -webkit-line-clamp: 1; -webkit-box-orient: vertical; overflow: hidden; }
</style>