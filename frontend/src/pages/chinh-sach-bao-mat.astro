---
// src/pages/chinh-sach-bao-mat.astro
// Trang Chính sách bảo mật thông tin khách hàng - Banner Vàng Bcons chữ Đen nằm giữa - Hệ thống bconstower.vn
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Chính Sách Bảo Mật Thông Tin | Bcons Tower">
  
  <!-- 🔥 HERO BANNER: NỀN VÀNG BCONS CHỮ ĐEN NẰM GIỮA -->
  <div class="w-full bg-[#fac72e] pt-32 pb-16 px-4 shadow-sm border-b border-[#fac72e]/20">
    <div class="max-w-[1440px] mx-auto px-4 md:px-12 text-center space-y-3.5 animate-fadeIn">
      <div class="flex items-center justify-center gap-3">
        <span class="w-6 h-[2px] bg-[#1E1E1E]/60"></span>
        <span class="text-[#1E1E1E] font-black tracking-[0.2em] uppercase text-[10px] md:text-xs">Điều khoản & Pháp lý</span>
        <span class="w-6 h-[2px] bg-[#1E1E1E]/60"></span>
      </div>
      <h1 class="text-3xl md:text-5xl font-black text-[#1E1E1E] tracking-tight leading-none uppercase drop-shadow-sm">
        Chính Sách Bảo Mật
      </h1>
      <p class="text-xs md:text-sm text-[#1E1E1E]/80 font-bold tracking-wide max-w-xl mx-auto">
        Cập nhật lần cuối: Tháng 06/2026 • Hệ thống dữ liệu bảo mật Website Bconstower.vn
      </p>
    </div>
  </div>

  <!-- BỐ CỤC 2 CỘT NỘI DUNG SANG TRỌNG PHÍA DƯỚI -->
  <div class="max-w-[1440px] mx-auto px-4 md:px-12 py-12 md:py-20">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-start">
      
      <!-- 📌 CỘT TRÁI: MỤC LỤC ĐIỀU HƯỚNG TỰ ĐỘNG GHIM CỨNG (STICKY SIDEBAR) -->
      <aside class="hidden lg:block lg:col-span-4 sticky top-28 bg-white p-6 rounded-2xl border border-slate-100 shadow-sm space-y-4">
        <p class="text-[11px] font-black uppercase text-slate-400 tracking-[0.15em] border-b border-slate-100 pb-3">Danh mục chính sách</p>
        <nav class="flex flex-col space-y-1">
          <a href="#muc-dich" class="toc-link px-3 py-2 rounded-lg text-sm font-bold text-slate-600 hover:bg-[#114232]/5 hover:text-[#114232] transition-all duration-200 flex items-center gap-2">
            <span class="text-[10px] font-mono text-slate-400">01.</span> Mục đích thu thập
          </a>
          <a href="#pham-vi" class="toc-link px-3 py-2 rounded-lg text-sm font-bold text-slate-600 hover:bg-[#114232]/5 hover:text-[#114232] transition-all duration-200 flex items-center gap-2">
            <span class="text-[10px] font-mono text-slate-400">02.</span> Phạm vi thu thập
          </a>
          <a href="#thoi-gian" class="toc-link px-3 py-2 rounded-lg text-sm font-bold text-slate-600 hover:bg-[#114232]/5 hover:text-[#114232] transition-all duration-200 flex items-center gap-2">
            <span class="text-[10px] font-mono text-slate-400">03.</span> Thời gian lưu trữ
          </a>
          <a href="#tiep-can" class="toc-link px-3 py-2 rounded-lg text-sm font-bold text-slate-600 hover:bg-[#114232]/5 hover:text-[#114232] transition-all duration-200 flex items-center gap-2">
            <span class="text-[10px] font-mono text-slate-400">04.</span> Đối tượng tiếp cận
          </a>
          <a href="#dia-chi" class="toc-link px-3 py-2 rounded-lg text-sm font-bold text-slate-600 hover:bg-[#114232]/5 hover:text-[#114232] transition-all duration-200 flex items-center gap-2">
            <span class="text-[10px] font-mono text-slate-400">05.</span> Đơn vị quản lý thông tin
          </a>
          <a href="#quyen-loi" class="toc-link px-3 py-2 rounded-lg text-sm font-bold text-slate-600 hover:bg-[#114232]/5 hover:text-[#114232] transition-all duration-200 flex items-center gap-2">
            <span class="text-[10px] font-mono text-slate-400">06.</span> Quyền lợi khách hàng
          </a>
          <a href="#cam-ket" class="toc-link px-3 py-2 rounded-lg text-sm font-bold text-slate-600 hover:bg-[#114232]/5 hover:text-[#114232] transition-all duration-200 flex items-center gap-2">
            <span class="text-[10px] font-mono text-slate-400">07.</span> Cam kết bảo mật
          </a>
        </nav>
      </aside>

      <!-- 📝 CỘT PHẢI: NỘI DUNG CHI TIẾT DẠNG THÈ -->
      <main class="col-span-1 lg:col-span-8 space-y-14 text-sm md:text-base leading-relaxed text-slate-600 font-medium">
        
        <p class="text-slate-500 italic border-l-2 border-[#fac72e] pl-4 text-sm md:text-base">
          Chào mừng quý khách đến với hệ thống dữ liệu bconstower.vn. Chúng tôi cam kết bảo vệ tuyệt đối quyền riêng tư và thông tin cá nhân của quý khách theo đúng quy định của Nghị định 13/2023/NĐ-CP về bảo vệ dữ liệu cá nhân tại Việt Nam.
        </p>

        <!-- Điều 1 -->
        <section id="muc-dich" class="space-y-4 relative group scroll-mt-24">
          <div class="absolute -left-6 top-0 text-5xl md:text-6xl font-mono font-black text-slate-100 opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none select-none">01</div>
          <div class="flex items-center gap-3">
            <div class="w-1 md:w-1.5 h-6 bg-[#fac72e] rounded-sm"></div>
            <h2 class="text-lg md:text-xl font-black text-[#114232] uppercase tracking-tight">
              1. Mục đích thu thập thông tin cá nhân
            </h2>
          </div>
          <p>Hệ thống thu thập dữ liệu cá nhân của quý khách một cách tự nguyện nhằm phục vụ các hoạt động hỗ trợ và kinh doanh minh bạch sau:</p>
          <ul class="space-y-2.5 pl-2">
            <li class="flex items-start gap-2.5"><span class="text-[#fac72e] pt-0.5">✦</span> <span>Cung cấp tài liệu, sơ đồ thiết kế mặt bằng và bảng giá rổ hàng ký gửi sang nhượng mới nhất từ các dự án Bcons City, Bcons Center City.</span></li>
            <li class="flex items-start gap-2.5"><span class="text-[#fac72e] pt-0.5">✦</span> <span>Kết nối chuyên viên tư vấn trực tiếp hỗ trợ khách hàng tham quan nhà mẫu và thực địa tiến độ dự án.</span></li>
            <li class="flex items-start gap-2.5"><span class="text-[#fac72e] pt-0.5">✦</span> <span>Xử lý quy trình đăng ký giữ chỗ, đặt cọc căn hộ theo đúng nguyện vọng tài chính.</span></li>
          </ul>
        </section>

        <!-- Điều 2 -->
        <section id="pham-vi" class="space-y-4 relative group scroll-mt-24">
          <div class="absolute -left-6 top-0 text-5xl md:text-6xl font-mono font-black text-slate-100 opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none select-none">02</div>
          <div class="flex items-center gap-3">
            <div class="w-1 md:w-1.5 h-6 bg-[#fac72e] rounded-sm"></div>
            <h2 class="text-lg md:text-xl font-black text-[#114232] uppercase tracking-tight">
              2. Phạm vi thu thập thông tin
            </h2>
          </div>
          <p>Phạm vi thông tin thu thập được giới hạn nghiêm ngặt trong biểu mẫu liên hệ hoặc rổ bộ lọc tìm kiếm căn hộ:</p>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 pt-2">
            <div class="bg-white border border-slate-100 p-4 rounded-xl flex items-center gap-3 shadow-sm">
              <div class="w-8 h-8 rounded-lg bg-[#114232]/5 flex items-center justify-center text-[#114232] font-bold text-xs">A</div>
              <div><p class="text-xs text-slate-400 font-bold uppercase tracking-wider">Định danh</p><p class="text-sm font-bold text-slate-800">Họ tên & Số điện thoại</p></div>
            </div>
            <div class="bg-white border border-slate-100 p-4 rounded-xl flex items-center gap-3 shadow-sm">
              <div class="w-8 h-8 rounded-lg bg-[#114232]/5 flex items-center justify-center text-[#114232] font-bold text-xs">B</div>
              <div><p class="text-xs text-slate-400 font-bold uppercase tracking-wider">Kết nối</p><p class="text-sm font-bold text-slate-800">Địa chỉ Email nhận tài liệu</p></div>
            </div>
          </div>
        </section>

        <!-- Điều 3 -->
        <section id="thoi-gian" class="space-y-4 relative group scroll-mt-24">
          <div class="absolute -left-6 top-0 text-5xl md:text-6xl font-mono font-black text-slate-100 opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none select-none">03</div>
          <div class="flex items-center gap-3">
            <div class="w-1 md:w-1.5 h-6 bg-[#fac72e] rounded-sm"></div>
            <h2 class="text-lg md:text-xl font-black text-[#114232] uppercase tracking-tight">
              3. Thời gian lưu trữ thông tin
            </h2>
          </div>
          <p>
            Dữ liệu cá nhân được mã hóa và lưu trữ an toàn trên máy chủ đám mây nội bộ. Thời hạn lưu trữ kéo dài cho đến khi hoàn tất chu kỳ tư vấn, giao dịch ký gửi căn hộ hoặc cho đến khi hệ thống tiếp nhận yêu cầu xóa bỏ bằng văn bản/email trực tiếp từ chủ thể dữ liệu.
          </p>
        </section>

        <!-- Điều 4 -->
        <section id="tiep-can" class="space-y-4 relative group scroll-mt-24">
          <div class="absolute -left-6 top-0 text-5xl md:text-6xl font-mono font-black text-slate-100 opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none select-none">04</div>
          <div class="flex items-center gap-3">
            <div class="w-1 md:w-1.5 h-6 bg-[#fac72e] rounded-sm"></div>
            <h2 class="text-lg md:text-xl font-black text-[#114232] uppercase tracking-tight">
              4. Đối tượng tiếp cận thông tin
            </h2>
          </div>
          <p>Để đảm bảo tính riêng tư, thông tin thu thập tuyệt đối không chia sẻ cho bất kỳ bên thứ ba nào ngoài:</p>
          <ul class="space-y-2 pl-2">
            <li class="flex items-center gap-2"><div class="w-1.5 h-1.5 rounded-full bg-[#114232]"></div> <span>Bộ phận kỹ thuật số quản lý lõi dữ liệu website bconstower.vn.</span></li>
            <li class="flex items-center gap-2"><div class="w-1.5 h-1.5 rounded-full bg-[#114232]"></div> <span>Trưởng phòng kinh doanh phụ trách bàn giao chuyên viên chăm sóc trực tiếp.</span></li>
          </ul>
        </section>

        <!-- Điều 5 -->
        <section id="dia-chi" class="space-y-4 relative group scroll-mt-24">
          <div class="absolute -left-6 top-0 text-5xl md:text-6xl font-mono font-black text-slate-100 opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none select-none">05</div>
          <div class="flex items-center gap-3">
            <div class="w-1 md:w-1.5 h-6 bg-[#fac72e] rounded-sm"></div>
            <h2 class="text-lg md:text-xl font-black text-[#114232] uppercase tracking-tight">
              5. Đơn vị thu thập và quản lý thông tin
            </h2>
          </div>
          <div class="bg-gradient-to-br from-white to-slate-50/50 p-6 rounded-2xl border border-slate-100 space-y-2 shadow-sm relative overflow-hidden">
            <div class="absolute right-0 bottom-0 text-8xl font-black text-slate-100/40 translate-x-5 translate-y-5 select-none font-mono">B</div>
            <p class="font-black text-base text-[#114232] tracking-wide">PHÒNG KINH DOANH BẤT ĐỘNG SẢN BCONS TOWER</p>
            <p class="text-sm"><strong class="text-slate-500 font-bold">Cổng thông tin:</strong> bconstower.vn</p>
            <p class="text-sm"><strong class="text-slate-500 font-bold">Hotline tiếp nhận dữ liệu:</strong> 0911 502 603</p>
            <p class="text-sm"><strong class="text-slate-500 font-bold">Email hỗ trợ:</strong> tin.bconsvietnam@gmail.com</p>
          </div>
        </section>

        <!-- Điều 6 -->
        <section id="quyen-loi" class="space-y-4 relative group scroll-mt-24">
          <div class="absolute -left-6 top-0 text-5xl md:text-6xl font-mono font-black text-slate-100 opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none select-none">06</div>
          <div class="flex items-center gap-3">
            <div class="w-1 md:w-1.5 h-6 bg-[#fac72e] rounded-sm"></div>
            <h2 class="text-lg md:text-xl font-black text-[#114232] uppercase tracking-tight">
              6. Quyền lợi cá nhân đối với dữ liệu của mình
            </h2>
          </div>
          <p>
            Khách hàng có toàn quyền yêu cầu kiểm tra, cập nhật thông tin sai lệch hoặc ép buộc hệ thống xóa bỏ dữ liệu vĩnh viễn khỏi DB. Quý khách vui lòng gọi trực tiếp hotline <strong class="text-[#114232]">0911 502 603</strong> để tổng đài xử lý yêu cầu ẩn danh lập tức trong vòng 12 giờ làm việc.
          </p>
        </section>

        <!-- Điều 7 -->
        <section id="cam-ket" class="space-y-4 relative group scroll-mt-24">
          <div class="absolute -left-6 top-0 text-5xl md:text-6xl font-mono font-black text-slate-100 opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none select-none">07</div>
          <div class="flex items-center gap-3">
            <div class="w-1 md:w-1.5 h-6 bg-[#fac72e] rounded-sm"></div>
            <h2 class="text-lg md:text-xl font-black text-[#114232] uppercase tracking-tight">
              7. Cam kết bảo mật thông tin khách hàng
            </h2>
          </div>
          <p>
            Chúng tôi cam kết sử dụng công nghệ tường lửa đa tầng bảo vệ cơ sở dữ liệu bán hàng. Website bconstower.vn tuân thủ nghiêm ngặt chuẩn an toàn bảo mật, ngăn ngừa hoàn toàn các nguy cơ rò rỉ hoặc tấn công đánh cắp thông tin, bảo vệ lợi ích an cư cao nhất cho cộng đồng khách hàng Bcons.
          </p>
        </section>

      </main>
    </div>
  </div>
</MainLayout>

<script is:inline>
  // 🌟 HIỆU ỨNG LIÊN KẾT MỤC LỤC HOẠT ĐỘNG (ACTIVE SCROLL SPY)
  function initScrollSpy() {
    const links = document.querySelectorAll('.toc-link');
    const sections = document.querySelectorAll('main section');

    window.addEventListener('scroll', () => {
      let currentSectionId = '';
      sections.forEach(section => {
        const sectionTop = section.offsetTop;
        if (window.scrollY >= sectionTop - 120) {
          currentSectionId = section.getAttribute('id');
        }
      });

      links.forEach(link => {
        link.classList.remove('bg-[#114232]/5', 'text-[#114232]', 'pl-5');
        if (link.getAttribute('href') === `#${currentSectionId}`) {
          link.classList.add('bg-[#114232]/5', 'text-[#114232]', 'pl-5');
        }
      });
    });
  }

  initScrollSpy();
  document.addEventListener('DOMContentLoaded', initScrollSpy);
  document.addEventListener('astro:page-load', initScrollSpy);
</script>

<style>
  @import "tailwindcss";
  
  @keyframes fadeIn { 
    from { opacity: 0; transform: translateY(12px); } 
    to { opacity: 1; transform: translateY(0); } 
  }
  .animate-fadeIn { animation: fadeIn 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards; }
  
  html {
    scroll-behavior: smooth;
  }
  
  .toc-link {
    transition: all 0.25s cubic-bezier(0.16, 1, 0.3, 1);
  }
</style>