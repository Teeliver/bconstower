---
// src/pages/[projectSlug]/[apartmentSlug].astro
import MainLayout from "../../layouts/MainLayout.astro";
import Navbar from '../../components/Navbar.astro';

export async function getStaticPaths() {
  const PUBLIC_API_BASE = import.meta.env.PUBLIC_API_BASE || "http://localhost:8000";
  try {
    const res = await fetch(`${PUBLIC_API_BASE}/api/apartments/public-paths`, {
      method: 'GET',
      headers: { 'Accept': 'application/json' }
    });
    
    if (!res.ok) return [];
    const data = await res.json();
    const paths = Array.isArray(data) ? data : (data && Array.isArray(data.data) ? data.data : []);
    
    return paths.map((p: any) => {
      const pSlug = String(p.projectSlug || p.project_slug || p.projectSlugPath || '').trim();
      const aSlug = String(p.apartmentSlug || p.apartment_slug || p.slug || '').trim();
      
      return {
        params: { projectSlug: pSlug, apartmentSlug: aSlug }
      };
    }).filter((item: any) => {
      return item.params.projectSlug && 
             item.params.apartmentSlug && 
             item.params.projectSlug !== 'undefined' &&
             item.params.projectSlug !== 'images' &&
             item.params.projectSlug !== 'assets' &&
             item.params.projectSlug !== 'favicon.ico';
    });
  } catch (e) {
    console.error("Lỗi đồng bộ danh sách đường dẫn căn hộ chi tiết:", e);
    return [];
  }
}

const { projectSlug, apartmentSlug } = Astro.params;
const PUBLIC_API_BASE = import.meta.env.PUBLIC_API_BASE || "http://localhost:8000";

let serverData = null;
let priceDisplay = "Liên hệ";
let pricePerM2Display = "Đang cập nhật";
let seoTitle = "Chi tiết căn hộ Bcons";
let seoDescription = "Bảng giá rổ hàng chi tiết căn hộ dự án Bcons cập nhật mới nhất từ phòng kinh doanh.";
let seoImage = "https://placehold.co/800x450?text=Bcons+Apartment";
let itemImages: string[] = [];

try {
  const res = await fetch(`${PUBLIC_API_BASE}/api/apartments/public-detail?project=${projectSlug}&slug=${apartmentSlug}`);
  if (res.ok) {
    serverData = await res.json();
    if (serverData) {
      seoTitle = serverData.name ? `${serverData.name} - Dự án ${serverData.projectName || 'Bcons'}` : seoTitle;
      seoDescription = serverData.summary || serverData.description?.substring(0, 160) || seoDescription;
      
      if (serverData.price) {
        priceDisplay = (serverData.price / 1000000000).toFixed(2).replace('.', ',') + " tỷ";
        if (serverData.area) {
          pricePerM2Display = Math.round(serverData.price / serverData.area / 1000000) + " tr/m²";
        }
      }
      
      if (serverData.image) {
        if (typeof serverData.image === 'string') {
          try { itemImages = JSON.parse(serverData.image); } catch { itemImages = [serverData.image]; }
        } else if (Array.isArray(serverData.image)) { itemImages = serverData.image; }
      }
      if (itemImages.length > 0) {
        seoImage = itemImages[0].startsWith('http') ? itemImages[0] : `${PUBLIC_API_BASE}/${itemImages[0].replace(/^\//, '')}`;
      }
    }
  }
} catch (e) {
  console.error("Lỗi nạp SEO tĩnh tầng Server:", e);
}

// 🔥 CẤU HÌNH JSON-LD SCHEMA: Khai báo cấu trúc dữ liệu cho thuật toán Google Index Rich Snippet
const schemaData = {
  "@context": "https://schema.org",
  "@type": "SingleFamilyResidence",
  "name": serverData?.name || seoTitle,
  "description": seoDescription,
  "image": seoImage,
  "address": {
    "@type": "PostalAddress",
    "streetAddress": serverData?.projectAddress || "Đang cập nhật"
  },
  "offers": {
    "@type": "Offer",
    "price": serverData?.price || "0",
    "priceCurrency": "VND",
    "availability": "https://schema.org/InStoreOnly"
  }
};
---

<MainLayout title={seoTitle} description={seoDescription} image={seoImage}>
  
  <script type="application/ld+json" set:html={JSON.stringify(schemaData)}></script>

  <div 
    id="apartment-detail-root"
    class="bg-[#F4F7F6] w-full overflow-x-hidden break-words min-h-screen pb-20 font-sans mt-20"
    data-project-id={serverData?.projectId || serverData?.project_id || ''}
    data-apartment-id={serverData?.id || ''}
    data-lat={serverData?.lat || ''}
    data-lng={serverData?.lng || ''}
    data-project-name={serverData?.projectName || 'Dự án Bcons'}
    data-images={JSON.stringify(itemImages)}
    data-backend={PUBLIC_API_BASE}
    data-project-slug={projectSlug}
    data-apartment-title={serverData?.name || ''}
    data-bedroom-count={serverData?.bedrooms || 2}
    data-bathroom-count={serverData?.bathrooms || 2}
  >
    <div class="max-w-7xl mx-auto px-4 pt-4">
      
      <div id="main-content" class="animate-fadeIn space-y-4">
        
        <nav class="flex text-[12px] text-slate-400 font-medium">
          <a href="/" class="hover:text-emerald-700">Trang chủ</a>
          <span class="mx-2">/</span>
          <span id="breadcrumb-project" class="text-slate-600">{serverData?.projectName || "Dự án Bcons"}</span>
        </nav>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 items-start">
          <div class="lg:col-span-2 space-y-4">
            
            <div class="bg-white p-1 rounded-2xl shadow-sm border border-slate-50">
              <div class="relative aspect-[16/9] rounded-xl overflow-hidden bg-slate-100">
                <img id="main-gallery-img" src={seoImage} alt={serverData?.name || "Hình ảnh căn hộ Bcons"} onerror="this.src='https://placehold.co/800x450?text=No+Image'" class="w-full h-full object-cover" />
                <div id="gallery-counter" class="absolute bottom-4 right-4 bg-black/50 text-white px-3 py-1 rounded-lg text-[10px] font-bold">1 / {itemImages.length} Ảnh</div>
              </div>
              <div id="thumb-gallery-container" class="flex gap-2 p-2 overflow-x-auto scrollbar-hide">
                {itemImages.map((img, idx) => {
                  const fullThumbUrl = img.startsWith('http') ? img : `${PUBLIC_API_BASE}/${img.replace(/^\//, '')}`;
                  return (
                    <div class={`thumb-gallery-item w-24 h-16 rounded-lg overflow-hidden flex-shrink-0 border-2 ${idx === 0 ? 'border-emerald-600' : 'border-transparent'} hover:border-emerald-600 transition-all cursor-pointer`} data-index={idx} data-url={fullThumbUrl}>
                      <img src={fullThumbUrl} alt={`Thumbnail ${idx + 1}`} class="w-full h-full object-cover" />
                    </div>
                  );
                })}
              </div>
            </div>

            <div class="bg-white p-8 rounded-2xl shadow-sm border border-slate-50">
              <div class="flex items-center justify-between mb-4">
                <div class="flex-shrink-0">
                  <div class="flex flex-row items-center gap-x-2">
                      <span id="apartment-price" class="text-2xl font-extrabold text-emerald-700">{priceDisplay}</span>
                  </div>
                  <span id="apartment-price-per-m2" class="pt-1 font-bold text-emerald-700">{pricePerM2Display}</span>
                </div>
                <div class="rounded-xl">
                  <ul class="flex flex-row items-center gap-x-3">
                    <li class="flex h-14 w-14 flex-col items-center justify-between rounded-md bg-neutral-100 py-1.5 px-2">
                      <svg viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 flex-shrink-0 text-neutral-600"><path opacity="0.2" d="M7 5h6.5a2 2 0 012 2v3.5H7V5z" fill="currentColor"></path><path d="M7 10.5V5h6.5a2 2 0 012 2v3.5M1.5 13V3M1.5 10.5h14V13M7 5H1.5" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"></path></svg>
                      <span id="badge-beds" class="whitespace-nowrap text-sm font-semibold text-neutral-700">{serverData?.bedrooms || "--"} PN</span>
                    </li>
                    <li class="flex h-14 w-14 flex-col items-center justify-between rounded-md bg-neutral-100 py-1.5 px-2">
                      <svg viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 flex-shrink-0 text-neutral-600"><g clip-path="url(#clip0_1135_13499)"><path opacity="0.2" d="M12.5 6.5V9h-4V6.5H1V9a3 3 0 003 3h8a3 3 0 003-3V6.5h-2.5z" fill="currentColor"></path><path d="M4.5 12v1.5M11.5 12v1.5M12.5 6h-4v3h4V6z" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"></path><path d="M12.5 6.5H15V9a3 3 0 01-3 3H4a3 3 0 01-3-3V6.5h7.5M3.5 6.5V3.25A1.25 1.25 0 014.75 2 1.278 1.278 0 016 3" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"></path></g><defs><clipPath id="clip0_1135_13499"><path fill="#fff" d="M0 0H16V16H0z"></path></clipPath></defs></svg>
                      <span id="badge-baths" class="whitespace-nowrap text-sm font-semibold text-neutral-700">{serverData?.bathrooms || "--"} WC</span>
                    </li>
                    <li class="flex h-14 w-14 flex-col items-center justify-between rounded-md bg-neutral-100 py-1.5 px-2">
                      <svg viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 flex-shrink-0 text-neutral-600"><path opacity="0.2" fill="currentColor" d="M2.96094 2.95996H13.040939999999999V13.03996H2.96094z"></path><path d="M13.041 2.96l-3.94 3.955M9.098 2.96h3.94v3.955M2.963 13.04l3.94-3.955M6.906 13.04H2.963V9.084M13.037 9.085v3.395a.56.56 0 01-.56.56H9.099M6.902 2.96H3.521a.56.56 0 00-.56.56v3.395" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"></path></svg>
                      <span id="badge-area" class="whitespace-nowrap text-sm font-semibold text-neutral-700">{serverData?.area || "--"} m²</span>
                    </li>
                  </ul>
                </div>
              </div>
              <h1 id="apartment-title" class="text-xl font-bold text-slate-800 leading-tight mb-3 uppercase tracking-tight">{serverData?.name || "..."}</h1>
              <p class="text-[16px] text-slate-500 flex items-center gap-2 font-medium">
                <svg class="w-4 h-4 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path></svg>
                <span id="project-address-text">{serverData?.projectAddress || "..."}</span>
              </p>
            </div>

            <div class="bg-white p-8 rounded-2xl shadow-sm border border-slate-50 space-y-12">
              <section>
                <div class="flex items-center gap-3 mb-12">
                  <div class="w-1.5 h-6 bg-[#fac72e] rounded-full"></div>
                  <h2 class="text-md font-bold text-slate-800 uppercase tracking-tight">Khoảng giá phổ biến khu vực <span id="text-header-khuvuc" class="text-orange-600">...</span></h2>
                </div>
        
                <div class="relative mb-6 pt-10 w-full max-w-[448px] mx-auto lg:mx-0">
                  <div id="price-tooltip" class="absolute -translate-x-1/2 top-0" style="left: 50%;">
                    <div class="bg-[#006B5D] text-white px-3 py-1.5 rounded-lg font-bold text-sm relative whitespace-nowrap shadow-md">
                      <span id="tooltip-current-meter">{pricePerM2Display.replace(" tr/m²", "")}</span> tr/m²
                      <div class="absolute -bottom-1 left-1/2 -translate-x-1/2 w-2 h-2 bg-[#006B5D] rotate-45"></div>
                    </div>
                  </div>

                  <div class="flex h-1.5 w-full rounded-full overflow-hidden bg-slate-100">
                    <div class="w-1/4 bg-slate-300 mr-1 rounded-full"></div>
                    <div class="w-2/4 bg-[#006B5D] mr-1 rounded-full"></div>
                    <div class="w-1/4 bg-slate-300 mr-1 rounded-full"></div>
                  </div>

                  <div class="relative w-full mt-4 h-10">
                    <div class="absolute text-center" style="left: 25%; transform: translateX(-50%);">
                      <div class="w-0 h-0 border-l-[4px] border-l-transparent border-r-[4px] border-r-transparent border-b-[6px] border-b-[#006B5D] mx-auto mb-1"></div>
                      <p class="text-[#006B5D] font-bold text-[13px] whitespace-nowrap"><span id="range-low-meter">--</span> tr/m²</p>
                    </div>
                    <div class="absolute text-center" style="left: 75%; transform: translateX(-50%);">
                      <div class="w-0 h-0 border-l-[4px] border-l-transparent border-r-[4px] border-r-transparent border-b-[6px] border-b-[#006B5D] mx-auto mb-1"></div>
                      <p class="text-[#006B5D] font-bold text-[13px] whitespace-nowrap"><span id="range-high-meter">--</span> tr/m²</p>
                    </div>
                  </div>
                </div>

                <div class="flex w-full items-start gap-4 p-4 border border-slate-100 bg-slate-50/50 rounded-2xl">
                  <div class="w-12 h-12 rounded-full bg-emerald-50 flex items-center justify-center flex-shrink-0">
                    <div class="w-6 h-6 bg-[#006B5D] rounded-full flex items-center justify-center text-white">
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
                    </div>
                  </div>
                  <div>
                    <p id="text-price-status-title" class="text-sm font-bold text-slate-800">Đang phân tích mức giá so với khu vực...</p>
                    <p class="text-slate-500 font-medium text-sm"><span id="price-status-sub">Căn hộ dự án {serverData?.projectName || "Bcons"}</span></p>
                  </div>
                </div>

                <div class="mt-4 p-4 rounded-xl bg-orange-50/40 border border-orange-100/70">
                  <p class="text-[11px] font-black text-orange-700 uppercase tracking-wider mb-2.5 flex items-center gap-1.5">
                    <span class="text-md">💡</span> Yếu tố ảnh hưởng & Điều kiện giá thị trường
                  </p>
                  <ul id="market-notes-container" class="space-y-2 text-xs text-slate-500 font-medium list-none pl-0">
                    <li class="italic text-slate-400">Đang phân tích dữ liệu phòng kinh doanh...</li>
                  </ul>
                </div>
              </section>

              <section class="pt-8 border-t border-slate-100" id="desc-section">
                <div class="flex items-center gap-3 mb-2">
                  <div class="w-1.5 h-6 bg-[#fac72e] rounded-full"></div>
                  <h2 class="text-md font-bold text-slate-800 uppercase tracking-tight">Mô tả</h2>
                </div>
                <div class="inline-block w-full">
                  <p class="inline whitespace-pre-line text-sm leading-6 text-slate-600 font-medium text-justify [overflow-wrap:anywhere]" id="desc-text">
                    {serverData?.description || "Đang nạp mô tả chi tiết..."}
                  </p>
                  <button type="button" id="btn-desc-toggle" class="focus:outline-none focus:ring-0 focus:ring-offset-0 inline px-1 text-sm font-semibold text-emerald-800 underline select-none hidden">
                    Xem thêm
                  </button>
                </div>
              </section>

              <section class="pt-8 border-t border-slate-100">
                <div class="flex items-center gap-3 mb-2">
                  <div class="w-1.5 h-6 bg-[#fac72e] rounded-full"></div>
                  <h2 class="text-md font-bold text-slate-800 uppercase tracking-tight">Chi tiết thông số</h2>
                </div>
                <div class="flex flex-col pt-1">
                  <div class="w-full">
                    <div class="grid w-full grid-cols-2 gap-6 sm:grid-cols-3 sm:gap-8">
                      <div class="flex flex-col gap-y-1">
                        <h6 class="text-sm font-medium text-neutral-500">Phòng ngủ</h6>
                        <div class="flex flex-row items-center gap-x-2">
                          <svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" fill="currentColor" viewBox="0 0 256 256" class="h-6 w-6 flex-shrink-0 text-emerald-700"><path d="M248,112v56H112V80H216A32,32,0,0,1,248,112Z" opacity="0.2"></path><path d="M216,72H32V48a8,8,0,0,0-16,0V208a8,8,0,0,0,16,0V176H240v32a8,8,0,0,0,16,0V112A40,40,0,0,0,216,72ZM32,88h72v72H32Zm88,72V88h96a24,24,0,0,1,24,24v48Z"></path></svg>
                          <b id="detail-beds" class="font-bold text-neutral-900">{serverData?.bedrooms || "--"} PN</b>
                        </div>
                      </div>
                      <div class="flex flex-col gap-y-1">
                        <h6 class="text-sm font-medium text-neutral-500">Phòng tắm / WC</h6>
                        <div class="flex flex-row items-center gap-x-2">
                          <svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" fill="currentColor" viewBox="0 0 256 256" class="h-6 w-6 flex-shrink-0 text-emerald-700"><path d="M240,104v40a48,48,0,0,1-48,48H64a48,48,0,0,1-48-48V104H136v40h64V104Z" opacity="0.2"></path><path d="M240,96H208a8,8,0,0,0-8-8H136a8,8,0,0,0-8,8H64V52A12,12,0,0,1,76,40a12.44,12.44,0,0,1,12.16,9.59,8,8,0,0,0,15.68-3.18A28.32,28.32,0,0,0,76,24,28,28,0,0,0,48,52V96H16a8,8,0,0,0-8,8v40a56.06,56.06,0,0,0,56,56v16a8,8,0,0,0,16,0V200h96v16a8,8,0,0,0,16,0V200a56.06,56.06,0,0,0,56-56V104A8,8,0,0,0,240,96Zm-48,8v32H144V104Zm40,40a40,40,0,0,1-40,40H64a40,40,0,0,1-40-40V112H128v32a8,8,0,0,0,8,8h64a8,8,0,0,0,8-8V112h24Z"></path></svg>
                          <b id="detail-baths" class="font-bold text-neutral-900">{serverData?.bathrooms || "--"} WC</b>
                        </div>
                      </div>
                      <div class="flex flex-col gap-y-1">
                        <h6 class="text-sm font-medium text-neutral-500">Diện tích sử dụng</h6>
                        <div class="flex flex-row items-center gap-x-2">
                          <svg viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 flex-shrink-0 text-emerald-700"><path opacity="0.2" fill="currentColor" d="M3.69922 3.69995H16.29922V16.29995H3.69922z"></path><path d="M16.3 3.7l-4.925 4.944M11.371 3.7h4.925v4.944M3.7 16.3l4.925-4.944M8.633 16.3H3.704v-4.944M16.294 11.356V15.6a.7.7 0 01-.7.7h-4.222M8.626 3.7H4.399a.7.7 0 00-.7.7v4.244" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"></path></svg>
                          <b id="detail-area" class="font-bold text-neutral-900">{serverData?.area || "--"} m²</b>
                        </div>
                      </div>
                    </div>
                  </div>

                  <div class="w-full">
                    <div class="h-px my-6 w-full" style="background-image: linear-gradient(to right, rgb(168, 162, 158) 30%, rgba(255, 255, 255, 0) 20%); background-position: center bottom; background-repeat: repeat-x; background-size: 4px 1px;"></div>
                    <div class="grid w-full grid-cols-2 gap-6 sm:grid-cols-3 sm:gap-8">
                      <div class="flex flex-col gap-y-1">
                        <h6 class="text-sm font-medium text-neutral-500">Vị trí tầng</h6>
                        <div class="flex flex-row items-center gap-x-2">
                          <svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" fill="currentColor" viewBox="0 0 256 256" class="h-6 w-6 flex-shrink-0 text-emerald-700"><path d="M224,80l-96,56L32,80l96-56Z" opacity="0.2"></path><path d="M230.91,172xA8,8,0,0,1,228,182.91l-96,56a8,8,0,0,1-8.06,0l-96-56A8,8,0,0,1,36,169.09l92,53.65,92-53.65A8,8,0,0,1,230.91,172ZM220,121.09l-92,53.65L36,121.09A8,8,0,0,0,28,134.91l96,56a8,8,0,0,0,8.06,0l96-56A8,8,0,1,0,220,121.09ZM24,80a8,8,0,0,1,4-6.91l96-56a8,8,0,0,1,8.06,0l96,56a8,8,0,0,1,0,13.82l-96,56a8,8,0,0,1-8.06,0l-96-56A8,8,0,0,1,24,80Zm23.88,0L128,126.74,208.12,80,128,33.26Z"></path></svg>
                          <b id="detail-floor" class="font-bold text-neutral-900">{serverData?.floor || "--"}</b>
                        </div>
                      </div>
                      <div class="flex flex-col gap-y-1">
                        <h6 class="text-sm font-medium text-neutral-500">Hướng cửa chính</h6>
                        <div class="flex flex-row items-center gap-x-2">
                          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" viewBox="0 0 256 256" class="h-6 w-6 flex-shrink-0 text-emerald-700">
                            <path d="M128,24A104,104,0,1,0,232,128,104.11,104.11,0,0,0,128,24Zm0,192a88,88,0,1,1,88-88A88.1,88.1,0,0,1,128,216Zm40-88a8,8,0,0,1-8,8H136v40a8,8,0,0,1-16,0V136H80a8,8,0,0,1,0-16h40V80a8,8,0,0,1,16,0v40h40A8,8,0,0,1,168,128Z"></path>
                          </svg>
                          <b id="detail-dir-main" class="font-bold text-neutral-900">{serverData?.direction_main || "--"}</b>
                        </div>
                      </div>
                      <div class="flex flex-col gap-y-1">
                        <h6 class="text-sm font-medium text-neutral-500">Hướng ban công</h6>
                        <div class="flex flex-row items-center gap-x-2">
                          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" viewBox="0 0 256 256" class="h-6 w-6 flex-shrink-0 text-emerald-700">
