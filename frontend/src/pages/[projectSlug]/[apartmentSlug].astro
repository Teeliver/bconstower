</MainLayout>

<script is:inline>
  // TRÍCH XUẤT BIẾN TỪ DATASET TẦNG GỐC CỦA SERVER ĐỂ HYDRATE CLIENT
  const root = document.getElementById('apartment-detail-root');
  const BACKEND_URL = root.dataset.backend;
  const projectSlug = root.dataset.projectSlug;
  const projectId = root.dataset.projectId;
  const apartmentId = root.dataset.apartmentId;
  const lat = root.dataset.lat;
  const lng = root.dataset.lng;
  const projectName = root.dataset.projectName;
  const images = JSON.parse(root.dataset.images || '[]');

  // Khởi chạy CDN SweetAlert2
  if (!window.Swal && !document.getElementById('sweetalert-js')) {
    const script = document.createElement('script');
    script.id = 'sweetalert-js';
    script.src = 'https://cdn.jsdelivr.net/npm/sweetalert2@11';
    document.head.appendChild(script);
  }

  const escapeHTML = (str) => {
    if (!str) return '';
    return str.replace(/[&<>"']/g, (match) => {
      const map = { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' };
      return map[match] || match;
    });
  };

  // Nạp tài nguyên MapLibre
  if (!document.getElementById('maplibre-css')) {
    const link = document.createElement('link');
    link.id = 'maplibre-css';
    link.rel = 'stylesheet';
    link.href = 'https://unpkg.com/maplibre-gl@4.7.1/dist/maplibre-gl.css';
    document.head.appendChild(link);
  }
  if (!document.getElementById('maplibre-js')) {
    const script = document.createElement('script');
    script.id = 'maplibre-js';
    script.src = 'https://unpkg.com/maplibre-gl@4.7.1/dist/maplibre-gl.js';
    document.head.appendChild(script);
  }

  function initMap(containerId, lat, lng, name) {
    if (!document.getElementById(containerId) || !lat || !lng) return;
    const checkAndInit = () => {
      if (typeof window.maplibregl === 'undefined') {
        setTimeout(checkAndInit, 50);
        return;
      }
      try {
        const map = new window.maplibregl.Map({
          container: containerId,
          style: {
            "version": 8,
            "sources": { "osm": { "type": "raster", "tiles": ["https://a.tile.openstreetmap.org/{z}/{x}/{y}.png"], "tileSize": 256 } },
            "layers": [{ "id": "osm-tiles", "type": "raster", "source": "osm", "maxzoom": 19 }]
          },
          center: [Number(lng), Number(lat)],
          zoom: 15,
          scrollZoom: false
        });
        map.on('load', () => {
          map.addControl(new window.maplibregl.NavigationControl(), 'top-right');
          const marker = new window.maplibregl.Marker({ color: '#006B5D' }).setLngLat([Number(lng), Number(lat)]).addTo(map);
          marker.setPopup(new window.maplibregl.Popup({ offset: 25 }).setHTML("<div class='font-sans font-bold text-xs p-1'>" + escapeHTML(name) + "</div>"));
        });
      } catch (e) { console.error("Lỗi dựng bản đồ:", e); }
    };
    checkAndInit();
  }

  function timeAgo(dateString) {
    if (!dateString) return "Mới đăng";
    const pastTime = new Date(dateString).getTime();
    if (isNaN(pastTime)) return "Mới đăng";
    const seconds = Math.floor((new Date().getTime() - pastTime) / 1000);
    if (seconds < 5) return "Vừa xong";
    let interval = seconds / 31536000;
    if (interval >= 1) return Math.floor(interval) + " năm trước";
    interval = seconds / 2592000;
    if (interval >= 1) return Math.floor(interval) + " tháng trước";
    interval = seconds / 86400;
    if (interval >= 1) return Math.floor(interval) + " ngày trước";
    interval = seconds / 3600;
    if (interval >= 1) return Math.floor(interval) + " giờ trước";
    interval = seconds / 60;
    if (interval >= 1) return Math.floor(interval) + " phút trước";
    return "Vừa xong";
  }

  // Tải rổ hàng căn hộ tương tự biệt lập
  async function loadSimilarApartments() {
    const grid = document.getElementById('similar-apartments-grid');
    const section = document.getElementById('similar-section');
    if (!grid || !projectId || !apartmentId) return;

    try {
      const res = await fetch(`${BACKEND_URL}/api/similar-apartments?projectId=${projectId}&excludeId=${apartmentId}&projectSlug=${projectSlug}`);
      const data = await res.json();
      if (!data || data.length === 0) {
        if (section) section.classList.add('hidden');
        return;
      }
      grid.innerHTML = data.map(apt => {
        let itemImages = [];
        if (apt.image) {
          if (typeof apt.image === 'string' && apt.image.trim().startsWith('[')) {
            try { itemImages = JSON.parse(apt.image); } catch { itemImages = [apt.image]; }
          } else { itemImages = [apt.image]; }
        }
        const thumb = itemImages[0] ? (itemImages[0].startsWith('http') ? itemImages[0] : `${BACKEND_URL.replace(/\/$/, '')}/${itemImages[0].replace(/^\//, '')}`) : 'https://placehold.co/600x450?text=No+Image';
        return `
          <a href="/${escapeHTML(apt.project_slug || projectSlug)}/${escapeHTML(apt.slug)}" class="group block transition-all duration-300">
            <div class="relative aspect-[4/3] rounded-2xl overflow-hidden mb-3 shadow-sm border border-slate-50">
              <img src="${thumb}" alt="${escapeHTML(apt.name)}" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
              <div class="absolute bottom-2 right-2 bg-black/40 backdrop-blur-sm px-2 py-1 rounded-lg text-white text-[10px] font-bold">1/${itemImages.length} Ảnh</div>
            </div>
            <div class="space-y-1.5 px-1">
              <div class="flex justify-between items-center">
                <div class="flex items-center gap-1">
                  <span class="text-[15px] font-bold text-[#064e3b]">${(apt.price / 1000000000).toFixed(2).replace('.', ',')} tỷ</span>
                  <span class="text-slate-400 text-sm">·</span>
                  <span class="text-[13px] font-bold text-[#064e3b]">${Math.round(apt.price / apt.area / 1000000)} tr/m²</span>
                </div>
                <span class="text-[10px] text-slate-400 font-medium">${timeAgo(apt.created_at || apt.createdAt)}</span>
              </div>
              <h3 class="text-[14px] font-bold text-slate-900 line-clamp-1 uppercase group-hover:text-[#064e3b] transition-colors">${escapeHTML(apt.name)}</h3>
              <p class="text-[13px] text-slate-500 line-clamp-2">${escapeHTML(apt.project_address || "Đang cập nhật")}</p>
            </div>
          </a>`;
      }).join('');
    } catch (e) { console.error("Lỗi nạp căn hộ tương tự:", e); }
  }

  // Tải dữ liệu phân tích khoảng giá thị trường bất đồng bộ
  async function loadMarketStats() {
    if (!apartmentId) return;
    try {
      const statsRes = await fetch(`${BACKEND_URL}/api/apartments/${apartmentId}/price-range-m2`);
      if (statsRes.ok) {
        const statsData = await statsRes.json();
        if (statsData.success) {
          const minMeter = parseFloat(statsData.minPricePerMeter);
          const maxMeter = parseFloat(statsData.maxPricePerMeter);
          const currentMeter = parseFloat(statsData.currentPricePerMeter);

          document.getElementById('text-header-khuvuc').textContent = statsData.khuVuc || "Dĩ An";
          document.getElementById('range-low-meter').textContent = String(Math.round(minMeter));
          document.getElementById('range-high-meter').textContent = String(Math.round(maxMeter));

          let finalPercent = 50;
          if (maxMeter > minMeter) {
            const baseRatio = (currentMeter - minMeter) / (maxMeter - minMeter);
            finalPercent = 15 + (baseRatio * 70);
            if (currentMeter < minMeter) finalPercent = Math.max(5, 15 - ((minMeter - currentMeter) / minMeter * 100));
            else if (currentMeter > maxMeter) finalPercent = Math.min(95, 85 + ((currentMeter - maxMeter) / maxMeter * 100));
          }
          if (document.getElementById('price-tooltip')) document.getElementById('price-tooltip').style.left = finalPercent.toFixed(2) + "%";

          const textStatusTitle = document.getElementById('text-price-status-title');
          if (textStatusTitle) {
            if (currentMeter < minMeter) {
              textStatusTitle.textContent = "Mức giá siêu hời, thấp hơn mặt bằng chung khu vực!";
              textStatusTitle.className = "text-sm font-bold text-emerald-600";
            } else if (currentMeter > maxMeter) {
              textStatusTitle.textContent = "Mức giá cao hơn trung bình (Do vị trí tầng hoặc nội thất cao cấp)";
              textStatusTitle.className = "text-sm font-bold text-orange-600";
            } else {
              textStatusTitle.textContent = "Mức giá rất tốt, nằm đúng trong khoảng phổ biến ổn định.";
              textStatusTitle.className = "text-sm font-bold text-slate-800";
            }
          }
          const notesContainer = document.getElementById('market-notes-container');
          if (notesContainer && statsData.marketNotes) {
            notesContainer.innerHTML = statsData.marketNotes.map(note => `<li class="flex items-start gap-2 leading-relaxed text-justify"><span class="text-orange-400 mt-0.5">•</span><span class="flex-1">${escapeHTML(note)}</span></li>`).join('');
          }
        }
      }
    } catch (errStats) { console.error("Lỗi đồng bộ khoảng giá stats:", errStats); }
  }

  // Khởi tạo các tương tác đổi ảnh Gallery
  const thumbItems = document.querySelectorAll('.thumb-gallery-item');
  thumbItems.forEach(item => {
    item.addEventListener('click', function() {
      const clickedUrl = this.getAttribute('data-url');
      const clickedIndex = parseInt(this.getAttribute('data-index')) + 1;
      document.getElementById('main-gallery-img').setAttribute('src', clickedUrl);
      document.getElementById('gallery-counter').textContent = `${clickedIndex} / ${thumbItems.length} Ảnh`;
      thumbItems.forEach(el => el.classList.replace('border-emerald-600', 'border-transparent'));
      this.classList.replace('border-transparent', 'border-emerald-600');
    });
  });

  // Toggle thu gọn/mở rộng mô tả
  const descText = document.getElementById('desc-text');
  const btnDescToggle = document.getElementById('btn-desc-toggle');
  if (descText) {
    const fullDesc = descText.textContent.trim();
    const words = fullDesc.split(/\s+/);
    if (words.length > 40) {
      const shortened = words.slice(0, 40).join(' ') + '... ';
      descText.textContent = shortened;
      if (btnDescToggle) {
        btnDescToggle.classList.remove('hidden');
        let isExpanded = false;
        btnDescToggle.addEventListener('click', () => {
          isExpanded = !isExpanded;
          descText.textContent = isExpanded ? (fullDesc + ' ') : shortened;
          btnDescToggle.textContent = isExpanded ? 'Rút gọn' : 'Xem thêm';
        });
      }
    }
  }

  // Toggle thu gọn/mở rộng bio môi giới
  const btnBioToggle = document.getElementById('btn-bio-toggle');
  const bioText = document.getElementById('bio-text');
  if (btnBioToggle && bioText) {
    const fullBio = btnBioToggle.getAttribute('data-full-bio');
    let isBioExpanded = false;
    btnBioToggle.addEventListener('click', () => {
      isBioExpanded = !isBioExpanded;
      bioText.textContent = isBioExpanded ? fullBio : fullBio.split(/\s+/).slice(0, 15).join(' ') + '... ';
      btnBioToggle.textContent = isBioExpanded ? 'Rút gọn' : 'Xem thêm';
    });
  }

  // Chạy các tác vụ Client phụ trợ không ảnh hưởng đến SEO text
  initMap('map', lat, lng, projectName);
  loadSimilarApartments();
  loadMarketStats();

  // Sự kiện Pop-up Form Leads
  const btnConsult = document.getElementById('btn-consult-trigger');
  if (btnConsult) {
    btnConsult.addEventListener('click', () => {
      const Swal = window.Swal;
      if (!Swal) return;
      const apartmentTitle = root.dataset.apartmentTitle;
      Swal.fire({
        title: '<span class="text-lg font-bold text-slate-800 uppercase tracking-tight">Đăng ký nhận tư vấn</span><br><span class="text-[10px] md:text-[12px]">* Cam kết tuyệt đối bảo mật thông tin khách hàng 100%.</span>',
        width: '600px', padding: '1rem',
        html: `
          <div class="space-y-4 text-left pt-2 font-sans">
            <div><label class="block text-xs font-bold text-slate-500 uppercase mb-1.5 tracking-wide">Căn hộ quan tâm</label><input type="text" class="w-full px-4 py-3 border border-slate-200 rounded-xl bg-slate-50 text-slate-500 font-bold text-sm focus:outline-none" value="${escapeHTML(apartmentTitle)}" disabled /></div>
            <div><label class="block text-xs font-bold text-slate-500 uppercase mb-1.5 tracking-wide">Họ và tên khách hàng <span class="text-red-500">*</span></label><input type="text" id="swal-cust-name" class="w-full px-4 py-3 border border-slate-200 rounded-xl text-slate-800 text-sm font-semibold focus:outline-none" placeholder="Ví dụ: Nguyễn Văn Tín" /></div>
            <div><label class="block text-xs font-bold text-slate-500 uppercase mb-1.5 tracking-wide">Số điện thoại liên hệ <span class="text-red-500">*</span></label><input type="tel" id="swal-cust-phone" class="w-full px-4 py-3 border border-slate-200 rounded-xl text-slate-800 text-sm font-semibold focus:outline-none" placeholder="Ví dụ: 0911502603" /></div>
            <div><label class="block text-xs font-bold text-slate-500 uppercase mb-1.5 tracking-wide">Ghi chú yêu cầu thêm</label><textarea id="swal-cust-note" rows="3" class="w-full px-4 py-3 border border-slate-200 rounded-xl text-slate-800 text-sm font-medium focus:outline-none" placeholder="Cần tư vấn giá, lịch xem nhà..."></textarea></div>
          </div>`,
        showCancelButton: true, confirmButtonText: 'Gửi yêu cầu ngay', cancelButtonText: 'Hủy bỏ', confirmButtonColor: '#006B5D', cancelButtonColor: '#94a3b8',
        preConfirm: () => {
          const name = document.getElementById('swal-cust-name').value.trim();
          const phone = document.getElementById('swal-cust-phone').value.trim();
          const note = document.getElementById('swal-cust-note').value.trim();
          if (!name) { Swal.showValidationMessage('Vui lòng nhập họ và tên.'); return false; }
          if (!phone || !/^(0|84)\d{9,10}$/.test(phone)) { Swal.showValidationMessage('Số điện thoại không hợp lệ.'); return false; }
          return { name, phone, project: projectName, source: apartmentTitle + (note ? " | Ghi chú: " + note : "") };
        }
      }).then(async (result) => {
        if (result.isConfirmed) {
          Swal.fire({ title: 'Đang gửi thông tin...', allowOutsideClick: false, didOpen: () => { Swal.showLoading(); } });
          try {
            const response = await fetch(`${BACKEND_URL}/api/leads`, {
              method: 'POST',
              headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
              body: JSON.stringify(result.value)
            });
            if (response.ok) Swal.fire({ icon: 'success', title: 'Đăng ký thành công!', text: 'Thông tin đã được ghi nhận vào danh sách Lead tư vấn.', confirmButtonColor: '#006B5D' });
            else throw new Error();
          } catch { Swal.fire({ icon: 'error', title: 'Thất bại', text: 'Không thể gửi yêu cầu tư vấn!', confirmButtonColor: '#006B5D' }); }
        }
      });
    });
  }
</script>

