---
// src/pages/dieu-khoan-dich-vu.astro
// Trang Điều khoản dịch vụ - Banner Vàng Bcons chữ Đen nằm giữa - Hệ thống bconstower.vn
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Điều Khoản Dịch Vụ | Bcons Tower">
  
  <!-- 🔥 HERO BANNER: NỀN VÀNG BCONS CHỮ ĐEN NẰM GIỮA -->
  <div class="w-full bg-[#fac72e] pt-32 pb-16 px-4 shadow-sm border-b border-[#fac72e]/20">
    <div class="max-w-[1440px] mx-auto px-4 md:px-12 text-center space-y-3.5 animate-fadeIn">
      <div class="flex items-center justify-center gap-3">
        <span class="w-6 h-[2px] bg-[#1E1E1E]/60"></span>
        <span class="text-[#1E1E1E] font-black tracking-[0.2em] uppercase text-[10px] md:text-xs">Quy định hệ thống</span>
        <span class="w-6 h-[2px] bg-[#1E1E1E]/60"></span>
      </div>
      <h1 class="text-3xl md:text-5xl font-black text-[#1E1E1E] tracking-tight leading-none uppercase drop-shadow-sm">
        Điều Khoản Dịch Vụ
      </h1>
      <p class="text-xs md:text-sm text-[#1E1E1E]/80 font-bold tracking-wide max-w-xl mx-auto">
        Cập nhật lần cuối: Tháng 06/2026 • Cổng thông tin giao dịch bconstower.vn
      </p>
    </div>
  </div>

  <!-- BỐ CỤC 2 CỘT NỘI DUNG SANG TRỌNG -->
  <div class="max-w-[1440px] mx-auto px-4 md:px-12 py-12 md:py-20">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-start">
      
      <!-- 📌 CỘT TRÁI: MỤC LỤC ĐIỀU HƯỚNG TỰ ĐỘNG GHIM CỨNG (STICKY SIDEBAR) -->
      <aside class="hidden lg:block lg:col-span-4 sticky top-28 bg-white p-6 rounded-2xl border border-slate-100 shadow-sm space-y-4">
        <p class="text-[11px] font-black uppercase text-slate-400 tracking-[0.15em] border-b border-slate-100 pb-3">Danh mục điều khoản</p>
        <nav class="flex flex-col space-y-1">
          <a href="#chap-thuan" class="toc-link px-3 py-2 rounded-lg text-sm font-bold text-slate-600 hover:bg-[#114232]/5 hover:text-[#114232] transition-all duration-200 flex items-center gap-2">
            <span class="text-[10px] font-mono text-slate-400">01.</span> Chấp thuận điều khoản
          </a>
          <a href="#trach-nhiem-user" class="toc-link px-3 py-2 rounded-lg text-sm font-bold text-slate-600 hover:bg-[#114232]/5 hover:text-[#114232] transition-all duration-200 flex items-center gap-2">
            <span class="text-[10px] font-mono text-slate-400">02.</span> Trách nhiệm người dùng
          </a>
          <a href="#thong-tin-du-an" class="toc-link px-3 py-2 rounded-lg text-sm font-bold text-slate-600 hover:bg-[#114232]/5 hover:text-[#114232] transition-all duration-200 flex items-center gap-2">
            <span class="text-[10px] font-mono text-slate-400">03.</span> Thông tin & Giá bán
          </a>
          <a href="#so-huu-tri-tue" class="toc-link px-3 py-2 rounded-lg text-sm font-bold text-slate-600 hover:bg-[#114232]/5 hover:text-[#114232] transition-all duration-200 flex items-center gap-2">
            <span class="text-[10px] font-mono text-slate-400">04.</span> Sở hữu trí tuệ
          </a>
          <a href="#gioi-han-trach-nhiem" class="toc-link px-3 py-2 rounded-lg text-sm font-bold text-slate-600 hover:bg-[#114232]/5 hover:text-[#114232] transition-all duration-200 flex items-center gap-2">
            <span class="text-[10px] font-mono text-slate-400">05.</span> Giới hạn trách nhiệm
          </a>
          <a href="#thay-doi-dieu-khoan" class="toc-link px-3 py-2 rounded-lg text-sm font-bold text-slate-600 hover:bg-[#114232]/5 hover:text-[#114232] transition-all duration-200 flex items-center gap-2">
            <span class="text-[10px] font-mono text-slate-400">06.</span> Thay đổi & Điều chỉnh
          </a>
          <a href="#giai-quyet-khieu-nai" class="toc-link px-3 py-2 rounded-lg text-sm font-bold text-slate-600 hover:bg-[#114232]/5 hover:text-[#114232] transition-all duration-200 flex items-center gap-2">
            <span class="text-[10px] font-mono text-slate-400">07.</span> Liên hệ & Khiếu nại
          </a>
        </nav>
      </aside>

      <!-- 📝 CỘT PHẢI: NỘI DUNG CHI TIẾT DẠNG THÈ -->
      <main class="col-span-1 lg:col-span-8 space-y-14 text-sm md:text-base leading-relaxed text-slate-600 font-medium">
        
        <p class="text-slate-500 italic border-l-2 border-[#fac72e] pl-4 text-sm md:text-base">
          Việc truy cập, tìm kiếm thông tin căn hộ hoặc để lại thông tin liên hệ trên website <strong>bconstower.vn</strong> đồng nghĩa với việc ông/bà đã đọc, hiểu và hoàn toàn đồng ý tuân thủ các điều khoản dịch vụ được quy định dưới đây.
        </p>

        <!-- Điều 1 -->
        <section id="chap-thuan" class="space-y-4 relative group scroll-mt-24">
          <div class="absolute -left-6 top-0 text-5xl md:text-6xl font-mono font-black text-slate-100 opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none select-none">01</div>
          <div class="flex items-center gap-3">
            <div class="w-1 md:w-1.5 h-6 bg-[#fac72e] rounded-sm"></div>
            <h2 class="text-lg md:text-xl font-black text-[#114232] uppercase tracking-tight">
              1. Chấp thuận điều khoản sử dụng
            </h2>
          </div>
          <p>
            Quy định này thiết lập mối quan hệ pháp lý giữa người dùng website và ban quản trị bconstower.vn. Nếu ông/bà không đồng ý với bất kỳ điều khoản nào trong văn bản này, vui lòng dừng việc sử dụng hoặc đăng ký nhận thông tin trên hệ thống.
          </p>
        </section>

        <!-- Điều 2 -->
        <section id="trach-nhiem-user" class="space-y-4 relative group scroll-mt-24">
          <div class="absolute -left-6 top-0 text-5xl md:text-6xl font-mono font-black text-slate-100 opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none select-none">02</div>
          <div class="flex items-center gap-3">
            <div class="w-1 md:w-1.5 h-6 bg-[#fac72e] rounded-sm"></div>
            <h2 class="text-lg md:text-xl font-black text-[#114232] uppercase tracking-tight">
              2. Quyền và trách nhiệm của người dùng
            </h2>
          </div>
          <p>Khi sử dụng các tính năng tương tác hoặc bộ lọc tìm kiếm nâng cao, người dùng cam kết:</p>
          <ul class="space-y-2.5 pl-2">
            <li class="flex items-start gap-2.5"><span class="text-[#fac72e] pt-0.5">✦</span> <span>Cung cấp thông tin họ tên, số điện thoại cá nhân chính xác tuyệt đối khi đăng ký nhận bảng giá rổ hàng sang nhượng.</span></li>
            <li class="flex items-start gap-2.5"><span class="text-[#fac72e] pt-0.5">✦</span> <span>Không sử dụng bất kỳ công cụ phần mềm hay robot mạng nào nhằm tấn công phá hoại cấu trúc hệ thống, đánh cắp lõi dữ liệu căn hộ.</span></li>
            <li class="flex items-start gap-2.5"><span class="text-[#fac72e] pt-0.5">✦</span> <span>Không mạo danh thương hiệu chủ đầu tư Bcons hoặc ban quản trị website để thực hiện các hành vi lừa đảo thông tin, gây thiệt hại tài chính cho khách hàng khác.</span></li>
          </ul>
        </section>

        <!-- Điều 3 -->
        <section id="thong-tin-du-an" class="space-y-4 relative group scroll-mt-24">
          <div class="absolute -left-6 top-0 text-5xl md:text-6xl font-mono font-black text-slate-100 opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none select-none">03</div>
          <div class="flex items-center gap-3">
            <div class="w-1 md:w-1.5 h-6 bg-[#fac72e] rounded-sm"></div>
            <h2 class="text-lg md:text-xl font-black text-[#114232] uppercase tracking-tight">
              3. Quy định về thông tin dự án & giá bán
            </h2>
          </div>
          <p>
            Mọi dữ liệu bao gồm hình ảnh phối cảnh, sơ đồ thiết kế mặt bằng, chính sách chiết khấu và giá bán căn hộ (Bcons City, Bcons Center City...) hiển thị trên website được tổng hợp từ nguồn thông tin rổ hàng ký gửi sang nhượng trực tiếp tại phòng kinh doanh. Dữ liệu giỏ hàng căn hộ liên tục biến động theo thời gian thực tế giao dịch trên thị trường, do đó thông tin mang tính chất tham khảo định hướng và không cấu thành một lời cam kết hợp đồng mua bán cố định pháp lý.
          </p>
        </section>

        <!-- Điều 4 -->
        <section id="so-huu-tri-tue" class="space-y-4 relative group scroll-mt-24">
          <div class="absolute -left-6 top-0 text-5xl md:text-6xl font-mono font-black text-slate-100 opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none select-none">04</div>
          <div class="flex items-center gap-3">
            <div class="w-1 md:w-1.5 h-6 bg-[#fac72e] rounded-sm"></div>
            <h2 class="text-lg md:text-xl font-black text-[#114232] uppercase tracking-tight">
              4. Quy định về sở hữu trí tuệ
            </h2>
          </div>
          <p>
            Toàn bộ nội dung văn bản, mã nguồn lập trình phần mềm, thiết kế giao diện UI/UX bộ lọc tìm kiếm, logo nhận diện thương hiệu hiển thị trên bconstower.vn đều thuộc quyền sở hữu trí tuệ hợp pháp của ban quản trị. Nghiêm cấm mọi hành vi sao chép, trích xuất dữ liệu thô hoặc phân phối lại nội dung khi chưa nhận được sự đồng ý bằng văn bản chính thức từ chúng tôi.
          </p>
        </section>

        <!-- Điều 5 -->
        <section id="gioi-han-trach-nhiem" class="space-y-4 relative group scroll-mt-24">
          <div class="absolute -left-6 top-0 text-5xl md:text-6xl font-mono font-black text-slate-100 opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none select-none">05</div>
          <div class="flex items-center gap-3">
            <div class="w-1 md:w-1.5 h-6 bg-[#fac72e] rounded-sm"></div>
            <h2 class="text-lg md:text-xl font-black text-[#114232] uppercase tracking-tight">
              5. Giới hạn trách nhiệm pháp lý
            </h2>
          </div>
          <p>
            Chúng tôi nỗ lực tối đa bảo vệ hoạt động thông suốt của website, tuy nhiên ban quản trị không chịu trách nhiệm đối với các sự cố gián đoạn đường truyền mạng nằm ngoài tầm kiểm soát hoặc các thiệt hại gián tiếp phát sinh từ việc người dùng tự ý chia sẻ dữ liệu liên lạc cá nhân lên không gian mạng mạng internet, dẫn đến các rủi ro không mong muốn.
          </p>
        </section>

        <!-- Điều 6 -->
        <section id="thay-doi-dieu-khoan" class="space-y-4 relative group scroll-mt-24">
          <div class="absolute -left-6 top-0 text-5xl md:text-6xl font-mono font-black text-slate-100 opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none select-none">06</div>
          <div class="flex items-center gap-3">
            <div class="w-1 md:w-1.5 h-6 bg-[#fac72e] rounded-sm"></div>
            <h2 class="text-lg md:text-xl font-black text-[#114232] uppercase tracking-tight">
              6. Thay đổi & Điều chỉnh quy định dịch vụ
            </h2>
          </div>
          <p>
            Ban quản trị bconstower.vn giữ toàn quyền sửa đổi, bổ sung hoặc cập nhật nội dung điều khoản dịch vụ này bất kỳ lúc nào để phù hợp với quy định pháp luật hiện hành và định hướng kinh doanh của tập đoàn. Phiên bản cập nhật mới nhất sẽ được ghim hiển thị công khai trên website kèm mốc thời gian cụ thể để người dùng theo dõi.
          </p>
        </section>

        <!-- Điều 7 -->
        <section id="giai-quyet-khieu-nai" class="space-y-4 relative group scroll-mt-24">
          <div class="absolute -left-6 top-0 text-5xl md:text-6xl font-mono font-black text-slate-100 opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none select-none">07</div>
          <div class="flex items-center gap-3">
            <div class="w-1 md:w-1.5 h-6 bg-[#fac72e] rounded-sm"></div>
            <h2 class="text-lg md:text-xl font-black text-[#114232] uppercase tracking-tight">
              7. Thông tin liên hệ & Giải quyết khiếu nại
            </h2>
          </div>
          <p>
            Mọi thắc mắc, phản ánh hoặc đóng góp ý kiến liên quan đến cơ chế hoạt động, điều khoản dịch vụ trên website, ông/bà vui lòng liên hệ trực tiếp với chúng tôi để nhận phản hồi nhanh chóng:
          </p>
          <div class="bg-gradient-to-br from-white to-slate-50/50 p-6 rounded-2xl border border-slate-100 space-y-2 shadow-sm relative overflow-hidden">
            <div class="absolute right-0 bottom-0 text-8xl font-black text-slate-100/40 translate-x-5 translate-y-5 select-none font-mono">T</div>
            <p class="font-black text-base text-[#114232] tracking-wide">PHÒNG KINH DOANH BẤT ĐỘNG SẢN BCONS</p>
            <p class="text-sm"><strong class="text-slate-500 font-bold">Hotline tiếp nhận xử lý:</strong> 0911 502 603</p>
            <p class="text-sm"><strong class="text-slate-500 font-bold">Email phản hồi:</strong> tin.bconsvietnam@gmail.com</p>
            <p class="text-sm"><strong class="text-slate-500 font-bold">Cổng thông tin:</strong> bconstower.vn</p>
          </div>
        </section>

      </main>
    </div>
  </div>
</MainLayout>

<script is:inline>
  // 🌟 HIỆU ỨNG LIÊN KẾT MỤC LỤC HOẠT ĐỘNG (ACTIVE SCROLL SPY)
  function initScrollSpy() {
    const links = document.querySelectorAll('.toc-link');
    const sections = document.querySelectorAll('main section');

    window.addEventListener('scroll', () => {
      let currentSectionId = '';
      sections.forEach(section => {
        const sectionTop = section.offsetTop;
        if (window.scrollY >= sectionTop - 120) {
          currentSectionId = section.getAttribute('id');
        }
      });

      links.forEach(link => {
        link.classList.remove('bg-[#114232]/5', 'text-[#114232]', 'pl-5');
        if (link.getAttribute('href') === `#${currentSectionId}`) {
          link.classList.add('bg-[#114232]/5', 'text-[#114232]', 'pl-5');
        }
      });
    });
  }

  initScrollSpy();
  document.addEventListener('DOMContentLoaded', initScrollSpy);
  document.addEventListener('astro:page-load', initScrollSpy);
</script>

<style>
  @import "tailwindcss";
  
  @keyframes fadeIn { 
    from { opacity: 0; transform: translateY(12px); } 
    to { opacity: 1; transform: translateY(0); } 
  }
  .animate-fadeIn { animation: fadeIn 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards; }
  
  html {
    scroll-behavior: smooth;
  }
  
  .toc-link {
    transition: all 0.25s cubic-bezier(0.16, 1, 0.3, 1);
  }
</style>