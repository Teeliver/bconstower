---
import AdminLayout from '../../../layouts/AdminLayout.astro';
---

<AdminLayout title="Chỉnh sửa cấu hình Banner">
  <div class="flex flex-col mb-8">
    <h1 class="text-2xl font-black text-slate-900">Cập nhật Banner Quảng Cáo</h1>
    <p class="text-slate-500">Chỉnh sửa tham số hoặc click đè trực tiếp lên ảnh trên Layout ảo để thay tệp mới</p>
  </div>

  <form id="editVisualBannerForm" class="grid grid-cols-1 lg:grid-cols-12 gap-8">
    <div class="lg:col-span-4 space-y-6 bg-white p-6 rounded-3xl border border-slate-100 shadow-sm h-fit">
      <div>
        <label class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Tên chiến dịch / Banner</label>
        <input type="text" id="bannerTitle" required class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl text-sm outline-none focus:border-orange-500 focus:bg-white transition-all text-slate-800 font-medium" />
      </div>

      <div>
        <label class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Đường dẫn khi click (URL Link)</label>
        <input type="url" id="linkUrl" class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl text-sm outline-none focus:border-orange-500 focus:bg-white transition-all text-slate-800 font-medium" />
      </div>

      <div class="grid grid-cols-2 gap-4">
        <div>
          <label class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Thứ tự nối tiếp</label>
          <input type="number" id="sortOrder" min="0" class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl text-sm outline-none focus:border-orange-500 focus:bg-white transition-all text-slate-800 font-medium" />
        </div>
        <div>
          <label class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Vị trí Ads</label>
          <select id="positionSelect" disabled class="w-full px-4 py-3 bg-slate-100 border border-slate-200 rounded-xl text-sm outline-none font-semibold text-slate-500 cursor-not-allowed">
            <option value="news_sidebar">Sidebar Tin Tức</option>
            <option value="apartment_sidebar">Sidebar Căn Hộ</option>
            <option value="project_horizontal">Banner Ngang Dự Án</option>
          </select>
        </div>
      </div>

      <input type="file" id="hiddenFileInput" accept="image/*" class="hidden" />

      <button type="submit" class="w-full bg-orange-600 hover:bg-orange-500 text-white font-bold py-3.5 rounded-xl transition-all shadow-lg shadow-orange-600/10 active:scale-[0.98] text-sm uppercase tracking-wider">
        Cập Nhật Banner
      </button>
    </div>

    <div class="lg:col-span-8 bg-slate-900 p-8 rounded-3xl border border-slate-800 shadow-2xl min-h-[460px] flex flex-col justify-between">
      <div class="flex items-center justify-between border-b border-slate-800 pb-4 mb-6">
        <div class="flex items-center gap-2">
          <span class="w-2.5 h-2.5 rounded-full bg-red-500 inline-block"></span>
          <span class="w-2.5 h-2.5 rounded-full bg-yellow-500 inline-block"></span>
          <span class="w-2.5 h-2.5 rounded-full bg-green-500 inline-block"></span>
          <span class="text-[11px] text-slate-500 font-mono ml-2">bconstower.vn/wireframe-canvas-edit</span>
        </div>
      </div>

      <div id="canvasBody" class="flex-1 flex flex-col justify-center">
        <div id="layout_news_sidebar" class="hidden-layout hidden w-full grid grid-cols-12 gap-4">
          <div class="col-span-8 bg-slate-800/40 rounded-2xl p-4 space-y-3 border border-slate-800">
            <div class="h-5 bg-slate-700/50 rounded-md w-2/3"></div><div class="h-20 bg-slate-700/20 rounded-xl w-full"></div>
          </div>
          <div class="col-span-4">
            <div class="banner-dropzone border-2 border-green-500 bg-green-500/5 rounded-2xl p-4 flex flex-col items-center justify-center text-center cursor-pointer transition-all aspect-[3/4] relative overflow-hidden h-full w-full group">
              <div class="dz-placeholder space-y-1 pointer-events-none opacity-0">
                <span class="text-lg">📸</span><div class="text-[11px] font-bold text-slate-200">THAY ẢNH MỚI</div>
              </div>
              <img class="dz-preview absolute inset-0 w-full h-full object-cover" />
            </div>
          </div>
        </div>

        <div id="layout_apartment_sidebar" class="hidden-layout hidden w-full grid grid-cols-12 gap-4">
          <div class="col-span-9 space-y-3">
            <div class="h-24 bg-slate-800/40 rounded-2xl border border-slate-800 p-4"></div>
          </div>
          <div class="col-span-3">
            <div class="banner-dropzone border-2 border-green-500 bg-green-500/5 rounded-2xl p-4 flex flex-col items-center justify-center text-center cursor-pointer transition-all h-[180px] relative overflow-hidden w-full group">
              <div class="dz-placeholder space-y-1 pointer-events-none opacity-0">
                <span class="text-lg">📸</span><div class="text-[10px] font-bold text-slate-200">THAY ẢNH MỚI</div>
              </div>
              <img class="dz-preview absolute inset-0 w-full h-full object-cover" />
            </div>
          </div>
        </div>

        <div id="layout_project_horizontal" class="hidden-layout hidden w-full space-y-4">
          <div class="h-10 bg-slate-800/40 rounded-xl border border-slate-800"></div>
          <div class="banner-dropzone border-2 border-green-500 bg-green-500/5 rounded-2xl p-4 flex flex-col items-center justify-center text-center cursor-pointer transition-all h-[90px] relative overflow-hidden w-full group">
            <div class="dz-placeholder flex items-center gap-3 pointer-events-none opacity-0">
              <span class="text-xl">📸</span><div class="text-[11px] font-bold text-slate-200">THAY ẢNH MỚI</div>
            </div>
            <img class="dz-preview absolute inset-0 w-full h-full object-cover" />
          </div>
        </div>
      </div>
    </div>
  </form>
</AdminLayout>

<script>
  import Swal from 'sweetalert2';

  const BACKEND_URL = import.meta.env.PUBLIC_API_BASE || 'http://127.0.0.1:8000';
  const token = localStorage.getItem('admin_token')?.replace(/['"]+/g, '').trim();

  const urlParams = new URLSearchParams(window.location.search);
  const id = urlParams.get('id');

  const selectPosition = document.getElementById('positionSelect') as HTMLSelectElement;
  const hiddenInput = document.getElementById('hiddenFileInput') as HTMLInputElement;
  const form = document.getElementById('editVisualBannerForm');

  // 1. GỌI API LẤY DATA CŨ ĐỂ ĐỔ VÀO FORM KHI TẢI TRANG
  async function fetchBannerDetails() {
    if (!id) {
      window.location.href = '/admin/banner';
      return;
    }

    try {
      // Vì Route Laravel dạng: /api/admin/banners/{id}
      const res = await fetch(`${BACKEND_URL}/api/admin/banners`, {
        method: 'GET',
        headers: { 'Authorization': `Bearer ${token}`, 'Accept': 'application/json' }
      });
      const json = await res.json();
      // Tìm đúng banner cần sửa trong mảng data trả về
      const banner = (json.data || []).find((b: any) => String(b.id) === String(id));

      if (!banner) throw new Error("Không tìm thấy banner");

      // Đổ data vào input
      (document.getElementById('bannerTitle') as HTMLInputElement).value = banner.title;
      (document.getElementById('linkUrl') as HTMLInputElement).value = banner.link_url || '';
      (document.getElementById('sortOrder') as HTMLInputElement).value = banner.sort_order;
      selectPosition.value = banner.position;

      // Kích hoạt hiển thị Layout tương ứng
      const currentLayout = document.getElementById(`layout_${banner.position}`);
      if (currentLayout) {
        currentLayout.classList.remove('hidden');
        const previewImg = currentLayout.querySelector('.dz-preview') as HTMLImageElement;
        
        // Đập link ảnh cũ từ server vào thẳng ô nét đứt
        const fullImgUrl = banner.image_path.startsWith('http') ? banner.image_path : `${BACKEND_URL}${banner.image_path}`;
        if (previewImg) {
          previewImg.src = fullImgUrl;
        }
      }

    } catch (e) {
      Swal.fire('Lỗi', 'Không thể tải chi tiết banner này.', 'error').then(() => {
        window.location.href = '/admin/banner';
      });
    }
  }

  // 2. Kích hoạt chọn ảnh thay thế
  document.querySelectorAll('.banner-dropzone').forEach(zone => {
    zone.addEventListener('click', () => hiddenInput?.click());
  });

  // 3. Xử lý preview ảnh mới thay thế
  hiddenInput?.addEventListener('change', (e) => {
    const input = e.target as HTMLInputElement;
    if (input.files && input.files[0]) {
      const reader = new FileReader();
      reader.onload = (event) => {
        const currentLayout = document.getElementById(`layout_${selectPosition.value}`);
        if (currentLayout && event.target?.result) {
          const previewImg = currentLayout.querySelector('.dz-preview') as HTMLImageElement;
          previewImg.src = event.target.result as string;
        }
      };
      reader.readAsDataURL(input.files[0]);
    }
  });

  // 4. SUBMIT UPDATE FORM SANG LARAVEL API
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    const formData = new FormData();
    formData.append('title', (document.getElementById('bannerTitle') as HTMLInputElement).value);
    formData.append('link_url', (document.getElementById('linkUrl') as HTMLInputElement).value);
    formData.append('sort_order', (document.getElementById('sortOrder') as HTMLInputElement).value);
    formData.append('position', selectPosition.value);
    
    // Gửi kèm cờ giả lập PUT method cho Laravel multipart hỗ trợ
    formData.append('_method', 'PUT');

    // Nếu chọn tệp ảnh mới thì đính kèm, không chọn thì Backend tự giữ ảnh cũ
    if (hiddenInput.files && hiddenInput.files[0]) {
      formData.append('image', hiddenInput.files[0]);
    }

    try {
      // Gửi POST kèm _method=PUT lên cổng tiếp nhận dữ liệu của Laravel
      const res = await fetch(`${BACKEND_URL}/api/admin/banners/${id}`, {
        method: 'POST',
        headers: { 'Authorization': `Bearer ${token}`, 'Accept': 'application/json' },
        body: formData
      });
      const data = await res.json();

      if (res.ok && data.success) {
        await Swal.fire('Cập nhật xong', 'Chiến dịch banner quảng cáo đã được làm mới.', 'success');
        window.location.href = '/admin/banner';
      } else {
        Swal.fire('Thất bại', data.message || 'Lỗi lưu thông tin.', 'error');
      }
    } catch (err) {
      Swal.fire('Lỗi', 'Gãy kết nối với server api.', 'error');
    }
  });

  document.addEventListener('DOMContentLoaded', fetchBannerDetails);
</script>