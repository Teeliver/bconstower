    const fileInput = itemEl.querySelector('.room-item-file-input') as HTMLInputElement;
    fileInput?.addEventListener('change', () => {
      if (fileInput.files && fileInput.files[0]) {
        const reader = new FileReader();
        reader.onload = (e) => {
          if (e.target?.result) {
            const base64Str = e.target.result as string;
            itemEl.setAttribute('data-base64', base64Str);
            
            const statusBadge = itemEl.querySelector('.room-image-status');
            if (statusBadge) {
              statusBadge.textContent = '🟢 Đã nạp ảnh mới';
              statusBadge.className = 'room-image-status text-[9px] px-1.5 py-1 rounded font-bold bg-green-50 text-green-600 border border-green-200';
            }

            const activeItem = document.querySelector('.furniture-room-item.border-orange-500');
            const previewImg = document.getElementById('furnitureRoomPreviewImg') as HTMLImageElement;
            if (activeItem === itemEl && previewImg) {
              previewImg.src = base64Str;
              previewImg.classList.remove('hidden');
            }
          }
        };
        reader.readAsDataURL(fileInput.files[0]);
      }
    });
