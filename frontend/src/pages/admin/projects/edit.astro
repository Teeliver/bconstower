<script>
  import Swal from 'sweetalert2';

  const BACKEND_URL = import.meta.env.PUBLIC_API_BASE || 'http://localhost:8000';
  const token = localStorage.getItem('admin_token')?.replace(/['"]+/g, '').trim();
  
  const urlParams = new URLSearchParams(window.location.search);
  const projectId = urlParams.get('id');

  let serverOriginalData: any = null;

  const titleInput = document.getElementById('projectTitle') as HTMLInputElement;
  const slugInput = document.getElementById('projectSlug') as HTMLInputElement;

  function convertToSlug(text: string): string {
    let slug = text.toLowerCase();
    slug = slug.replace(/à|á|ạ|ả|ã|â|ầ|ấ|ậ|ẩ|ẫ|ă|ằ|ắ|ặ|ẳ|ẵ/g, "a");
    slug = slug.replace(/è|é|ẹ|ẻ|ẽ|ê|ề|ế|ệ|ể|ễ/g, "e");
    slug = slug.replace(/ì|í|ị|ỉ|ĩ/g, "i");
    slug = slug.replace(/ò|ó|ọ|ỏ|õ|ô|ồ|ố|ộ|ổ|ỗ|ơ|ờ|ớ|ợ|ở|ỡ/g, "o");
    slug = slug.replace(/ù|ú|ụ|ủ|ũ|ư|ừ|ứ|ự|ử|ữ/g, "u");
    slug = slug.replace(/ỳ|ý|ỵ|ỷ|ỹ/g, "y");
    slug = slug.replace(/đ/g, "d");
    slug = slug.replace(/[^a-z0-9 -]/g, ""); 
    slug = slug.replace(/\s+/g, "-"); 
    slug = slug.replace(/-+/g, "-"); 
    return slug.trim();
  }

  titleInput?.addEventListener('input', () => {
    if (titleInput && slugInput) {
      slugInput.value = convertToSlug(titleInput.value);
    }
  });

  function setupCustomDropdown(containerId: string) {
    const container = document.getElementById(containerId);
    if (!container) return;

    const btn = container.querySelector('.drop-btn') as HTMLButtonElement;
    const input = container.querySelector('input[type="hidden"]') as HTMLInputElement;
    const options = container.querySelectorAll('.option-item');
    const selectedText = container.querySelector('.selected-text');

    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      document.querySelectorAll('.dropdown-container').forEach(el => {
        if (el !== container) el.classList.remove('active');
      });
      container.classList.toggle('active');
    });

    options.forEach(opt => {
      opt.addEventListener('click', () => {
        const val = opt.getAttribute('data-value');
        const content = opt.innerHTML;
        if (val && input) input.value = val;
        if (selectedText) selectedText.innerHTML = content;
        container.classList.remove('active');
      });
    });
  }
  

  setupCustomDropdown('dropdown-status');
  setupCustomDropdown('dropdown-legal');

  window.addEventListener('click', () => {
    document.querySelectorAll('.dropdown-container').forEach(el => el.classList.remove('active'));
  });

  document.querySelectorAll('.section-header').forEach((header) => {
    header.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      if (target.closest('label') || target.closest('input') || target.closest('button:not(.collapse-toggle-btn)')) {
        return;
      }

      const card = header.closest('.section-card');
      if (!card) return;

      const content = card.querySelector('.section-content');
      const chevron = header.querySelector('.chevron-icon');

      if (content) {
        content.classList.toggle('hidden');
        if (chevron) {
          chevron.classList.toggle('rotate-180');
        }
      }
    });
  });

  const restoreContainerDirection = (containerId: string, badgeId: string, direction: string) => {
    const parentFlex = document.getElementById(containerId);
    const badgeEl = document.getElementById(badgeId);
    if (!parentFlex) return;

    if (direction === 'reverse') {
      parentFlex.classList.add('lg:flex-row-reverse');
      parentFlex.setAttribute('data-direction', 'reverse');
      if (badgeEl) {
        badgeEl.textContent = "Bố cục: Đảo chiều";
        badgeEl.className = "direction-badge text-[10px] font-bold text-orange-600 bg-orange-50 px-2.5 py-1 rounded-md uppercase font-mono border border-orange-200";
      }
    } else {
      parentFlex.classList.remove('lg:flex-row-reverse');
      parentFlex.setAttribute('data-direction', 'normal');
      if (badgeEl) {
        badgeEl.textContent = "Bố cục: Mặc định";
        badgeEl.className = "direction-badge text-[10px] font-bold text-slate-400 bg-slate-100 px-2.5 py-1 rounded-md uppercase font-mono";
      }
    }
  };

  function getFullImageUrl(path: string | null | undefined): string {
    if (!path) return '';
    if (path.startsWith('http://') || path.startsWith('https://') || path.startsWith('data:')) return path;
    const cleanBase = BACKEND_URL.endsWith('/') ? BACKEND_URL.slice(0, -1) : BACKEND_URL;
    return cleanBase + (path.startsWith('/') ? path : '/' + path);
  }

  const initVisualDropzone = (zoneId: string, inputId: string, previewId: string) => {
    const zone = document.getElementById(zoneId);
    const input = document.getElementById(inputId) as HTMLInputElement;
    const img = document.getElementById(previewId) as HTMLImageElement;

    zone?.addEventListener('click', () => input.click());
    input?.addEventListener('change', () => {
      if (input.files && input.files[0]) {
        const reader = new FileReader();
        reader.onload = (e) => {
          if (img && e.target?.result) {
            img.src = e.target.result as string;
            img.classList.remove('hidden');
          }
        };
        reader.readAsDataURL(input.files[0]);
      }
    });
  };

  initVisualDropzone('heroDropzone', 'heroFileInput', 'heroPreviewImg');
  initVisualDropzone('overviewDropzone', 'overviewFileInput', 'overviewPreviewImg');
  initVisualDropzone('locationDropzone', 'locationFileInput', 'locationPreviewImg');
  initVisualDropzone('planDropzone', 'planFileInput', 'planPreviewImg');

  const projInput = document.getElementById('projectFileInput') as HTMLInputElement;
  const projImg = document.getElementById('projectPreviewImg') as HTMLImageElement;
  const projPlaceholder = document.getElementById('projectPreviewPlaceholder');
  projInput?.addEventListener('change', () => {
    if (projInput.files && projInput.files[0]) {
      const reader = new FileReader();
      reader.onload = (e) => {
        if (projImg && e.target?.result) {
          projImg.src = e.target.result as string;
          projImg.classList.remove('hidden');
          if (projPlaceholder) projPlaceholder.classList.add('hidden');
        }
      };
      reader.readAsDataURL(projInput.files[0]);
    }
  });

  document.querySelectorAll('.amenity-node').forEach(node => {
    const dropzone = node.querySelector('.amenity-dropzone') as HTMLDivElement;
    const fileInput = node.querySelector('.amenity-file-input') as HTMLInputElement;
    const previewImg = node.querySelector('.amenity-preview') as HTMLImageElement;

    dropzone?.addEventListener('click', () => fileInput.click());
    fileInput?.addEventListener('change', () => {
      if (fileInput.files && fileInput.files[0]) {
        const reader = new FileReader();
        reader.onload = (e) => {
          if (previewImg && e.target?.result) {
            previewImg.src = e.target.result as string;
            previewImg.classList.remove('hidden');
          }
        };
        reader.readAsDataURL(fileInput.files[0]);
      }
    });
  });

  function setActiveUnit(itemEl: HTMLElement) {
    document.querySelectorAll('.unit-repeater-item').forEach(el => {
      el.classList.remove('border-orange-500', 'bg-orange-50/40', 'ring-2', 'ring-orange-500/10');
      el.classList.add('bg-white', 'border-slate-200');
    });

    itemEl.classList.remove('bg-white', 'border-slate-200');
    itemEl.classList.add('border-orange-500', 'bg-orange-50/40', 'ring-2', 'ring-orange-500/10');

    const previewImg = document.getElementById('unitPreviewImg') as HTMLImageElement;
    const labelEl = document.getElementById('unitDropzoneLabel');

    if (labelEl) {
      const nameInp = itemEl.querySelector('.unit-name-input') as HTMLInputElement;
      labelEl.textContent = `ẢNH LAYOUT: ${nameInp?.value.trim() || 'CHƯA ĐẶT TÊN'}`;
    }

    const localBase64 = itemEl.getAttribute('data-base64');
    const existingUrl = itemEl.getAttribute('data-image-url');

    if (localBase64 && previewImg) {
      previewImg.src = localBase64;
      previewImg.classList.remove('hidden');
    } else if (existingUrl && previewImg) {
      previewImg.src = getFullImageUrl(existingUrl);
      previewImg.classList.remove('hidden');
    } else if (previewImg) {
      previewImg.classList.add('hidden');
      previewImg.src = '';
    }
  }

  function bindUnitItemEvents(itemEl: HTMLElement) {
    itemEl.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      if (target.classList.contains('delete-unit-btn')) return;
      setActiveUnit(itemEl);
    });

    const nameInp = itemEl.querySelector('.unit-name-input') as HTMLInputElement;
    nameInp?.addEventListener('input', () => {
      const activeItem = document.querySelector('.unit-repeater-item.border-orange-500');
      const labelEl = document.getElementById('unitDropzoneLabel');
      if (activeItem === itemEl && labelEl) {
        labelEl.textContent = `ẢNH LAYOUT: ${nameInp.value.trim() || 'CHƯA ĐẶT TÊN'}`;
      }
    });

    const fileInput = itemEl.querySelector('.unit-item-file-input') as HTMLInputElement;
    fileInput?.addEventListener('change', () => {
      if (fileInput.files && fileInput.files[0]) {
        const reader = new FileReader();
        reader.onload = (e) => {
          if (e.target?.result) {
            const base64Str = e.target.result as string;
            itemEl.setAttribute('data-base64', base64Str);
            
            const statusBadge = itemEl.querySelector('.unit-image-status');
            if (statusBadge) {
              statusBadge.textContent = '🟢 Đã nạp ảnh mới';
              statusBadge.className = 'unit-image-status text-[9px] px-1.5 py-1 rounded font-bold bg-green-50 text-green-600 border border-green-200';
            }

            const activeItem = document.querySelector('.unit-repeater-item.border-orange-500');
            const previewImg = document.getElementById('unitPreviewImg') as HTMLImageElement;
            if (activeItem === itemEl && previewImg) {
              previewImg.src = base64Str;
              previewImg.classList.remove('hidden');
            }
          }
        };
        reader.readAsDataURL(fileInput.files[0]);
      }
    });
  }

  document.getElementById('unitDropzone')?.addEventListener('click', () => {
    const activeItem = document.querySelector('.unit-repeater-item.border-orange-500');
    if (!activeItem) {
      Swal.fire('Thông báo', 'Vui lòng chọn một mẫu thiết kế căn hộ ở cột bên trái trước khi nạp ảnh!', 'info');
      return;
    }
    (activeItem.querySelector('.unit-item-file-input') as HTMLInputElement)?.click();
  });

  function recalculateUnitLabels() {
    document.querySelectorAll('.unit-repeater-item').forEach((item, idx) => {
      const label = item.querySelector('.unit-title-label');
      if (label) label.textContent = `Mẫu thiết kế #${idx + 1}`;
