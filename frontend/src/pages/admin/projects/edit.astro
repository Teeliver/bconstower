  function recalculateRoomLabels() {
    document.querySelectorAll('.furniture-room-item').forEach((item, idx) => {
      const label = item.querySelector('.room-title-label');
      if (label) label.textContent = `Không gian / Phòng #${idx + 1}`;
    });
  }

