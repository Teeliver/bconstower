  function recalculateCanvasIndices() {
    const canvas = document.getElementById('activeCanvas');
    const pool = document.getElementById('widgetPool');
    if (!canvas || !pool) return;

    const activeSections = canvas.querySelectorAll('.section-card');
    const activeIds = new Set<string>();

    activeSections.forEach((card, idx) => {
      const sId = card.getAttribute('data-section-id');
      if (sId) activeIds.add(sId);
      
      const indexBadge = card.querySelector('.canvas-index-badge');
      if (indexBadge) indexBadge.textContent = `#${idx + 1}`;
    });

    pool.querySelectorAll('[data-widget-id]').forEach(widgetNode => {
      const wId = widgetNode.getAttribute('data-widget-id');
      const btn = widgetNode.querySelector('.activate-widget-btn');
      if (!wId || !btn) return;

      if (activeIds.has(wId)) {
        widgetNode.classList.add('border-green-500', 'bg-slate-800/40');
        widgetNode.classList.remove('border-slate-700');
        btn.textContent = 'Đang hiện';
        btn.className = 'activate-widget-btn text-[10px] bg-green-600 px-2 py-1 rounded-lg text-white font-bold cursor-default';
      } else {
        widgetNode.classList.remove('border-green-500', 'bg-slate-800/40');
        widgetNode.classList.add('border-slate-700');
        btn.textContent = 'Bật';
        btn.className = 'activate-widget-btn text-[10px] bg-slate-700 group-hover:bg-orange-600 px-2.5 py-1 rounded-lg text-white font-bold transition-all';
      }
    });
  }
  

  function initWidgetLayoutBuilder() {
    const pool = document.getElementById('widgetPool');
    const canvas = document.getElementById('activeCanvas');
    const storage = document.getElementById('hiddenWidgetStorage');
    if (!pool || !canvas || !storage) return;

    pool.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      const widgetItem = target.closest('[data-widget-id]');
      if (!widgetItem) return;

      const sId = widgetItem.getAttribute('data-widget-id');
      if (!sId) return;

      const alreadyInCanvas = canvas.querySelector(`[data-section-id="${sId}"]`);
      if (!alreadyInCanvas) {
        const sectionCard = storage.querySelector(`[data-section-id="${sId}"]`);
        if (sectionCard) {
          canvas.appendChild(sectionCard);
          recalculateCanvasIndices(); 
          sectionCard.scrollIntoView({ behavior: 'smooth', block: 'center' });
        }
      }
    });

    canvas.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      if (target.classList.contains('remove-widget-btn')) {
        const card = target.closest('.section-card');
        if (card) {
          storage.appendChild(card);
          recalculateCanvasIndices(); 
        }
      }
    });

    let draggedCard: HTMLElement | null = null;

    canvas.addEventListener('dragstart', (e) => {
      const target = e.target as HTMLElement;
      const card = target.closest('.section-card') as HTMLElement;
      if (card && target.closest('.canvas-drag-handle')) {
        draggedCard = card;
        card.classList.add('opacity-40', 'border-orange-500', 'scale-[0.99]');
      }
    });

    canvas.addEventListener('dragend', () => {
      if (draggedCard) {
        draggedCard.classList.remove('opacity-40', 'border-orange-500', 'scale-[0.99]');
        draggedCard = null;
      }
      recalculateCanvasIndices(); 
    });

    canvas.addEventListener('dragover', (e) => {
      e.preventDefault();
      if (!draggedCard) return;

      const target = e.target as HTMLElement;
      const overCard = target.closest('.section-card') as HTMLElement;

      if (overCard && overCard !== draggedCard && overCard.parentElement === canvas) {
        const bounding = overCard.getBoundingClientRect();
        const offset = e.clientY - bounding.top;
        if (offset > bounding.height / 2) {
          canvas.insertBefore(draggedCard, overCard.nextSibling);
        } else {
          canvas.insertBefore(draggedCard, overCard);
        }
      }
    });
  }

  async function loadProjectLandingData() {
    if (!projectId || projectId === 'null' || projectId === 'undefined') {
      window.location.replace('/admin/projects');
      return;
    }

    try {
      const res = await fetch(`${BACKEND_URL}/api/admin/projects/${projectId}`, {
        method: 'GET',
        headers: { 'Authorization': `Bearer ${token}`, 'Accept': 'application/json' }
      });

      if (res.status === 401) {
          localStorage.clear();
          document.cookie = "auth_token=; path=/; expires=Thu, 01 Jan 1970 00:00:00 UTC;";
          window.location.href = '/admin/login';
      } 

      else if (res.status === 403) {
          window.location.href = '/403'; 
      }

      if (!res.ok) throw new Error("Không thể liên kết bóc tách dữ liệu.");
      const serverData = await res.json();
      
      const setInput = (id: string, value: any) => {
        const el = document.getElementById(id) as HTMLInputElement;
        if (el) el.value = value || '';
      };

      setInput('projectTitle', serverData.title);
      setInput('projectSlug', serverData.slug);
      setInput('projectLat', serverData.lat);
      setInput('projectLng', serverData.lng);
      setInput('projectAddress', serverData.address);

      const statusInput = document.getElementById('status') as HTMLInputElement;
      if (statusInput) {
        statusInput.value = serverData.status || 'dang_xay_dung';
        const statusText = document.querySelector(`#dropdown-status [data-value="${statusInput.value}"]`)?.innerHTML;
        if (statusText) document.querySelector('#dropdown-status .selected-text')!.innerHTML = statusText;
      }

      const legalInput = document.getElementById('legal') as HTMLInputElement;
      if (legalInput) {
        legalInput.value = serverData.legal || 'hdmb';
        const legalText = document.querySelector(`#dropdown-legal [data-value="${legalInput.value}"]`)?.innerHTML;
        if (legalText) document.querySelector('#dropdown-legal .selected-text')!.innerHTML = legalText;
      }

      if (serverData.image && projImg) {
        projImg.src = getFullImageUrl(serverData.image);
        projImg.classList.remove('hidden');
        if (projPlaceholder) projPlaceholder.classList.add('hidden');
      }

      const data = typeof serverData.landing_data === 'string' ? JSON.parse(serverData.landing_data) : serverData.landing_data;
      if (!data) return;
      
      serverOriginalData = data;

      const setImg = (previewId: string, url: string) => {
        const img = document.getElementById(previewId) as HTMLImageElement;
        if (img && url) {
          img.src = getFullImageUrl(url);
          img.classList.remove('hidden');
        }
      };

      const canvas = document.getElementById('activeCanvas');
      const storage = document.getElementById('hiddenWidgetStorage');
      const visibility = data.visibility || {};

      if (data.layout_order && Array.isArray(data.layout_order)) {
        data.layout_order.forEach((sId: string) => {
          const card = storage?.querySelector(`[data-section-id="${sId}"]`);
          if (card && canvas) canvas.appendChild(card);
        });
      } else {
        const defaultOrder = ['hero', 'highlights', 'stats', 'promo', 'overview', 'location_links', 'floorplan', 'amenities', 'unit_designs', 'furniture', 'payment_methods', 'apartments', 'lead_form'];
        defaultOrder.forEach((sId) => {
          const legacyKey = sId === 'location_links' ? 'location_links' : (sId === 'floorplan' ? 'floorplan' : sId);
          if (visibility[legacyKey] === true || visibility[legacyKey] === undefined) {
            const card = storage?.querySelector(`[data-section-id="${sId}"]`);
            if (card && canvas) canvas.appendChild(card);
          }
        });
      }
      
      recalculateCanvasIndices();

      // 1. Hero
      setInput('heroTitle', data.hero?.title);
      setInput('heroSubtitle', data.hero?.subtitle);
      setInput('heroDescription', data.hero?.description); 
      setInput('heroBtnText', data.hero?.btn_text);
      setImg('heroPreviewImg', data.hero?.bg_url);
      restoreContainerDirection('container_hero', 'badge_hero', data.hero?.direction);

      // 2. Highlights
      if (data.highlights) {
        if (data.highlights.trust_points && Array.isArray(data.highlights.trust_points)) {
          data.highlights.trust_points.forEach((tp: any, index: number) => {
            const i = index + 1;
            setInput(`trustTitle${i}`, tp.title);
            setInput(`trustDesc${i}`, tp.desc);
            setInput(`trustIcon${i}`, tp.icon);
          });
        }
        if (data.highlights.partners && Array.isArray(data.highlights.partners)) {
