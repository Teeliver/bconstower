  const escapeHTML = (str: string): string => {
    if (!str) return '';
    return str.replace(/[&<>"']/g, (match) => {
      const map: Record<string, string> = { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' };
      return map[match] || match;
    });
  };

  const form = document.getElementById('projectLandingForm');
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    Swal.fire({ title: 'Đang xử lý cập nhật...', text: 'Vui lòng chờ trong giây lát', allowOutsideClick: false, didOpen: () => { Swal.showLoading(); } });

    const layoutOrderArr: string[] = [];
    const canvas = document.getElementById('activeCanvas');
    if (canvas) {
      canvas.querySelectorAll('.section-card').forEach(card => {
        const sId = card.getAttribute('data-section-id');
        if (sId) layoutOrderArr.push(sId);
      });
    }

    const isSectionActive = (id: string) => layoutOrderArr.includes(id);

    const listAmenitiesText: Array<{title: string, index: number, image_url: string}> = [];
    document.querySelectorAll('.amenity-node').forEach(node => {
      const input = node.querySelector('.amenity-title-input') as HTMLInputElement;
      const zone = node.querySelector('.amenity-dropzone') as HTMLDivElement;
      const indexStr = zone.getAttribute('data-index');
      const idx = Number(indexStr);

      let oldUrl = '';
      if (serverOriginalData && serverOriginalData.amenities) {
        const matched = serverOriginalData.amenities.find((a: any) => a.index === idx);
        if (matched) oldUrl = matched.image_url || '';
      }
      listAmenitiesText.push({ title: input.value || `Tiện ích ${indexStr}`, index: idx, image_url: oldUrl });
    });

    const planPointsArr: Array<{block: string, title: string, desc: string}> = [];
    document.querySelectorAll('.plan-point-item').forEach(item => {
      const blockInp = item.querySelector('.plan-point-block-input') as HTMLInputElement;
      const titleInp = item.querySelector('.plan-point-title-input') as HTMLInputElement;
      const descInp = item.querySelector('.plan-point-desc-input') as HTMLInputElement;
      if (titleInp && titleInp.value.trim()) {
        planPointsArr.push({
          block: blockInp ? blockInp.value.trim() : '',
          title: titleInp.value.trim(),
          desc: descInp ? descInp.value.trim() : ''
        });
      }
    });

    const formData = new FormData();

    const unitDesignArr: Array<{name: string, area: string, specs: string, desc: string, image_url: string}> = [];
    document.querySelectorAll('.unit-repeater-item').forEach((item, idx) => {
      const nameEl = item.querySelector('.unit-name-input') as HTMLInputElement;
      const areaEl = item.querySelector('.unit-area-input') as HTMLInputElement;
      const specsEl = item.querySelector('.unit-specs-input') as HTMLInputElement;
      const descEl = item.querySelector('.unit-desc-input') as HTMLInputElement;
      
      let targetImgSource = item.getAttribute('data-base64') || item.getAttribute('data-image-url') || '';
      if (nameEl && nameEl.value.trim()) {
        unitDesignArr.push({
          name: nameEl.value.trim(),
          area: areaEl.value.trim(),
          specs: specsEl.value.trim(),
          desc: descEl.value.trim(),
          image_url: targetImgSource
        });
        
        const fileInput = item.querySelector('.unit-item-file-input') as HTMLInputElement;
        if (fileInput && fileInput.files && fileInput.files[0]) {
          formData.append(`unit_layout_files[${idx}]`, fileInput.files[0]);
        }
      }
    });

    const furnitureRoomsArr: Array<{name: string, image_url: string, items: Array<{title: string, description: string}>}> = [];
    document.querySelectorAll('.furniture-room-item').forEach((roomItem, rIdx) => {
      const roomNameEl = roomItem.querySelector('.room-name-input') as HTMLInputElement;
      let targetRoomImgSource = roomItem.getAttribute('data-base64') || roomItem.getAttribute('data-image-url') || '';
      
      const innerMaterialsArr: Array<{title: string, description: string}> = [];
      roomItem.querySelectorAll('.room-material-row').forEach(row => {
        const titleEl = row.querySelector('.mat-title-input') as HTMLInputElement;
        const descEl = row.querySelector('.mat-desc-input') as HTMLInputElement;
        if (titleEl && titleEl.value.trim()) {
          innerMaterialsArr.push({
            title: titleEl.value.trim(),
            description: descEl ? descEl.value.trim() : ''
          });
        }
      });

      if (roomNameEl && roomNameEl.value.trim()) {
        furnitureRoomsArr.push({
          name: roomNameEl.value.trim(),
          image_url: targetRoomImgSource,
          items: innerMaterialsArr
        });

        const fileInput = roomItem.querySelector('.room-item-file-input') as HTMLInputElement;
        if (fileInput && fileInput.files && fileInput.files[0]) {
          formData.append(`furniture_room_files[${rIdx}]`, fileInput.files[0]);
        }
      }
    });

    const paymentMethodsArr: Array<{name: string, discount: string, description: string, key_index: number, file_url: string}> = [];
    document.querySelectorAll('.payment-repeater-item').forEach((item, idx) => {
      const name = (item.querySelector('.payment-name-input') as HTMLInputElement).value.trim();
      const discount = (item.querySelector('.payment-discount-input') as HTMLInputElement).value.trim();
      const description = (item.querySelector('.payment-desc-input') as HTMLTextAreaElement).value.trim();
      const currentIdx = idx + 1;
      
      let oldUrl = item.getAttribute('data-file-url') || '';
      if (!oldUrl && serverOriginalData && serverOriginalData.payment_methods) {
        const pList = Array.isArray(serverOriginalData.payment_methods) ? serverOriginalData.payment_methods : (serverOriginalData.payment_methods.items || []);
        if (pList[idx]) oldUrl = pList[idx].file_url || '';
      }

      if (name) {
        paymentMethodsArr.push({ name, discount, description, key_index: currentIdx, file_url: oldUrl });
        const fileInput = item.querySelector('.payment-file-input') as HTMLInputElement;
        if (fileInput && fileInput.files && fileInput.files[0]) {
          formData.append(`payment_document_files[${idx}]`, fileInput.files[0]);
        }
      }
    });

    const locationLinksArr: Array<{name: string, time: string}> = [];
    document.querySelectorAll('.location-link-item').forEach(item => {
      const nameInp = item.querySelector('.location-item-input') as HTMLInputElement;
      const timeInp = item.querySelector('.location-time-input') as HTMLInputElement;
      if (nameInp && nameInp.value.trim()) {
        locationLinksArr.push({
          name: nameInp.value.trim(),
          time: timeInp ? timeInp.value.trim() : ''
        });
      }
    });

    const getDir = (id: string) => document.getElementById(id)?.getAttribute('data-direction') || 'normal';

    const flatTitle = (document.getElementById('projectTitle') as HTMLInputElement).value.trim();
    const flatLat = (document.getElementById('projectLat') as HTMLInputElement).value.trim();
    const flatLng = (document.getElementById('projectLng') as HTMLInputElement).value.trim();
    const flatSlug = (document.getElementById('projectSlug') as HTMLInputElement).value.trim();
    const flatAddress = (document.getElementById('projectAddress') as HTMLInputElement).value.trim();
    const flatStatus = (document.getElementById('status') as HTMLInputElement).value;
    const flatLegal = (document.getElementById('legal') as HTMLInputElement).value;

    const visibilityJson = {
      hero: isSectionActive('hero'),
      highlights: isSectionActive('highlights'),
      stats: isSectionActive('stats'),
      promo: isSectionActive('promo'),
      overview: isSectionActive('overview'),
      location_links: isSectionActive('location_links'),
      floorplan: isSectionActive('floorplan'),
      amenities: isSectionActive('amenities'),
      unit_designs: isSectionActive('unit_designs'),
      furniture: isSectionActive('furniture'),
      payment_methods: isSectionActive('payment_methods'),
      apartments: isSectionActive('apartments'),
      lead_form: isSectionActive('lead_form')
    };

    const structuralTextJson = {
      layout_order: layoutOrderArr, 
      visibility: visibilityJson,
      hero: {
        direction: getDir('container_hero'),
        title: (document.getElementById('heroTitle') as HTMLInputElement).value || flatTitle,
        subtitle: (document.getElementById('heroSubtitle') as HTMLInputElement).value,
        description: (document.getElementById('heroDescription') as HTMLTextAreaElement).value, 
        btn_text: (document.getElementById('heroBtnText') as HTMLInputElement).value,
        bg_url: serverOriginalData?.hero?.bg_url || ''
      },
      highlights: {
        trust_points: [
          {
            title: (document.getElementById('trustTitle1') as HTMLInputElement).value,
            desc: (document.getElementById('trustDesc1') as HTMLTextAreaElement).value,
            icon: (document.getElementById('trustIcon1') as HTMLInputElement).value
          },
          {
            title: (document.getElementById('trustTitle2') as HTMLInputElement).value,
            desc: (document.getElementById('trustDesc2') as HTMLTextAreaElement).value,
            icon: (document.getElementById('trustIcon2') as HTMLInputElement).value
          },
          {
            title: (document.getElementById('trustTitle3') as HTMLInputElement).value,
            desc: (document.getElementById('trustDesc3') as HTMLTextAreaElement).value,
            icon: (document.getElementById('trustIcon3') as HTMLInputElement).value
          }
        ],
        partners: [
          (document.getElementById('partner1') as HTMLInputElement).value,
          (document.getElementById('partner2') as HTMLInputElement).value,
          (document.getElementById('partner3') as HTMLInputElement).value,
          (document.getElementById('partner4') as HTMLInputElement).value,
          (document.getElementById('partner5') as HTMLInputElement).value,
          (document.getElementById('partner6') as HTMLInputElement).value,
          (document.getElementById('partner7') as HTMLInputElement).value
        ]
      },
      stats: {
        items: [
          (document.getElementById('statNumber1') as HTMLInputElement).value,
          (document.getElementById('statNumber2') as HTMLInputElement).value,
          (document.getElementById('statNumber3') as HTMLInputElement).value,
          (document.getElementById('statNumber4') as HTMLInputElement).value
        ],
        descriptions: [
          (document.getElementById('statDesc1') as HTMLInputElement).value,
          (document.getElementById('statDesc2') as HTMLInputElement).value,
          (document.getElementById('statDesc3') as HTMLInputElement).value,
          (document.getElementById('statDesc4') as HTMLInputElement).value
        ]
      },
      promo: {
        title: (document.getElementById('promoTitle') as HTMLInputElement).value,
        description: (document.getElementById('promoDesc') as HTMLTextAreaElement).value
      },
      overview: {
        direction: getDir('container_overview'),
        name: (document.getElementById('overviewName') as HTMLInputElement).value || flatTitle,
        investor: (document.getElementById('overviewInvestor') as HTMLInputElement).value,
        location: (document.getElementById('overviewLocation') as HTMLInputElement).value || flatAddress,
        scale: (document.getElementById('overviewScale') as HTMLInputElement).value,
        type: (document.getElementById('overviewType') as HTMLInputElement).value,
        legal: (document.getElementById('overviewLegal') as HTMLInputElement).value || flatLegal,
        highlights: (document.getElementById('overviewHighlights') as HTMLInputElement).value,
        image_url: serverOriginalData?.overview?.image_url || ''
      },
      location_links: {
        direction: getDir('container_location'),
        title: (document.getElementById('locationTitle') as HTMLInputElement).value.trim(),
        description: (document.getElementById('locationDescription') as HTMLTextAreaElement).value.trim(),
        links: locationLinksArr,
        image_url: serverOriginalData?.location_links?.image_url || ''
      },
      floorplan: {
        direction: getDir('container_plan'),
        description: (document.getElementById('planDescriptionText') as HTMLTextAreaElement).value,
        key_points: planPointsArr,
        image_url: serverOriginalData?.floorplan?.image_url || ''
      },
      amenities: listAmenitiesText,
      unit_designs: {
        direction: getDir('container_unit'),
        description: (document.getElementById('unitSectionDesc') as HTMLInputElement).value.trim(),
        units: unitDesignArr,
        image_url: serverOriginalData?.unit_designs?.image_url || ''
      },
      furniture: {
        direction: getDir('container_furniture'),
        title: (document.getElementById('furnitureMainTitle') as HTMLInputElement).value || 'NỘI THẤT BÀN GIAO',
        subtitle: (document.getElementById('furnitureSubtitle') as HTMLInputElement).value || '',
        rooms: furnitureRoomsArr,
        items: furnitureRoomsArr[0] ? furnitureRoomsArr[0].items.map(i => ({ space: i.title, brand: i.description })) : [],
        image_url: furnitureRoomsArr[0] ? furnitureRoomsArr[0].image_url : ''
      },
      payment_methods: paymentMethodsArr,
      apartments: {
        title: (document.getElementById('apartmentsTitle') as HTMLInputElement).value.trim(),
        subtitle: (document.getElementById('apartmentsSubtitle') as HTMLInputElement).value.trim()
      },
      lead_form: {
        title: (document.getElementById('leadFormTitle') as HTMLInputElement).value.trim(),
        subtitle: (document.getElementById('leadFormSubtitle') as HTMLTextAreaElement).value.trim(),
        btn_text: (document.getElementById('leadFormBtnText') as HTMLInputElement).value.trim()
      }
    };

    formData.append('_method', 'PUT'); 
    formData.append('landing_structure', JSON.stringify(structuralTextJson));
    
    formData.append('title', flatTitle);
    formData.append('slug', flatSlug);
    formData.append('status', flatStatus);
    formData.append('legal', flatLegal);
    formData.append('lat', flatLat);
    formData.append('lng', flatLng);
    formData.append('address', flatAddress);

    if (projInput && projInput.files && projInput.files[0]) formData.append('image', projInput.files[0]);

    const appendFileField = (inputId: string, paramName: string) => {
      const fileInput = document.getElementById(inputId) as HTMLInputElement;
      if (fileInput && fileInput.files && fileInput.files[0]) formData.append(paramName, fileInput.files[0]);
    };
    appendFileField('heroFileInput', 'hero_bg');
    appendFileField('overviewFileInput', 'overview_image');
    appendFileField('locationFileInput', 'location_image');
    appendFileField('planFileInput', 'plan_image');

    document.querySelectorAll('.amenity-node').forEach(node => {
      const fileInput = node.querySelector('.amenity-file-input') as HTMLInputElement;
      const zone = node.querySelector('.amenity-dropzone') as HTMLDivElement;
      const idx = zone.getAttribute('data-index');
      if (fileInput.files && fileInput.files[0]) formData.append(`amenity_file_${idx}`, fileInput.files[0]);
    });

    try {
      const res = await fetch(`${BACKEND_URL}/api/admin/projects/${projectId}`, {
        method: 'POST',
        headers: { 'Authorization': `Bearer ${token}` },
        body: formData
      });
      const resData = await res.json();
      if (res.ok && resData.success) {
        await Swal.fire('Thành công', 'Bố cục Canvas và Landing Page đã cập nhật thành công!', 'success');
        window.location.href = '/admin/projects';
      } else {
        Swal.fire('Thất bại', resData.message || 'Lỗi lưu thông tin.', 'error');
      }
    } catch (err) {
      Swal.fire('Lỗi liên kết', 'Không thể kết nối tới máy chủ dữ liệu Laravel.', 'error');
    }
  });

  document.addEventListener('DOMContentLoaded', () => {
    initWidgetLayoutBuilder(); 
    loadProjectLandingData();
  });
</script>