---
import AdminLayout from '../../../layouts/AdminLayout.astro';
---

<AdminLayout title="Cấu hình trực quan Landing Page Dự Án">
  <div class="max-w-full mx-auto py-2 px-2">
    
    <div class="flex flex-col mb-8">
      <h1 class="text-2xl font-black text-slate-900">Cấu Hình Landing Page</h1>
      <p class="text-slate-500">Bật/tắt các Widget tính năng ở cột trái, kéo thả thay đổi vị trí sắp xếp linh hoạt bên cột phải bám sát cấu trúc thiết kế mẫu.</p>
    </div>

    <form id="projectLandingForm" class="w-full">
      
      <div class="bg-white p-6 md:p-8 rounded-3xl border border-slate-100 shadow-sm space-y-4 mb-6">
        <div class="flex items-center justify-between border-b border-slate-100 pb-2 cursor-pointer select-none">
          <div class="text-xs font-black text-slate-400 uppercase tracking-widest">
            SECTION 00: THÔNG TIN PHẲNG CỐT LÕI (NHẬN DIỆN HỆ THỐNG BẮT BUỘC)
          </div>
        </div>
        
        <div class="space-y-6">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <label class="block text-[10px] font-black text-slate-400 uppercase tracking-wider mb-1">Tên dự án gốc</label>
              <input type="text" id="projectTitle" required class="w-full px-3 py-2.5 bg-slate-50 border border-slate-200 rounded-xl text-xs font-bold text-slate-800 outline-none focus:border-orange-500 focus:bg-white transition-all" placeholder="Ví dụ: Bcons City" />
            </div>
            <div>
              <label class="block text-[10px] font-black text-slate-400 uppercase tracking-wider mb-1">Đường dẫn thân thiện (Slug URL tự động)</label>
              <input type="text" id="projectSlug" required class="w-full px-3 py-2.5 bg-slate-50 border border-slate-200 rounded-xl text-xs font-bold text-slate-800 outline-none focus:border-orange-500 focus:bg-white transition-all" placeholder="Ví dụ: bcons-city" />
            </div>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="grid grid-cols-2 gap-4">
              <div>
                <label class="block text-[10px] font-black text-slate-400 uppercase tracking-wider mb-1">Tọa độ Lat</label>
                <input type="text" id="projectLat" required class="w-full px-3 py-2.5 bg-slate-50 border border-slate-200 rounded-xl text-xs font-bold text-slate-800 outline-none focus:border-orange-500 focus:bg-white transition-all" placeholder="10.885348" />
              </div>
              <div>
                <label class="block text-[10px] font-black text-slate-400 uppercase tracking-wider mb-1">Tọa độ Lng</label>
                <input type="text" id="projectLng" required class="w-full px-3 py-2.5 bg-slate-50 border border-slate-200 rounded-xl text-xs font-bold text-slate-800 outline-none focus:border-orange-500 focus:bg-white transition-all" placeholder="106.783637" />
              </div>
            </div>

            <div class="grid grid-cols-2 gap-4">
              <div class="relative dropdown-container" id="dropdown-status">
                <label class="block text-[10px] font-black text-slate-400 uppercase tracking-wider mb-1">Tình trạng mở bán</label>
                <input type="hidden" id="status" value="dang_xay_dung" />
                <button type="button" class="drop-btn w-full px-4 py-2 bg-slate-50 border border-slate-200 rounded-xl flex items-center justify-between text-xs font-bold hover:bg-slate-100 transition-all outline-none min-h-[38px]">
                  <span class="selected-text">Đang xây dựng</span>
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-slate-400 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                  </svg>
                </button>
                <div class="drop-menu absolute z-30 w-full mt-2 bg-white rounded-2xl shadow-2xl border border-slate-100 opacity-0 invisible -translate-y-2 transition-all duration-300">
                  <div class="p-2 space-y-1">
                    <div data-value="dang_xay_dung" class="option-item flex items-center gap-3 px-4 py-2.5 text-xs font-bold hover:bg-orange-50 hover:text-orange-700 hover:rounded-xl cursor-pointer border-b border-slate-100">Đang xây dựng</div>
                    <div data-value="da_ban_giao" class="option-item flex items-center gap-3 px-4 py-2.5 text-xs font-bold hover:bg-orange-50 hover:text-orange-700 hover:rounded-xl cursor-pointer border-b border-slate-100">Đã bàn giao</div>
                    <div data-value="dang_mo_ban" class="option-item flex items-center gap-3 px-4 py-2.5 text-xs font-bold hover:bg-orange-50 hover:text-orange-700 hover:rounded-xl cursor-pointer border-b border-slate-100">Đang mở bán</div>
                    <div data-value="sap_mo_ban" class="option-item flex items-center gap-3 px-4 py-2.5 text-xs font-bold hover:bg-orange-50 hover:text-orange-700 hover:rounded-xl cursor-pointer border-b border-slate-100">Sắp mở bán</div>
                  </div>
                </div>
              </div>

              <div class="relative dropdown-container" id="dropdown-legal">
                <label class="block text-[10px] font-black text-slate-400 uppercase tracking-wider mb-1">Pháp lý hiện tại</label>
                <input type="hidden" id="legal" value="hdmb" />
                <button type="button" class="drop-btn w-full px-4 py-2 bg-slate-50 border border-slate-200 rounded-xl flex items-center justify-between text-xs font-bold hover:bg-slate-100 transition-all outline-none min-h-[38px]">
                  <span class="selected-text">Hợp đồng mua bán</span>
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-slate-400 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                  </svg>
                </button>
                <div class="drop-menu absolute z-30 w-full mt-2 bg-white rounded-2xl shadow-2xl border border-slate-100 opacity-0 invisible -translate-y-2 transition-all duration-300">
                  <div class="p-2 space-y-1">
                    <div data-value="hdmb" class="option-item flex items-center gap-3 px-4 py-2.5 rounded-xl text-xs font-bold hover:bg-orange-50 hover:text-orange-700 hover:rounded-xl cursor-pointer border-b border-slate-100">Hợp đồng mua bán</div>
                    <div data-value="so_hong" class="option-item flex items-center gap-3 px-4 py-2.5 rounded-xl text-xs font-bold hover:bg-orange-50 hover:text-orange-700 hover:rounded-xl cursor-pointer border-b border-slate-100">Đã có sổ hồng</div>
                    <div data-value="booking" class="option-item flex items-center gap-3 px-4 py-2.5 rounded-xl text-xs font-bold hover:bg-orange-50 hover:text-orange-700 hover:rounded-xl cursor-pointer border-b border-slate-100">Booking tư vấn</div>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <div>
            <label class="block text-[10px] font-black text-slate-400 uppercase tracking-wider mb-1">Địa chỉ dự án chính thức</label>
            <input type="text" id="projectAddress" required class="w-full px-3 py-2.5 bg-slate-50 border border-slate-200 rounded-xl text-xs font-bold text-slate-800 outline-none focus:border-orange-500 focus:bg-white transition-all" placeholder="Ví dụ: Đại lộ Bình Dương, Phường Đông Hòa, TP. Dĩ An, Bình Dương" />
          </div>

          <div>
            <label class="block text-[10px] font-black text-slate-400 uppercase tracking-wider mb-2">Hình ảnh đại diện ngoài danh sách</label>
            <div class="flex flex-col sm:flex-row gap-4 items-center bg-slate-50 p-4 rounded-2xl border border-slate-200">
              <div class="flex-1 w-full">
                <input type="file" id="projectFileInput" accept="image/*" class="w-full text-xs file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-xs file:font-bold file:bg-orange-50 file:text-orange-700 hover:file:bg-orange-100 cursor-pointer" />
                <p class="text-[10px] text-slate-400 mt-2">Ảnh thumbnail phẳng đại diện của sản phẩm phục vụ hiển thị ngoài danh sách bảng điều khiển chính.</p>
              </div>
              <div class="w-24 h-24 rounded-xl border bg-white flex items-center justify-center overflow-hidden shrink-0 shadow-sm">
                <img id="projectPreviewImg" class="w-full h-full object-cover hidden" />
                <span id="projectPreviewPlaceholder" class="text-[10px] font-bold text-slate-400">Chưa ảnh</span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="grid grid-cols-1 xl:grid-cols-4 gap-6 items-start">
        
        <div class="xl:col-span-1 bg-slate-900 text-white p-5 rounded-3xl border border-slate-800 shadow-2xl xl:sticky xl:top-6 space-y-4">
          <div>
            <h3 class="text-xs font-black text-slate-400 uppercase tracking-widest">Kho Widget Tính Năng</h3>
            <p class="text-[11px] text-slate-400 mt-1">Bấm nút kích hoạt để đưa khối vào khu vực Canvas bố cục thực tế.</p>
          </div>
          
          <div id="widgetPool" class="space-y-2 max-h-[65vh] overflow-y-auto pr-1">
            <div data-widget-id="hero" class="widget-pool-item bg-slate-800 p-3 rounded-xl border border-slate-700 flex items-center justify-between cursor-pointer hover:border-orange-500 transition-all select-none group">
              <div class="flex items-center gap-2 text-xs font-bold"><span>01. Banner Hero & Form</span></div>
              <button type="button" class="activate-widget-btn text-[10px] bg-slate-700 group-hover:bg-orange-600 px-2.5 py-1 rounded-lg text-white font-bold transition-all">Bật</button>
            </div>
            <div data-widget-id="highlights" class="widget-pool-item bg-slate-800 p-3 rounded-xl border border-slate-700 flex items-center justify-between cursor-pointer hover:border-orange-500 transition-all select-none group">
              <div class="flex items-center gap-2 text-xs font-bold"><span>02. Đối Tác Ngân Hàng</span></div>
              <button type="button" class="activate-widget-btn text-[10px] bg-slate-700 group-hover:bg-orange-600 px-2.5 py-1 rounded-lg text-white font-bold transition-all">Bật</button>
            </div>
            <div data-widget-id="stats" class="widget-pool-item bg-slate-800 p-3 rounded-xl border border-slate-700 flex items-center justify-between cursor-pointer hover:border-orange-500 transition-all select-none group">
              <div class="flex items-center gap-2 text-xs font-bold"><span>03. Thanh 4 Thông Số</span></div>
              <button type="button" class="activate-widget-btn text-[10px] bg-slate-700 group-hover:bg-orange-600 px-2.5 py-1 rounded-lg text-white font-bold transition-all">Bật</button>
            </div>
            <div data-widget-id="promo" class="widget-pool-item bg-slate-800 p-3 rounded-xl border border-slate-700 flex items-center justify-between cursor-pointer hover:border-orange-500 transition-all select-none group">
              <div class="flex items-center gap-2 text-xs font-bold"><span>04. Khối Chiết Khấu</span></div>
              <button type="button" class="activate-widget-btn text-[10px] bg-slate-700 group-hover:bg-orange-600 px-2.5 py-1 rounded-lg text-white font-bold transition-all">Bật</button>
            </div>
            <div data-widget-id="overview" class="widget-pool-item bg-slate-800 p-3 rounded-xl border border-slate-700 flex items-center justify-between cursor-pointer hover:border-orange-500 transition-all select-none group">
              <div class="flex items-center gap-2 text-xs font-bold"><span>05. Tổng Quan Chi Tiết</span></div>
              <button type="button" class="activate-widget-btn text-[10px] bg-slate-700 group-hover:bg-orange-600 px-2.5 py-1 rounded-lg text-white font-bold transition-all">Bật</button>
            </div>
            <div data-widget-id="location_links" class="widget-pool-item bg-slate-800 p-3 rounded-xl border border-slate-700 flex items-center justify-between cursor-pointer hover:border-orange-500 transition-all select-none group">
              <div class="flex items-center gap-2 text-xs font-bold"><span>06. Bản Đồ Vị Trí Vùng</span></div>
              <button type="button" class="activate-widget-btn text-[10px] bg-slate-700 group-hover:bg-orange-600 px-2.5 py-1 rounded-lg text-white font-bold transition-all">Bật</button>
            </div>
            <div data-widget-id="floorplan" class="widget-pool-item bg-slate-800 p-3 rounded-xl border border-slate-700 flex items-center justify-between cursor-pointer hover:border-orange-500 transition-all select-none group">
              <div class="flex items-center gap-2 text-xs font-bold"><span>07. Bản Đồ Mặt Bằng</span></div>
              <button type="button" class="activate-widget-btn text-[10px] bg-slate-700 group-hover:bg-orange-600 px-2.5 py-1 rounded-lg text-white font-bold transition-all">Bật</button>
            </div>
            <div data-widget-id="amenities" class="widget-pool-item bg-slate-800 p-3 rounded-xl border border-slate-700 flex items-center justify-between cursor-pointer hover:border-orange-500 transition-all select-none group">
              <div class="flex items-center gap-2 text-xs font-bold"><span>08. 6 Khối Tiện Ích Nội Khu</span></div>
              <button type="button" class="activate-widget-btn text-[10px] bg-slate-700 group-hover:bg-orange-600 px-2.5 py-1 rounded-lg text-white font-bold transition-all">Bật</button>
            </div>
            <div data-widget-id="unit_designs" class="widget-pool-item bg-slate-800 p-3 rounded-xl border border-slate-700 flex items-center justify-between cursor-pointer hover:border-orange-500 transition-all select-none group">
              <div class="flex items-center gap-2 text-xs font-bold"><span>09. Layout Mẫu Căn Hộ</span></div>
              <button type="button" class="activate-widget-btn text-[10px] bg-slate-700 group-hover:bg-orange-600 px-2.5 py-1 rounded-lg text-white font-bold transition-all">Bật</button>
            </div>
            <div data-widget-id="furniture" class="widget-pool-item bg-slate-800 p-3 rounded-xl border border-slate-700 flex items-center justify-between cursor-pointer hover:border-orange-500 transition-all select-none group">
              <div class="flex items-center gap-2 text-xs font-bold"><span>10. Vật Liệu Bàn Giao</span></div>
              <button type="button" class="activate-widget-btn text-[10px] bg-slate-700 group-hover:bg-orange-600 px-2.5 py-1 rounded-lg text-white font-bold transition-all">Bật</button>
            </div>
            <div data-widget-id="payment_methods" class="widget-pool-item bg-slate-800 p-3 rounded-xl border border-slate-700 flex items-center justify-between cursor-pointer hover:border-orange-500 transition-all select-none group">
              <div class="flex items-center gap-2 text-xs font-bold"><span>11. Tiến Độ Thanh Toán</span></div>
              <button type="button" class="activate-widget-btn text-[10px] bg-slate-700 group-hover:bg-orange-600 px-2.5 py-1 rounded-lg text-white font-bold transition-all">Bật</button>
            </div>
            <div data-widget-id="apartments" class="widget-pool-item bg-slate-800 p-3 rounded-xl border border-slate-700 flex items-center justify-between cursor-pointer hover:border-orange-500 transition-all select-none group">
              <div class="flex items-center gap-2 text-xs font-bold"><span>12. Live Inventory Giỏ Hàng</span></div>
              <button type="button" class="activate-widget-btn text-[10px] bg-slate-700 group-hover:bg-orange-600 px-2.5 py-1 rounded-lg text-white font-bold transition-all">Bật</button>
            </div>
            <div data-widget-id="lead_form" class="widget-pool-item bg-slate-800 p-3 rounded-xl border border-slate-700 flex items-center justify-between cursor-pointer hover:border-orange-500 transition-all select-none group">
              <div class="flex items-center gap-2 text-xs font-bold"><span>13. Biểu Mẫu Chân Trang</span></div>
              <button type="button" class="activate-widget-btn text-[10px] bg-slate-700 group-hover:bg-orange-600 px-2.5 py-1 rounded-lg text-white font-bold transition-all">Bật</button>
            </div>
          </div>
        </div>

        <div class="xl:col-span-3 space-y-6">
          <div id="activeCanvas" class="space-y-6 min-h-[350px] bg-slate-50/60 border-2 border-dashed border-slate-200 rounded-3xl p-4 md:p-6 transition-all">
          </div>
          
          <button type="submit" class="w-full bg-orange-600 hover:bg-orange-500 text-white font-bold py-4 rounded-2xl transition-all shadow-xl shadow-orange-600/10 active:scale-[0.99] text-sm uppercase tracking-wider cursor-pointer">
            Cập Nhật Landing Page Dự Án
          </button>
        </div>
        
      </div>

      <div id="hiddenWidgetStorage" class="hidden">
        
        <div data-section-id="hero" class="bg-white p-6 md:p-8 rounded-3xl border border-slate-100 shadow-sm space-y-4 section-card">
          <div class="canvas-drag-handle flex items-center justify-between bg-slate-50 px-4 py-2 rounded-xl mb-2 border border-slate-100 cursor-move select-none" draggable="true">
            <div class="flex items-center gap-2">
              <span class="text-slate-400 text-sm">⣿</span>
              <span class="canvas-index-badge text-[10px] bg-slate-200 text-slate-700 font-bold px-1.5 py-0.5 rounded font-mono">#</span>
              <span class="text-xs font-bold text-slate-600 uppercase tracking-wider">SECTION 01: BANNER HERO & LEAD FORM</span>
            </div>
            <button type="button" class="remove-widget-btn text-[10px] font-bold text-red-500 hover:text-red-700 transition-colors bg-red-50 px-2 py-1 rounded-lg border border-red-100">✕ Gỡ hiển thị</button>
          </div>
          <div class="flex items-center justify-between border-b border-slate-100 pb-1 cursor-pointer section-header select-none">
            <span class="text-[10px] font-black text-slate-400 tracking-wider uppercase">Cấu hình chi tiết form nhập liệu</span>
            <div class="flex items-center gap-3">
              <span class="direction-badge text-[10px] font-bold text-slate-400 bg-slate-100 px-2.5 py-1 rounded-md uppercase font-mono" id="badge_hero">Bố cục: Mặc định</span>
              <button type="button" class="collapse-toggle-btn p-1 text-slate-400 hover:text-slate-600"><svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 transform transition-transform duration-200 chevron-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg></button>
            </div>
          </div>
          <div class="section-content space-y-4">
            <div id="container_hero" class="flex flex-col lg:flex-row gap-6 items-stretch transition-all duration-300 dynamic-flex-row" data-direction="normal" data-badge="badge_hero">
              <div class="w-full lg:w-[58%] bg-white p-5 rounded-xl border border-slate-200 flex flex-col justify-between gap-5 relative group/col draggable-column" draggable="true">
                <div class="absolute top-2 right-2 opacity-0 group-hover/col:opacity-100 transition-opacity cursor-move bg-slate-200 text-slate-600 text-[9px] font-black px-2 py-1 rounded-md shadow-sm select-none">⣿ KÉO ĐỔI BÊN</div>
                <div class="space-y-4 w-full">
                  <div>
                    <label class="block text-[10px] font-black text-slate-400 uppercase tracking-wider mb-1">Tên dự án chính (H1)</label>
                    <input type="text" id="heroTitle" class="w-full px-3 py-2.5 bg-slate-50 border border-slate-200 rounded-xl text-xs font-bold text-slate-800 outline-none focus:border-orange-500 focus:bg-white transition-all" placeholder="Ví dụ: BCONS CENTER CITY" />
                  </div>
                  <div>
                    <label class="block text-[10px] font-black text-slate-400 uppercase tracking-wider mb-1">Giới thiệu ngắn dự án / Slogan sản phẩm</label>
                    <input type="text" id="heroSubtitle" class="w-full px-3 py-2.5 bg-slate-50 border border-slate-200 rounded-xl text-xs font-semibold text-slate-700 outline-none focus:border-orange-500 focus:bg-white transition-all" placeholder="Ví dụ: Căn hộ cao cấp mặt tiền đại lộ" />
                  </div>
                  <div>
                    <label class="block text-[10px] font-black text-slate-400 uppercase tracking-wider mb-1">Giới thiệu chi tiết dự án</label>
                    <textarea id="heroDescription" rows="3" class="w-full px-3 py-2.5 bg-slate-50 border border-slate-200 rounded-xl text-xs font-medium text-slate-700 outline-none focus:border-orange-500 focus:bg-white transition-all" placeholder="Nhập văn bản mô tả chi tiết..."></textarea>
                  </div>
                </div>
                <div class="bg-amber-400/10 p-4 rounded-xl border border-dashed border-amber-400 space-y-3">
                  <span class="block text-[9px] font-black text-amber-800 uppercase tracking-wider">Biểu mẫu tư vấn (Hứng Leads Ads)</span>
                  <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
                    <div class="h-9 bg-white border border-slate-200 rounded-lg flex items-center px-3 text-[10px] text-slate-400 font-medium">Họ và tên của khách...</div>
                    <div class="h-9 bg-white border border-slate-200 rounded-lg flex items-center px-3 text-[10px] text-slate-400 font-medium">Số điện thoại liên hệ...</div>
                  </div>
                  <div>
                    <label class="block text-[9px] font-bold text-amber-900 uppercase tracking-wider mb-1">Chữ hiển thị trên nút gửi dữ liệu Form</label>
                    <input type="text" id="heroBtnText" class="w-full px-3 py-2 bg-white border border-slate-200 rounded-lg text-xs font-bold text-slate-900 outline-none" placeholder="Ví dụ: ĐĂNG KÝ NHẬN BẢNG GIÁ" />
                  </div>
                </div>
              </div>
              <div class="w-full lg:w-[42%] flex flex-col min-h-[260px] relative group/col draggable-column" draggable="true">
                <div class="absolute top-2 right-2 opacity-0 group-hover/col:opacity-100 transition-opacity cursor-move bg-slate-200 text-slate-600 text-[9px] font-black px-2 py-1 rounded-md shadow-sm select-none">⣿ KÉO ĐỔI BÊN</div>
                <div class="flex-1 border-2 border-dashed border-slate-300 hover:border-orange-500 bg-white rounded-2xl flex flex-col items-center justify-center p-4 text-center cursor-pointer relative overflow-hidden transition-all group" id="heroDropzone">
                  <div class="pointer-events-none space-y-1 text-slate-400 group-hover:text-slate-600 transition-colors">
                    <span class="text-3xl">📸</span><div class="text-xs font-bold text-slate-700">UP ẢNH PHỐI CẢNH HERO</div>
                    <div class="text-[9px] text-slate-400 italic">(Vui lòng click chọn 1 mẫu bên trái trước khi tải ảnh)</div>
                  </div>
                  <img id="heroPreviewImg" class="absolute inset-0 w-full h-full object-cover hidden" />
                </div>
                <input type="file" id="heroFileInput" accept="image/*" class="hidden" />
              </div>
            </div>
          </div>
        </div>

        <div data-section-id="highlights" class="bg-white p-6 md:p-8 rounded-3xl border border-slate-100 shadow-sm space-y-4 section-card">
