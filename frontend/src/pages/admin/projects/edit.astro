    const nameInp = itemEl.querySelector('.room-name-input') as HTMLInputElement;
    nameInp?.addEventListener('input', () => {
      const activeItem = document.querySelector('.furniture-room-item.border-orange-500');
      const labelEl = document.getElementById('furnitureRoomDropzoneLabel');
      if (activeItem === itemEl && labelEl) {
        labelEl.textContent = `ẢNH KHÔNG GIAN: ${nameInp.value.trim() || 'CHƯA ĐẶT TÊN'}`;
      }
