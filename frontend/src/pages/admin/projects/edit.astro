      row.className = "flex items-center gap-2 room-material-row animate-fadeIn";
      row.innerHTML = `
        <input type="text" class="mat-title-input w-1/3 px-2 py-1 bg-white border border-slate-200 rounded text-xs font-bold" placeholder="Mục (CỬA CHÍNH)" />
        <input type="text" class="mat-desc-input w-2/3 px-2 py-1 bg-white border border-slate-200 rounded text-xs" placeholder="Thương hiệu & chất liệu..." />
        <button type="button" class="delete-mat-row-btn text-slate-400 hover:text-red-500 p-1 text-xs cursor-pointer">✕</button>
      `;
      matContainer?.appendChild(row);
