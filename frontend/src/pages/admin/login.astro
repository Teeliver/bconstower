---
import MainLayout from '../../layouts/MainLayout.astro';
---

<MainLayout title="Quản trị viên - Đăng nhập">
  <div class="min-h-screen flex items-center justify-center bg-slate-950 font-sans text-slate-200">
    <div class="w-full max-w-md p-8 bg-slate-900 rounded-2xl shadow-2xl border border-slate-800">
      <div class="text-center mb-10">
        <h1 class="text-4xl font-black text-white tracking-tighter">ADMIN <span class="text-orange-500 font-light">BĐS</span></h1>
        <p class="text-slate-400 mt-2">Hệ thống quản lý tin đăng bất động sản</p>
      </div>

      <form id="adminLoginForm" class="space-y-6">
        <div>
          <label class="block text-sm font-medium mb-2 text-slate-300">Email hệ thống</label>
          <input type="email" id="email" required 
            class="w-full px-4 py-3 bg-slate-800 border border-slate-700 rounded-xl focus:ring-2 focus:ring-orange-500 focus:border-transparent outline-none transition-all text-white"
            placeholder="admin@email.com" />
        </div>

        <div>
          <label class="block text-sm font-medium mb-2 text-slate-300">Mật khẩu</label>
          <input type="password" id="password" required 
            class="w-full px-4 py-3 bg-slate-800 border border-slate-700 rounded-xl focus:ring-2 focus:ring-orange-500 focus:border-transparent outline-none transition-all text-white"
            placeholder="••••••••" />
        </div>

        <button type="submit" id="submitBtn"
          class="w-full bg-orange-600 hover:bg-orange-500 text-white font-bold py-3 rounded-xl transition-all shadow-lg shadow-orange-900/20 active:scale-95">
          Đăng Nhập Quản Trị
        </button>

        <p id="msg" class="text-center text-sm font-medium mt-4 p-3 rounded-lg hidden"></p>
      </form>
    </div>
  </div>
</MainLayout>

<script>
  const form = document.getElementById('adminLoginForm') as HTMLFormElement;
  const msg = document.getElementById('msg') as HTMLParagraphElement;
  const btn = document.getElementById('submitBtn') as HTMLButtonElement;

  const BACKEND_URL = import.meta.env.PUBLIC_API_BASE || 'http://localhost:8000';

  const ALLOWED_ROLES = [
    'ADMIN', 'EDITOR', 
    'MANAGER', 'QUAN_LY', 'QUẢN LÝ', 
    'BROKER', 'MOI_GIOI', 'MÔI GIỚI'
  ];

  /**
   * 1. KIỂM TRA TRẠNG THÁI ĐĂNG NHẬP (Bảo vệ đầu vào)
   */
  const checkAuth = () => {
    const token = localStorage.getItem('admin_token');
    const userStr = localStorage.getItem('admin_user');

    if (token && userStr) {
      try {
        const user = JSON.parse(userStr);
        const roleClean = String(user.role || '').toUpperCase().trim();
        
        if (ALLOWED_ROLES.includes(roleClean)) {
          window.location.replace('/admin/dashboard');
        }
      } catch (e) {
        localStorage.clear();
      }
    }
  };

  // Chạy ngay khi tải trang
  checkAuth();

  /**
   * 2. XỬ LÝ FORM ĐĂNG NHẬP
   */
  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    btn.disabled = true;
    btn.innerText = "Đang kiểm tra...";
    msg.classList.add('hidden');

    const email = (document.getElementById('email') as HTMLInputElement).value;
    const password = (document.getElementById('password') as HTMLInputElement).value;

    try {
      const res = await fetch(`${BACKEND_URL}/api/admin/login`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email, password })
      });

      const data = await res.json();

      if (res.ok && data.success) {
        const roleClean = String(data.user?.role || '').toUpperCase().trim();

        if (data.user && ALLOWED_ROLES.includes(roleClean)) {
  
        // Giữ nguyên các dòng localStorage cũ của ông...
        localStorage.setItem('admin_token', data.token);
        localStorage.setItem('admin_user', JSON.stringify(data.user));
        localStorage.setItem('user_role', data.user.role);

        // 🔥 ĐÃ VÁ: Đổi SameSite từ Strict sang Lax để tránh bị kẹt bộ lọc khi redirect trên Localhost
        document.cookie = `auth_token=${data.token}; path=/; max-age=86400; SameSite=Lax`;
        document.cookie = `user_role=${data.user.role}; path=/; max-age=86400; SameSite=Lax`;

        msg.className = "text-center text-sm font-medium mt-4 p-3 rounded-lg bg-green-900/30 text-green-400 border border-green-800/50";
        msg.innerText = data.message || "Xác thực thành công! Đang vào hệ thống...";
        msg.classList.remove('hidden');

        setTimeout(() => { 
          window.location.replace('/admin/dashboard'); 
        }, 800);
      } else {
          throw new Error("Tài khoản này không có quyền truy cập quản trị!");
        }
      } else {
        throw new Error(data.message || "Email hoặc mật khẩu không chính xác.");
      }
    } catch (err: any) {
      msg.className = "text-center text-sm font-medium mt-4 p-3 rounded-lg bg-red-900/30 text-red-400 border border-red-800/50";
      msg.innerText = err.message;
      msg.classList.remove('hidden');
      
      btn.disabled = false;
      btn.innerText = "Đăng Nhập Quản Trị";
    }
  });
</script>