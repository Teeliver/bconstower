---
// src/pages/admin/posts/index.astro
import AdminLayout from '../../../layouts/AdminLayout.astro';
---

<AdminLayout title="Quản lý bài viết">
    <div class="flex justify-between items-center mb-8">
      <div>
        <h1 class="text-2xl font-black text-slate-900 uppercase">Quản lý bài viết</h1>
        <p class="text-slate-500">Đăng tải tin tức thị trường và tiến độ dự án Bcons</p>
      </div>
      <a href="/admin/posts/add" class="bg-[#fac72e] hover:bg-[#e7af2d] text-black px-6 py-3 rounded-2xl font-medium transition-all shadow-lg shadow-[#fac72e]-200">
        + Thêm mới
      </a>
    </div>

    <div class="bg-white p-6 rounded-[1.5rem] shadow-sm border border-slate-100 mb-6 grid grid-cols-1 md:grid-cols-3 gap-4">
      <div class="relative dropdown-container" id="drop-category">
        <label class="text-[10px] font-bold text-slate-400 uppercase ml-2 mb-1 block">Chuyên mục</label>
        <button type="button" class="drop-btn w-full px-4 py-2.5 bg-slate-50 border border-transparent rounded-xl flex items-center justify-between text-sm font-medium hover:bg-slate-100 transition-all outline-none">
          <span class="selected-text">Tất cả chuyên mục</span>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
        </button>
        <input type="hidden" id="filterCategory" value="all">
        <div class="drop-menu absolute z-50 w-full mt-2 bg-white rounded-2xl shadow-2xl border border-slate-100 opacity-0 invisible -translate-y-2 transition-all duration-300">
          <div class="p-2 space-y-1">
            <div data-value="all" class="option-item px-4 py-2 rounded-lg hover:bg-orange-50 hover:text-orange-600 cursor-pointer text-sm">Tất cả chuyên mục</div>
            <div data-value="thi-truong" class="option-item px-4 py-2 rounded-lg hover:bg-orange-50 hover:text-orange-600 cursor-pointer text-sm">Tin thị trường</div>
            <div data-value="tien-do" class="option-item px-4 py-2 rounded-lg hover:bg-orange-50 hover:text-orange-600 cursor-pointer text-sm">Tiến độ dự án</div>
          </div>
        </div>
      </div>

      <div class="relative dropdown-container" id="drop-status">
        <label class="text-[10px] font-bold text-slate-400 uppercase ml-2 mb-1 block">Trạng thái</label>
        <button type="button" class="drop-btn w-full px-4 py-2.5 bg-slate-50 border border-transparent rounded-xl flex items-center justify-between text-sm font-medium hover:bg-slate-100 transition-all outline-none">
          <span class="selected-text">Tất cả trạng thái</span>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
        </button>
        <input type="hidden" id="filterStatus" value="all">
        <div class="drop-menu absolute z-50 w-full mt-2 bg-white rounded-2xl shadow-2xl border border-slate-100 opacity-0 invisible -translate-y-2 transition-all duration-300">
          <div class="p-2 space-y-1">
            <div data-value="all" class="option-item px-4 py-2 rounded-lg hover:bg-orange-50 hover:text-orange-600 cursor-pointer text-sm">Tất cả trạng thái</div>
            <div data-value="published" class="option-item px-4 py-2 rounded-lg hover:bg-orange-50 hover:text-orange-600 cursor-pointer text-sm">✅ Đã xuất bản</div>
            <div data-value="draft" class="option-item px-4 py-2 rounded-lg hover:bg-orange-50 hover:text-orange-600 cursor-pointer text-sm">⏳ Bản nháp</div>
          </div>
        </div>
      </div>

      <div>
        <label class="text-[10px] font-bold text-slate-400 uppercase ml-2 mb-1 block">Tìm bài viết</label>
        <input type="text" id="searchInput" placeholder="Tên tiêu đề hoặc slug..." class="w-full px-4 py-2.5 bg-slate-50 border border-transparent rounded-xl text-sm font-medium focus:bg-white focus:border-orange-500 outline-none transition-all" />
      </div>
    </div>

    <div class="bg-white rounded-3xl shadow-sm border border-slate-200 overflow-hidden">
        <table class="w-full text-left">
          <thead class="bg-slate-50 border-b border-slate-200">
            <tr>
              <th class="px-6 py-4 font-bold text-slate-600 text-sm">Bài viết</th>
              <th class="px-6 py-4 font-bold text-slate-600 text-sm text-center">Chuyên mục</th>
              <th class="px-6 py-4 font-bold text-slate-600 text-sm text-center">Ngày đăng</th>
              <th class="px-6 py-4 font-bold text-slate-600 text-sm text-center">Trạng thái</th>
              <th class="px-6 py-4 font-bold text-slate-600 text-sm text-center">Lượt xem</th>
              <th class="px-6 py-5 font-bold text-slate-600 text-sm text-right">Thao tác</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100" id="postTableBody">
            <tr>
                <td colspan="6" class="p-20 text-center text-slate-400 italic font-medium animate-pulse">Đang kết nối máy chủ bài viết...</td>
            </tr>
          </tbody>
        </table>
        <div id="noResults" class="hidden p-20 text-center text-slate-400 italic bg-white font-medium">
          Không tìm thấy bài viết nào khớp với bộ lọc.
        </div>
    </div>
</AdminLayout>

<style>
  .dropdown-container.active .drop-menu { opacity: 1; visibility: visible; transform: translateY(0); }
  .dropdown-container.active .drop-btn svg { transform: rotate(180deg); }
  .dropdown-container.active .drop-btn { border-color: #ea580c; background-color: #fff; }
</style>

<script>
  import Swal from 'sweetalert2';
  import { checkAdminAuth } from '../../../lib/auth';

  checkAdminAuth();

  const API_BASE = import.meta.env.PUBLIC_API_BASE || 'http://localhost:8000';

  const escapeHTML = (val: any): string => {
    if (val === null || val === undefined) return '';
    return String(val).replace(/[&<>"']/g, (m) => ({'&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;'}[m] || m));
  };

  async function initPage() {
    const tbody = document.getElementById('postTableBody');
    if (!tbody) return;

    const rawToken = localStorage.getItem('admin_token') || localStorage.getItem('token');
    const token = rawToken ? rawToken.replace(/['"]+/g, '').trim() : '';

    try {
      const res = await fetch(`${API_BASE}/api/admin/posts`, {
          headers: { 
            'Authorization': `Bearer ${token}`,
            'Accept': 'application/json'
          }
      });
      
      if (res.status === 401) {
        window.location.href = '/admin';
        return;
      }
      
      if (!res.ok) throw new Error("Server Error");
      
      const posts = await res.json();

      if (!posts || posts.length === 0) {
        tbody.innerHTML = '<tr><td colspan="6" class="p-20 text-center text-slate-400 italic font-medium">Chưa có bài viết nào trong hệ thống.</td></tr>';
        return;
      }

      renderTable(posts);
      setupFilters();

    } catch (err) {
      tbody.innerHTML = '<tr><td colspan="6" class="p-20 text-center text-red-500 font-bold italic underline">Lỗi kết nối máy chủ Laravel API. Vui lòng kiểm tra cổng 8000.</td></tr>';
    }
  }

  function renderTable(data: any[]) {
    const tbody = document.getElementById('postTableBody');
    if (!tbody) return;

    tbody.innerHTML = data.map((item: any) => {
        const title = item.title || 'Không tiêu đề';
        const slug = item.slug || '';
        const image = item.thumbnail ? (item.thumbnail.startsWith('http') ? item.thumbnail : `${API_BASE}${item.thumbnail}`) : 'https://placehold.co/100x100?text=No+Img';
        
        // 🟢 FIX LUẬN LÝ TRẠNG THÁI: Tương thích cả string lẫn boolean is_published từ Laravel
        let status = item.status || 'draft';
        if (item.is_published === true || item.is_published === 1) status = 'published';
        else if (item.is_published === false || item.is_published === 0) status = 'draft';

        // 🟢 FIX ĐỘC QUYỀN CHUYÊN MỤC: Tự động bóc tách thông minh từ Object Eloquent hoặc ID
        let category = 'khac';
        let categoryLabel = 'Khác';

        if (item.category && typeof item.category === 'object') {
            category = item.category.slug || 'khac';
            categoryLabel = item.category.name || (category === 'thi-truong' ? 'Thị trường' : 'Tiến độ');
        } else if (typeof item.category === 'string') {
            category = item.category;
            categoryLabel = category === 'thi-truong' ? 'Thị trường' : (category === 'tien-do' ? 'Tiến độ' : 'Khác');
        } else if (item.category_id) {
            if (item.category_id == 1 || String(item.category_id) === 'thi-truong') { category = 'thi-truong'; categoryLabel = 'Thị trường'; }
            else if (item.category_id == 2 || String(item.category_id) === 'tien-do') { category = 'tien-do'; categoryLabel = 'Tiến độ'; }
        }
        
        // 🟢 FIX ĐƯỜNG DẪN THỜI GIAN: Laravel trả về trường dạng snake_case (created_at) thay vì camelCase
        const rawDate = item.created_at || item.createdAt;
        const date = rawDate ? new Date(rawDate).toLocaleDateString('vi-VN') : 'N/A';

        return `
        <tr class="post-row group hover:bg-slate-50/50 transition-colors" 
            data-category="${escapeHTML(category)}" 
            data-status="${escapeHTML(status)}"
            data-title="${escapeHTML(title.toLowerCase())}">
            <td class="px-6 py-5">
                <div class="flex items-center gap-4">
                    <img src="${image}" class="w-14 h-10 rounded-lg object-cover border border-slate-100 shadow-sm" onerror="this.src='https://placehold.co/100x100?text=Error'" />
                    <div>
                        <div class="font-bold text-slate-800 line-clamp-3 group-hover:text-orange-600 transition-colors">${escapeHTML(title)}</div>
                        <div class="text-[10px] text-slate-400 font-mono italic">/${escapeHTML(slug)}</div>
                    </div>
                </div>
            </td>
            <td class="px-6 py-5 text-center">
                <span class="text-xs font-bold ${category === 'thi-truong' ? 'text-blue-600' : (category === 'tien-do' ? 'text-emerald-600' : 'text-slate-400')}">
                    ${escapeHTML(categoryLabel)}
                </span>
            </td>
            <td class="px-6 py-5 text-center text-sm text-slate-500">
                ${date}
            </td>
            <td class="px-6 py-5 text-center">
                <span class="px-3 py-1 rounded-full text-[10px] font-bold uppercase ${
                    status === 'published' ? 'bg-green-50 text-green-600' : 'bg-slate-100 text-slate-400'
                }">
                    ${status === 'published' ? '✅ Xuất bản' : '⏳ Bản nháp'}
                </span>
            </td>
            <td class="px-6 py-5 text-center font-bold text-slate-700 text-sm">
                ${(item.views || 0).toLocaleString()}
            </td>
            <td class="px-6 py-5 text-right">
                <div class="flex justify-end gap-2">
                    <a href="/admin/posts/edit?id=${item.id}" class="p-2 bg-blue-50 text-blue-600 rounded-xl hover:bg-blue-600 hover:text-white transition-all shadow-sm">
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" /></svg>
                    </a>
                    <button class="delete-btn p-2 bg-red-50 text-red-600 rounded-xl hover:bg-red-600 hover:text-white transition-all shadow-sm" data-id="${item.id}" data-title="${escapeHTML(title)}">
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" /></svg>
                    </button>
                </div>
            </td>
        </tr>`;
    }).join('');

    setupActionEvents();
  }

  function setupFilters() {
    ['drop-category', 'drop-status'].forEach(id => {
        const container = document.getElementById(id);
        if (!container) return;
        const btn = container.querySelector('.drop-btn') as HTMLButtonElement;
        const hiddenInput = container.querySelector('input[type="hidden"]') as HTMLInputElement;
        const selectedText = container.querySelector('.selected-text');

        btn.addEventListener('click', (e) => {
            e.stopPropagation();
            document.querySelectorAll('.dropdown-container').forEach(el => el !== container && el.classList.remove('active'));
            container.classList.toggle('active');
        });

        container.addEventListener('click', (e) => {
            const optionItem = (e.target as HTMLElement).closest('.option-item');
            if (optionItem) {
                const val = optionItem.getAttribute('data-value');
                if (val && hiddenInput) {
                    hiddenInput.value = val;
                    if (selectedText) selectedText.textContent = optionItem.textContent;
                    container.classList.remove('active');
                    filterData();
                }
            }
        });
    });

    document.getElementById('searchInput')?.addEventListener('input', filterData);
    window.addEventListener('click', () => {
        document.querySelectorAll('.dropdown-container').forEach(el => el.classList.remove('active'));
    });
  }

  function filterData() {
    const valCat = (document.getElementById('filterCategory') as HTMLInputElement).value;
    const valStatus = (document.getElementById('filterStatus') as HTMLInputElement).value;
    const valSearch = (document.getElementById('searchInput') as HTMLInputElement).value.toLowerCase();

    const rows = document.querySelectorAll('.post-row');
    const noResults = document.getElementById('noResults');
    let visibleCount = 0;

    rows.forEach((row: any) => {
      const cat = row.dataset.category;
      const status = row.dataset.status;
      const title = row.dataset.title;

      const passCat = valCat === 'all' || cat === valCat;
      const passStatus = valStatus === 'all' || status === valStatus;
      const passSearch = title.includes(valSearch);

      if (passCat && passStatus && passSearch) {
        row.classList.remove('hidden');
        visibleCount++;
      } else {
        row.classList.add('hidden');
      }
    });

    if (visibleCount === 0) noResults?.classList.remove('hidden');
    else noResults?.classList.add('hidden');
  }

  function setupActionEvents() {
    document.querySelectorAll('.delete-btn').forEach(btn => {
        btn.addEventListener('click', async (e) => {
            const target = e.currentTarget as HTMLElement;
            const id = target.dataset.id;
            const title = target.dataset.title;
            
            if (!id) return;

            const confirm = await Swal.fire({ 
              title: 'Xóa bài viết?', 
              text: `Bạn muốn xóa: "${title}"? Hành động này không thể hoàn tác!`, 
              icon: 'warning', 
              showCancelButton: true, 
              confirmButtonColor: '#ef4444',
              confirmButtonText: 'Đồng ý xóa',
              cancelButtonText: 'Hủy'
            });

            if (confirm.isConfirmed) {
                Swal.fire({ title: 'Đang thực hiện...', didOpen: () => Swal.showLoading() });
                
                const rawToken = localStorage.getItem('admin_token') || localStorage.getItem('token');
                const token = rawToken ? rawToken.replace(/['"]+/g, '').trim() : '';

                try {
                    const res = await fetch(`${API_BASE}/api/admin/posts/${id}`, {
                        method: 'DELETE',
                        headers: { 
                          'Authorization': `Bearer ${token}`,
                          'Accept': 'application/json'
                        }
                    });

                    const data = await res.json();

                    if (res.ok && data.success) {
                        await Swal.fire({ icon: 'success', title: 'Đã xóa thành công!', timer: 1500, showConfirmButton: false });
                        initPage();
                    } else {
                        throw new Error(data.message || "Lỗi xóa");
                    }
                } catch (err: any) {
                    Swal.fire('Thất bại', err.message || 'Không thể kết nối máy chủ', 'error');
                }
            }
        });
    });
  }

  initPage();
</script>