---
import AdminLayout from '../../../layouts/AdminLayout.astro';
---

<AdminLayout title="Soạn thảo bài viết">
  <script is:inline src="https://cdn.jsdelivr.net/npm/tinymce@6/tinymce.min.js" referrerpolicy="origin"></script>

  <div class="max-w-full mx-auto">
    <div class="mb-8">
      <a href="/admin/posts" class="text-slate-400 hover:text-orange-600 flex items-center gap-2 mb-4 transition-all group">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 transition-transform group-hover:-translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
        <span class="font-bold text-sm">Quay lại danh sách</span>
      </a>
      <h1 class="text-3xl font-black text-slate-900 tracking-tight">Soạn thảo nội dung</h1>
    </div>

    <form id="addPostForm" class="grid grid-cols-1 lg:grid-cols-12 gap-8" enctype="multipart/form-data">
      <div class="lg:col-span-8 space-y-6">
        <div class="bg-white p-8 rounded-[2.5rem] border border-slate-100 shadow-sm space-y-6">
          <div class="space-y-2">
            <label class="text-xs font-bold text-slate-500 uppercase ml-1">Tiêu đề bài viết *</label>
            <input type="text" name="title" id="title" required placeholder="Nhập tiêu đề tin tức..." class="w-full px-6 py-4 bg-slate-50 border-none rounded-2xl text-lg font-bold focus:bg-white focus:ring-2 focus:ring-orange-500 outline-none transition-all" />
          </div>

          <div class="space-y-2">
            <label class="text-xs font-bold text-slate-500 uppercase ml-1 tracking-tighter">Đường dẫn (Slug)</label>
            <input type="text" name="slug" id="slug" readonly class="w-full px-4 py-2 bg-slate-100 border-none rounded-lg text-sm text-slate-400 font-mono outline-none cursor-not-allowed" />
          </div>

          <div class="space-y-2">
            <label class="text-xs font-bold text-slate-500 uppercase ml-1">Tóm tắt ngắn</label>
            <textarea name="summary" rows="3" placeholder="Mô tả ngắn gọn nội dung bài viết..." class="w-full px-5 py-4 bg-slate-50 border-none rounded-2xl focus:bg-white focus:ring-2 focus:ring-orange-500 outline-none transition-all resize-none"></textarea>
          </div>

          <div class="space-y-2">
            <label class="text-xs font-bold text-slate-500 uppercase ml-1">Nội dung chi tiết *</label>
            <textarea name="content" id="full-editor"></textarea>
          </div>
        </div>
      </div>

      <div class="lg:col-span-4 space-y-6">
        <div class="bg-white p-8 rounded-[2.5rem] border border-slate-100 shadow-sm space-y-8 sticky top-24">
          
          <div class="space-y-4">
            <div class="flex justify-between items-end ml-1">
                <label class="text-xs font-bold text-slate-500 uppercase">Ảnh đại diện (Thumbnail)</label>
                <span id="file-name" class="text-[10px] text-orange-600 font-bold truncate max-w-[150px]"></span>
            </div>
            
            <div class="aspect-video rounded-3xl bg-slate-50 border-2 border-dashed border-slate-200 overflow-hidden relative group transition-all hover:border-orange-400 hover:bg-orange-50/30">
                <img id="previewThumb" src="" class="w-full h-full object-cover hidden z-10 relative" />
                
                <div id="placeholderThumb" class="absolute inset-0 flex flex-col items-center justify-center text-slate-400 z-0">
                    <div class="w-12 h-12 bg-white rounded-2xl shadow-sm flex items-center justify-center mb-3 group-hover:scale-110 transition-transform">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-orange-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                        </svg>
                    </div>
                    <span class="text-[10px] font-black uppercase tracking-widest">Tải ảnh lên</span>
                    <p class="text-[9px] mt-1 text-slate-400 italic">Dung lượng tối đa 2MB</p>
                </div>

                <input type="file" name="image" id="thumbInput" required class="absolute inset-0 opacity-0 cursor-pointer z-20" accept="image/*" />
                
                <div id="changePhotoOverlay" class="absolute inset-0 bg-black/40 items-center justify-center text-white text-xs font-bold opacity-0 group-hover:opacity-100 transition-opacity z-30 hidden">
                    Thay đổi ảnh
                </div>
            </div>
          </div>

          <div class="space-y-2">
            <label class="text-xs font-bold text-slate-500 uppercase ml-1">Chuyên mục</label>
            <select name="category" class="w-full bg-slate-50 border-none rounded-2xl py-4 px-5 font-bold text-slate-700 outline-none ring-1 ring-slate-100 focus:ring-2 focus:ring-orange-500 transition-all appearance-none cursor-pointer">
                <option value="thi-truong">Tin tức thị trường</option>
                <option value="tien-do">Tiến độ công trình</option>
            </select>
          </div>

          <div class="space-y-2">
            <label class="text-xs font-bold text-slate-500 uppercase ml-1">Trạng thái</label>
            <select name="status" class="w-full bg-slate-50 border-none rounded-2xl py-4 px-5 font-bold text-slate-700 outline-none ring-1 ring-slate-100 focus:ring-2 focus:ring-orange-500 transition-all appearance-none cursor-pointer">
                <option value="published">Xuất bản ngay</option>
                <option value="draft">Lưu bản nháp</option>
            </select>
          </div>

          <div class="pt-4">
            <button type="submit" class="w-full py-4 bg-orange-600 text-white rounded-2xl font-black shadow-xl shadow-orange-600/30 hover:bg-orange-700 hover:-translate-y-1 transition-all active:scale-95 flex items-center justify-center gap-3">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" /></svg>
              Đăng bài viết
            </button>
          </div>
        </div>
      </div>
    </form>
  </div>
</AdminLayout>

<style is:global>
  .tox-tinymce {
    border: none !important;
    border-radius: 1.5rem !important;
    background-color: #f8fafc !important;
    overflow: hidden;
  }
  .tox .tox-edit-area__iframe { background-color: #f8fafc !important; }
</style>

<script>
  import { checkAdminAuth } from '../../../lib/auth'
  import Swal from 'sweetalert2';

  checkAdminAuth();

  declare var tinymce: any;

  // 🔥 ĐỒNG BỘ: Đổi về cổng máy chủ Laravel chuẩn bảo mật
  const BACKEND_URL = 'http://127.0.0.1:8000';
  
  tinymce.init({
    selector: '#full-editor',
    height: 500,
    language: 'vi',
    plugins: 'preview searchreplace autolink directionality code visualblocks visualchars fullscreen image link media codesample table charmap pagebreak nonbreaking anchor insertdatetime advlist lists wordcount help emoticons',
    toolbar: 'undo redo | bold italic underline strikethrough | fontfamily fontsize blocks | alignleft aligncenter alignright alignjustify | outdent indent |  numlist bullist | forecolor backcolor removeformat | charmap emoticons | fullscreen preview | image media link codesample',
    content_style: 'body { font-family: "Plus Jakarta Sans", sans-serif; font-size: 16px; color: #1e293b; line-height: 1.6; }',
    image_title: true,
    automatic_uploads: true,
    file_picker_types: 'image',
    file_picker_callback: (cb: any) => {
      const input = document.createElement('input');
      input.setAttribute('type', 'file');
      input.setAttribute('accept', 'image/*');
      input.onchange = function (this: any) {
        const file = this.files[0];
        const reader = new FileReader();
        reader.onload = function () {
          const id = 'blobid' + (new Date()).getTime();
          const blobCache =  tinymce.activeEditor.editorUpload.blobCache;
          const result = reader.result as string;
          const base64 = result.split(',')[1];
          const blobInfo = blobCache.create(id, file, base64);
          blobCache.add(blobInfo);
          cb(blobInfo.blobUri(), { title: file.name });
        };
        reader.readAsDataURL(file);
      };
      input.click();
    },
    setup: (editor: any) => { editor.on('change', () => editor.save()); }
  });

  const form = document.getElementById('addPostForm') as HTMLFormElement;
  const titleInput = document.getElementById('title') as HTMLInputElement;
  const slugInput = document.getElementById('slug') as HTMLInputElement;
  const thumbInput = document.getElementById('thumbInput') as HTMLInputElement;
  const previewImg = document.getElementById('previewThumb') as HTMLImageElement;
  const placeholder = document.getElementById('placeholderThumb') as HTMLElement;
  const fileNameDisplay = document.getElementById('file-name') as HTMLElement;
  const changeOverlay = document.getElementById('changePhotoOverlay') as HTMLElement;

  function toSlug(str: string) {
    str = str.toLowerCase().trim();
    str = str.normalize('NFD').replace(/[\u0300-\u036f]/g, '');
    str = str.replace(/[đĐ]/g, 'd');
    str = str.replace(/([^0-9a-z-\s])/g, '');
    str = str.replace(/(\s+)/g, '-');
    str = str.replace(/-+/g, '-');
    str = str.replace(/^-+|-+$/g, '');
    return str;
  }

  titleInput.addEventListener('input', (e: any) => {
    slugInput.value = toSlug(e.target.value);
  });

  thumbInput.addEventListener('change', function(e: any) {
    if (e.target.files && e.target.files[0]) {
      const file = e.target.files[0];
      fileNameDisplay.textContent = file.name;
      const reader = new FileReader();
      reader.onload = (event: any) => {
        previewImg.src = event.target.result;
        previewImg.classList.remove('hidden');
        placeholder.classList.add('hidden');
        changeOverlay.classList.remove('hidden');
        changeOverlay.classList.add('flex');
      };
      reader.readAsDataURL(file);
    }
  });

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    tinymce.triggerSave();

    // 🔒 BẢO MẬT: Làm sạch Token khỏi dấu nháy rác từ localStorage trước khi đóng gói
    const rawToken = localStorage.getItem('admin_token');
    const token = rawToken ? rawToken.replace(/['"]+/g, '').trim() : '';
    const formData = new FormData(form);

    Swal.fire({ title: 'Đang xử lý...', didOpen: () => Swal.showLoading(), allowOutsideClick: false });

    try {
      // ĐỒNG BỘ: Đổi endpoint chuẩn xác về cụm router bảo mật của Laravel (/api/admin/posts)
      const res = await fetch(`${BACKEND_URL}/api/admin/posts`, {
        method: 'POST',
        headers: { 
          'Authorization': `Bearer ${token}`,
          'Accept': 'application/json' // Ép trả dữ liệu dạng JSON thay vì HTML lỗi
        },
        body: formData
      });
      
      const data = await res.json();
      
      if (res.ok && data.success) {
        await Swal.fire({ icon: 'success', title: 'Thành công', text: 'Đã đăng bài viết thành công!', timer: 1500, showConfirmButton: false });
        window.location.href = '/admin/posts';
      } else {
        // 🔒 BẢO MẬT ĐA TẦNG: Bóc tách chính xác mảng thông báo lỗi chi tiết từ Validator Laravel nếu có
        if (data.errors) {
          const errorMsgs = Object.values(data.errors).flat().join('<br>');
          Swal.fire({ icon: 'error', title: 'Lỗi xác thực', html: errorMsgs });
        } else {
          Swal.fire({ icon: 'error', title: 'Thất bại', text: data.message || 'Có lỗi xảy ra trong quá trình đăng bài.' });
        }
      }
    } catch (err) {
      console.error("Lỗi Submit Add Post:", err);
      Swal.fire('Lỗi hệ thống', 'Không thể kết nối đến máy chủ Laravel API. Vui lòng kiểm tra terminal php artisan serve.', 'error');
    }
  });
</script>