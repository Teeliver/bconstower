---
import AdminLayout from '../../../layouts/AdminLayout.astro';
---

<AdminLayout title="Chỉnh sửa căn hộ Bcons">
  <div id="apartment-meta" class="hidden"></div>

  <script is:inline src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

  <div class="max-w-full mx-auto py-2 px-2">
    <div class="mb-8 flex justify-between items-end">
      <div>
        <h1 class="text-3xl font-black text-slate-900">Chỉnh Sửa Căn Hộ</h1>
        <p class="text-slate-500">Cập nhật thông tin cho mã căn: <span id="apartmentIdDisplay" class="font-mono text-orange-600 font-bold">...</span></p>
      </div>
      <a href="/admin/apartments" class="text-slate-400 hover:text-slate-900 font-bold flex items-center gap-2 mb-1 transition-all">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7 7-7-7" /></svg>
        QUAY LẠI
      </a>
    </div>

    <form id="editApartmentForm" class="grid grid-cols-1 lg:grid-cols-3 gap-8" enctype="multipart/form-data">
      <div class="lg:col-span-2 space-y-6">
        <div class="bg-white p-8 rounded-[2.5rem] shadow-sm border border-slate-100 space-y-6">
          <h3 class="text-xl font-bold text-slate-800 border-b pb-4">1. Thông tin cơ bản</h3>
          
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <label class="block text-sm font-bold text-slate-700 mb-2">Tên căn hộ/Mã căn <span class="text-red-500">*</span></label>
              <input type="text" name="name" id="nameInput" required class="w-full px-5 py-4 bg-slate-50 border-2 border-transparent rounded-2xl focus:border-orange-500 focus:bg-white outline-none transition">
            </div>
            <div>
              <label class="block text-sm font-bold text-slate-700 mb-2">Slug SEO</label>
              <input type="text" name="slug" id="slugInput" readonly class="w-full px-5 py-4 bg-slate-100 border-2 border-transparent rounded-2xl text-slate-400 outline-none font-mono text-sm">
            </div>
          </div>

          <div>
            <label class="block text-sm font-bold text-slate-700 mb-2">Mô tả ngắn</label>
            <textarea name="description" id="descriptionInput" rows="4" class="w-full px-5 py-4 bg-slate-50 border-2 border-transparent rounded-2xl focus:border-orange-500 outline-none transition"></textarea>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <div>
              <label class="block text-sm font-bold text-slate-700 mb-2">Diện tích (m²)</label>
              <input type="text" name="area" id="areaInput" class="w-full px-5 py-4 bg-slate-50 border-2 border-transparent rounded-2xl focus:border-orange-500 outline-none transition">
            </div>
            <div>
              <label class="block text-sm font-bold text-slate-700 mb-2">Số Tầng</label>
              <input type="number" name="floor" id="floorInput" class="w-full px-5 py-4 bg-slate-50 border-2 border-transparent rounded-2xl focus:border-orange-500 outline-none transition">
            </div>
            <div>
              <label class="block text-sm font-bold text-slate-700 mb-2">Block/Tháp</label>
              <input type="text" name="block" id="blockInput" class="w-full px-5 py-4 bg-slate-50 border-2 border-transparent rounded-2xl focus:border-orange-500 outline-none transition">
            </div>
          </div>
        </div>

        <div class="bg-white p-8 rounded-[2.5rem] shadow-sm border border-slate-100 space-y-6">
          <h3 class="text-xl font-bold text-slate-800 border-b pb-4">2. Đặc điểm kỹ thuật</h3>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <label class="block text-sm font-bold text-slate-700 mb-2">Phòng Ngủ</label>
              <input type="number" name="bedrooms" id="bedroomsInput" class="w-full px-5 py-4 bg-slate-50 border-2 border-transparent rounded-2xl focus:border-orange-500 outline-none transition">
            </div>
            <div>
              <label class="block text-sm font-bold text-slate-700 mb-2">Phòng Vệ Sinh</label>
              <input type="number" name="bathrooms" id="bathroomsInput" class="w-full px-5 py-4 bg-slate-50 border-2 border-transparent rounded-2xl focus:border-orange-500 outline-none transition">
            </div>

            <div class="relative dropdown-container" id="dropdown-directionMain">
              <label class="block text-sm font-bold text-slate-700 mb-2 ml-1">Hướng cửa chính</label>
              <input type="hidden" name="directionMain" id="directionMainInput" value="Đông">
              <button type="button" class="drop-btn w-full px-6 py-4 bg-slate-50 border-2 border-transparent rounded-2xl flex items-center justify-between font-medium hover:bg-slate-100 transition-all focus:border-orange-500 outline-none shadow-sm">
                <span class="selected-text">Đông</span>
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-slate-400 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </button>
              <div class="drop-menu absolute z-20 w-full mt-2 bg-white rounded-2xl shadow-2xl border border-slate-100 opacity-0 invisible -translate-y-2 transition-all duration-300">
                <div class="p-2 space-y-1">
                  {["Đông", "Tây", "Nam", "Bắc", "Đông Nam", "Đông Bắc", "Tây Nam", "Tây Bắc"].map((dir) => (
                    <div data-value={dir} class="option-item flex items-center gap-3 px-4 py-3 rounded-xl hover:bg-orange-50 hover:text-orange-700 cursor-pointer">
                      <span>{dir}</span>
                    </div>
                  ))}
                </div>
              </div>
            </div>

            <div class="relative dropdown-container" id="dropdown-directionBalcony">
              <label class="block text-sm font-bold text-slate-700 mb-2 ml-1">Hướng ban công</label>
              <input type="hidden" name="directionBalcony" id="directionBalconyInput" value="Nam">
              <button type="button" class="drop-btn w-full px-6 py-4 bg-slate-50 border-2 border-transparent rounded-2xl flex items-center justify-between font-medium hover:bg-slate-100 transition-all focus:border-orange-500 outline-none shadow-sm">
                <span class="selected-text">Nam</span>
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-slate-400 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </button>
              <div class="drop-menu absolute z-20 w-full mt-2 bg-white rounded-2xl shadow-2xl border border-slate-100 opacity-0 invisible -translate-y-2 transition-all duration-300">
                <div class="p-2 space-y-1">
                  {["Nam", "Bắc", "Đông", "Tây"].map((dir) => (
                    <div data-value={dir} class="option-item flex items-center gap-3 px-4 py-3 rounded-xl hover:bg-orange-50 hover:text-orange-700 cursor-pointer">
                      <span>{dir}</span>
                    </div>
                  ))}
                </div>
              </div>
            </div>
          </div>
        </div>
        <button type="submit" id="submitBtn" class="w-full bg-orange-500 hover:bg-slate-900 text-white font-black py-5 rounded-2xl shadow-xl transition-all active:scale-95 shadow-orange-200">
          CẬP NHẬT THÔNG TIN
        </button>
      </div>

      <div class="space-y-6">
        <div class="bg-white p-8 rounded-[2.5rem] shadow-sm border border-slate-100 space-y-6">
            <h3 class="text-xl font-bold text-slate-800 border-b pb-4">4. Trạng thái hiển thị</h3>
            <div class="relative dropdown-container" id="dropdown-status">
                <label class="block text-sm font-bold text-slate-700 mb-2 ml-1">Trạng thái duyệt</label>
                <input type="hidden" name="approvalStatus" id="statusInput" value="pending">
                <button type="button" class="drop-btn w-full px-6 py-4 bg-slate-50 border-2 border-transparent rounded-2xl flex items-center justify-between font-medium hover:bg-slate-100 transition-all focus:border-orange-500 outline-none shadow-sm">
                  <span class="selected-text flex items-center gap-2">⏳ Chờ duyệt</span>
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-slate-400 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                  </svg>
                </button>
                <div class="drop-menu absolute z-20 w-full mt-2 bg-white rounded-2xl shadow-2xl border border-slate-100 opacity-0 invisible -translate-y-2 transition-all duration-300">
                  <div class="p-2 space-y-1">
                    <div data-value="pending" class="option-item flex items-center gap-2 px-4 py-3 rounded-xl hover:bg-yellow-50 hover:text-yellow-700 cursor-pointer transition-all">
                      <span>⏳ Chờ duyệt</span>
                    </div>
                    <div data-value="approved" class="option-item flex items-center gap-2 px-4 py-3 rounded-xl hover:bg-green-50 hover:text-green-700 cursor-pointer transition-all">
                      <span>✅ Đã duyệt</span>
                    </div>
                    <div data-value="rejected" class="option-item flex items-center gap-2 px-4 py-3 rounded-xl hover:bg-red-50 hover:text-red-700 cursor-pointer transition-all">
                      <span>❌ Từ chối</span>
                    </div>
                  </div>
                </div>
            </div>

            <div class="relative dropdown-container" id="dropdown-sale-status">
              <label class="block text-sm font-bold text-slate-700 mb-2 ml-1">Trạng thái bán</label>
              <input type="hidden" name="status" id="saleStatusInput" value="trong">
              <button type="button" class="drop-btn w-full px-6 py-4 bg-slate-50 border-2 border-transparent rounded-2xl flex items-center justify-between font-medium hover:bg-slate-100 transition-all focus:border-orange-500 outline-none shadow-sm">
                <span class="selected-text flex items-center gap-2">🏠 Còn trống</span>
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-slate-400 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </button>
              <div class="drop-menu absolute z-20 w-full mt-2 bg-white rounded-2xl shadow-2xl border border-slate-100 opacity-0 invisible -translate-y-2 transition-all duration-300">
                <div class="p-2 space-y-1">
                  <div data-value="trong" class="option-item flex items-center gap-2 px-4 py-3 rounded-xl hover:bg-blue-50 hover:text-blue-700 cursor-pointer transition-all">
                    <span>🏠 Còn trống</span>
                  </div>
                  <div data-value="da_coc" class="option-item flex items-center gap-2 px-4 py-3 rounded-xl hover:bg-orange-50 hover:text-orange-700 cursor-pointer transition-all">
                    <span>💰 Đã cọc</span>
                  </div>
                  <div data-value="da_ban" class="option-item flex items-center gap-2 px-4 py-3 rounded-xl hover:bg-green-50 hover:text-green-700 cursor-pointer transition-all">
                    <span>🤝 Đã bán</span>
                  </div>
                </div>
              </div>
            </div>
        </div>

        <div class="bg-white p-8 rounded-[2.5rem] shadow-sm border border-slate-100 space-y-6">
          <h3 class="text-xl font-bold text-slate-800 border-b pb-4">3. Phân loại & Ảnh</h3>
          
          <div class="relative dropdown-container" id="dropdown-project">
            <label class="block text-sm font-bold text-slate-700 mb-2 ml-1">Thuộc Dự Án <span class="text-red-500">*</span></label>
            <input type="hidden" name="projectId" id="projectIdInput" required>
            <button type="button" class="drop-btn w-full px-6 py-4 bg-slate-50 border-2 border-transparent rounded-2xl flex items-center justify-between font-medium hover:bg-slate-100 transition-all focus:border-orange-500 outline-none shadow-sm">
              <span class="selected-text">Đang tải...</span>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-slate-400 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </button>
            <div class="drop-menu absolute z-20 w-full mt-2 bg-white rounded-2xl shadow-2xl border border-slate-100 opacity-0 invisible -translate-y-2 transition-all duration-300 max-h-64 overflow-y-auto">
              <div class="p-2 space-y-1" id="projectOptionsList"></div>
            </div>
          </div>

          <div>
            <label class="block text-sm font-bold text-slate-700 mb-2 ml-1">Giá bán (VNĐ) <span class="text-red-500">*</span></label>
            <input type="number" name="price" id="priceInput" required class="w-full px-5 py-4 bg-slate-50 border-2 border-transparent rounded-2xl focus:border-orange-500 outline-none transition font-bold text-orange-600">
          </div>

          <div class="relative dropdown-container" id="dropdown-furniture">
            <label class="block text-sm font-bold text-slate-700 mb-2 ml-1">Nội thất</label>
            <input type="hidden" name="furniture" id="furnitureInput" value="Cơ bản">
            <button type="button" class="drop-btn w-full px-6 py-4 bg-slate-50 border-2 border-transparent rounded-2xl flex items-center justify-between font-medium hover:bg-slate-100 transition-all focus:border-orange-500 outline-none shadow-sm">
              <span class="selected-text">Bàn giao cơ bản</span>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-slate-400 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </button>
            <div class="drop-menu absolute z-20 w-full mt-2 bg-white rounded-2xl shadow-2xl border border-slate-100 opacity-0 invisible -translate-y-2 transition-all duration-300">
              <div class="p-2 space-y-1">
                <div data-value="Cơ bản" class="option-item flex items-center gap-3 px-4 py-3 rounded-xl hover:bg-orange-50 hover:text-orange-700 cursor-pointer"><span>Bàn giao cơ bản</span></div>
                <div data-value="Đầy đủ" class="option-item flex items-center gap-3 px-4 py-3 rounded-xl hover:bg-orange-50 hover:text-orange-700 cursor-pointer"><span>Đầy đủ nội thất</span></div>
                <div data-value="Thô" class="option-item flex items-center gap-3 px-4 py-3 rounded-xl hover:bg-orange-50 hover:text-orange-700 cursor-pointer"><span>Giao thô</span></div>
              </div>
            </div>
          </div>

          <div>
            <label class="block text-sm font-bold text-slate-700 mb-2 ml-1">Hình ảnh mới</label>
            <div class="relative group border-2 border-dashed border-slate-200 rounded-2xl p-4 text-center hover:border-orange-500 transition-all bg-slate-50">
              <input type="file" name="images[]" id="imageInput" accept="image/*" multiple class="absolute inset-0 w-full h-full opacity-0 cursor-pointer z-10" />
              <div class="space-y-1">
                <div class="text-2xl">📸</div>
                <p class="text-xs text-slate-500 font-medium">Thay đổi dàn ảnh</p>
              </div>
            </div>
            
            <div id="imagePreview" class="grid grid-cols-4 gap-2 mt-3"></div>
          </div>
        </div>
      </div>
    </form>
  </div>
</AdminLayout>

<style>
  .dropdown-container.active .drop-menu { opacity: 1; visibility: visible; transform: translateY(0); }
  .dropdown-container.active .drop-btn svg { transform: rotate(180deg); }
</style>

<script>
  import Swal from 'sweetalert2';
  import { checkAdminAuth } from '../../../lib/auth';

  checkAdminAuth();

  const API_BASE = import.meta.env.PUBLIC_API_BASE || 'http://localhost:8000';

  const escapeHTML = (val: any): string => {
    if (val === null || val === undefined) return '';
    const str = String(val);
    return str.replace(/[&<>"']/g, (match) => {
      const map: Record<string, string> = {
        '&': '&amp;',
        '<': '&lt;',
        '>': '&gt;',
        '"': '&quot;',
        "'": '&#39;'
      };
      return map[match] || match;
    });
  };

  window.addEventListener('DOMContentLoaded', async () => {
    const form = document.getElementById('editApartmentForm') as HTMLFormElement;
    const nameInput = document.getElementById('nameInput') as HTMLInputElement;
    const slugInput = document.getElementById('slugInput') as HTMLInputElement;
    const imageInput = document.getElementById('imageInput') as HTMLInputElement;
    const imagePreview = document.getElementById('imagePreview');
    
    const urlParams = new URLSearchParams(window.location.search);
    const apartmentId = urlParams.get('id');

    const idDisplay = document.getElementById('apartmentIdDisplay');
    if (idDisplay && apartmentId) {
      idDisplay.textContent = apartmentId;
    }

    if (!apartmentId) {
      Swal.fire({
        icon: 'error',
        title: 'Thiếu mã căn hộ',
        text: 'Không tìm thấy tham số ID căn hộ hợp lệ trên URL!',
        confirmButtonColor: '#ef4444'
      }).then(() => {
        window.location.href = '/admin/apartments';
      });
      return;
    }

    function setupCustomDropdown(containerId: string) {
      const container = document.getElementById(containerId);
      if (!container) return;
      const dropBtn = container.querySelector('.drop-btn') as HTMLButtonElement;
      const hiddenInput = container.querySelector('input[type="hidden"]') as HTMLInputElement;
      const selectedText = container.querySelector('.selected-text');

      dropBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        document.querySelectorAll('.dropdown-container').forEach(el => el !== container && el.classList.remove('active'));
        container.classList.toggle('active');
      });

      container.addEventListener('click', (e) => {
        const optionItem = (e.target as HTMLElement).closest('.option-item');
        if (optionItem) {
          const val = optionItem.getAttribute('data-value');
          if (val && hiddenInput) hiddenInput.value = val;
          if (selectedText) selectedText.innerHTML = optionItem.innerHTML;
          container.classList.remove('active');
        }
      });
    }

    async function loadApartmentDetail() {
      if (!apartmentId) return;
      const token = localStorage.getItem('admin_token')?.replace(/['"]+/g, '').trim();

      try {
        Swal.fire({ title: 'Đang tải thông tin...', allowOutsideClick: false, didOpen: () => Swal.showLoading() });
        
        const res = await fetch(`${API_BASE}/api/admin/apartments/${apartmentId}`, {
          method: 'GET',
          headers: {
            'Authorization': `Bearer ${token}`,
            'Accept': 'application/json'
          }
        });

        if (res.status === 401 || res.status === 403) {
          localStorage.clear();
          window.location.replace('/admin');
          return;
        }

        if (!res.ok) throw new Error("Không tìm thấy thông tin căn hộ này trong Database Laravel");
        
        const data = await res.json();

        nameInput.value = data.name || '';
        slugInput.value = data.slug || '';
        (document.getElementById('descriptionInput') as HTMLTextAreaElement).value = data.description || '';
        (document.getElementById('areaInput') as HTMLInputElement).value = data.area || '';
        (document.getElementById('floorInput') as HTMLInputElement).value = data.floor || 0;
        (document.getElementById('blockInput') as HTMLInputElement).value = data.block || '';
        (document.getElementById('bedroomsInput') as HTMLInputElement).value = data.bedrooms || data.rooms || 0;
        (document.getElementById('bathroomsInput') as HTMLInputElement).value = data.bathrooms || 0;
        (document.getElementById('priceInput') as HTMLInputElement).value = data.price || 0;
        
        (document.getElementById('directionMainInput') as HTMLInputElement).value = data.direction_main || data.directionMain || 'Đông';
        (document.getElementById('directionBalconyInput') as HTMLInputElement).value = data.direction_balcony || data.directionBalcony || 'Nam';
        (document.getElementById('statusInput') as HTMLInputElement).value = data.approval_status || data.approvalStatus || 'pending';
        (document.getElementById('saleStatusInput') as HTMLInputElement).value = data.status || 'trong';
        (document.getElementById('furnitureInput') as HTMLInputElement).value = data.furniture || 'Cơ bản';
        (document.getElementById('projectIdInput') as HTMLInputElement).value = data.project_id || data.projectId || '';

        document.querySelector('#dropdown-directionMain .selected-text')!.innerHTML = (document.getElementById('directionMainInput') as HTMLInputElement).value;
        document.querySelector('#dropdown-directionBalcony .selected-text')!.innerHTML = (document.getElementById('directionBalconyInput') as HTMLInputElement).value;
        
        const furn = (document.getElementById('furnitureInput') as HTMLInputElement).value;
        document.querySelector('#dropdown-furniture .selected-text')!.innerHTML = furn === "Đầy đủ" ? "Đầy đủ nội thất" : furn === "Thô" ? "Giao thô" : "Bàn giao cơ bản";

        const appStatus = (document.getElementById('statusInput') as HTMLInputElement).value;
        document.querySelector('#dropdown-status .selected-text')!.innerHTML = appStatus === 'approved' ? '✅ Đã duyệt' : appStatus === 'rejected' ? '❌ Từ chối' : '⏳ Chờ duyệt';

        const saleStatus = (document.getElementById('saleStatusInput') as HTMLInputElement).value;
        document.querySelector('#dropdown-sale-status .selected-text')!.innerHTML = saleStatus === 'da_ban' ? '🤝 Đã bán' : saleStatus === 'da_coc' ? '💰 Đã cọc' : '🏠 Còn trống';

        await loadProjects();

        const rawImage = data.image || data.image_url;
        if (rawImage && imagePreview) {
          let oldImages: string[] = [];
          try {
            oldImages = typeof rawImage === 'string' ? JSON.parse(rawImage) : rawImage;
            if (!Array.isArray(oldImages)) oldImages = [rawImage];
          } catch {
            oldImages = [String(rawImage).replace(/[\[\]"\\ ]/g, '')];
          }

          imagePreview.innerHTML = oldImages.map(img => `
            <div class="aspect-square rounded-lg border border-slate-200 overflow-hidden shadow-sm relative group">
              <img src="${img.startsWith('http') ? img : API_BASE + (img.startsWith('/') ? img : '/' + img)}" class="w-full h-full object-cover" onerror="this.src='https://placehold.co/100x100?text=Error'"/>
              <div class="absolute inset-0 bg-black/40 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity">
                <span class="text-[8px] text-white font-bold uppercase">Ảnh cũ</span>
              </div>
            </div>
          `).join('');
        }

        Swal.close();
      } catch (err: any) {
        Swal.fire({ icon: 'error', title: 'Lỗi nạp thông tin', text: err.message, confirmButtonColor: '#ea580c' });
      }
    }

    async function loadProjects() {
      const optionsList = document.getElementById('projectOptionsList');
      const selectedText = document.querySelector('#dropdown-project .selected-text');
      const currentId = (document.getElementById('projectIdInput') as HTMLInputElement).value;
      const token = localStorage.getItem('admin_token')?.replace(/['"]+/g, '').trim();

      try {
        const res = await fetch(`${API_BASE}/api/admin/projects`, {
          method: 'GET',
          headers: { 'Authorization': `Bearer ${token}`, 'Accept': 'application/json' }
        });
        const data = await res.json();
        const projectArray = Array.isArray(data) ? data : (data.data || []);

        if (Array.isArray(projectArray) && optionsList) {
          optionsList.innerHTML = '';
          projectArray.forEach(p => {
            const isSelected = p.id.toString() === String(currentId);
            if (isSelected && selectedText) selectedText.textContent = p.title || p.name;

            const optItem = document.createElement('div');
            optItem.className = "option-item flex items-center gap-3 px-4 py-3 rounded-xl hover:bg-orange-50 hover:text-orange-700 cursor-pointer transition-all font-medium";
            optItem.setAttribute('data-value', p.id);
            optItem.innerHTML = `<span>${escapeHTML(p.title || p.name)}</span>`;
            optionsList.appendChild(optItem);
          });
        }
      } catch (err) { console.error("Lỗi đồng bộ danh mục dự án Bcons"); }
    }

    imageInput?.addEventListener('change', () => {
      if (!imagePreview || !imageInput.files?.length) return;
      imagePreview.innerHTML = '';
      Array.from(imageInput.files).forEach(file => {
        const reader = new FileReader();
        reader.onload = (e) => {
          const div = document.createElement('div');
          div.className = "aspect-square rounded-lg border-2 border-orange-400 overflow-hidden shadow-sm";
          div.innerHTML = `<img src="${e.target?.result}" class="w-full h-full object-cover" />`;
          imagePreview.appendChild(div);
        };
        reader.readAsDataURL(file);
      });
    });

    // 🔥 ĐÃ SỬA: Bọc hàm ép chữ đ/Đ thành d thủ công trước khi lọc dấu giống như file add.astro
    nameInput?.addEventListener('input', () => {
      let value = nameInput.value.toLowerCase();
      value = value.replace(/đ/g, 'd'); // Ép ký tự đ chuyển hóa thành d an toàn
      
      slugInput.value = value.normalize('NFD')
        .replace(/[\u0300-\u036f]/g, '') // Khử sạch dấu mũ tiếng Việt lẻ
        .replace(/[^\w\s-]/g, '')        // Chỉ cho phép ký tự la-tinh, số và khoảng trắng
        .replace(/\s+/g, '-')            // Chuyển khoảng trắng thành gạch ngang
        .replace(/-+/g, '-')             // Gom các dấu gạch ngang liền nhau thành 1
        .trim();
    });

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();

      const submitBtn = document.getElementById('submitBtn') as HTMLButtonElement;

      if (imageInput.files && imageInput.files.length > 0) {
        const allowedTypes = ['image/jpeg', 'image/png', 'image/webp', 'image/jpg'];
        
        for (let i = 0; i < imageInput.files.length; i++) {
          const file = imageInput.files[i];
          
          if (file.size > 5 * 1024 * 1024) {
            Swal.fire({ icon: 'error', title: 'Tệp quá lớn', text: `Hình ảnh "${file.name}" vượt quá mốc 5MB!`, confirmButtonColor: '#ef4444' });
            return;
          }
          
          if (!allowedTypes.includes(file.type)) {
            Swal.fire({ icon: 'error', title: 'Sai định dạng', text: `Hệ thống không chấp nhận định dạng tệp của "${file.name}"!`, confirmButtonColor: '#ef4444' });
            return;
          }
        }
      }

      Swal.fire({ title: 'Đang lưu...', allowOutsideClick: false, didOpen: () => Swal.showLoading() });
      if (submitBtn) submitBtn.disabled = true;

      const formData = new FormData(form);
      
      if (imageInput.files?.length === 0) {
        formData.delete('images[]');
      }

      formData.append('_method', 'PUT');
      
      const projectIdVal = (document.getElementById('projectIdInput') as HTMLInputElement).value;
      formData.append('project_id', projectIdVal);

      const token = localStorage.getItem('admin_token')?.replace(/['"]+/g, '').trim();

      try {
        const res = await fetch(`${API_BASE}/api/admin/apartments/${apartmentId}`, {
          method: 'POST', 
          headers: {
            'Authorization': `Bearer ${token}`,
            'Accept': 'application/json'
          },
          body: formData
        });

        if (res.status === 401 || res.status === 403) {
          throw new Error("Phiên làm việc hết hạn hoặc bạn không có quyền chỉnh sửa căn hộ này!");
        }

        const result = await res.json();

        if (res.ok && result.success) {
          await Swal.fire({ icon: 'success', title: 'Đã cập nhật!', timer: 1500, showConfirmButton: false });
          window.location.href = '/admin/apartments';
        } else {
          throw new Error(result.message || 'Lỗi không rõ nguyên nhân từ hệ thống Laravel');
        }
      } catch (err: any) { 
        Swal.fire('Lỗi cập nhật', err.message || 'Mất kết nối máy chủ', 'error'); 
      } finally {
        if (submitBtn) submitBtn.disabled = false;
      }
    });

    window.addEventListener('click', () => document.querySelectorAll('.dropdown-container').forEach(el => el.classList.remove('active')));

    setupCustomDropdown('dropdown-directionMain');
    setupCustomDropdown('dropdown-directionBalcony');
    setupCustomDropdown('dropdown-furniture');
    setupCustomDropdown('dropdown-project');
    setupCustomDropdown('dropdown-status'); 
    setupCustomDropdown('dropdown-sale-status');
    
    loadApartmentDetail();
  });
</script>