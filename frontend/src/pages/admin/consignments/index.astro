---
// src/pages/admin/consignments/index.astro
import AdminLayout from '../../../layouts/AdminLayout.astro';

const API_BASE = import.meta.env.PUBLIC_API_BASE || 'http://localhost:8000';
---

<AdminLayout title="Quản lý ký gửi căn hộ">
    <div class="flex justify-between items-center mb-8">
      <div>
        <h1 class="text-2xl font-black text-slate-900 uppercase">Quản lý ký gửi</h1>
        <p class="text-slate-500">Danh sách chủ nhà gửi bán và cho thuê thuộc chuỗi dự án Bcons</p>
      </div>
      <div class="bg-[#fac72e] text-black border border-orange-100 px-6 py-3 rounded-2xl font-medium shadow-sm flex items-center gap-1 text-sm">
        <svg class="w-6 h-6" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" version="1.1" width="256" height="256" viewBox="0 0 256 256" xml:space="preserve">
          <g style="stroke: none; stroke-width: 0; stroke-dasharray: none; stroke-linecap: butt; stroke-linejoin: miter; stroke-miterlimit: 10; fill: none; fill-rule: nonzero; opacity: 1;" transform="translate(1.4065934065934016 1.4065934065934016) scale(2.81 2.81)">
            <path d="M 40.345 69.936 H 6.4 c -3.53 0 -6.402 -2.872 -6.402 -6.402 V 16.61 c 0 -3.53 2.872 -6.402 6.402 -6.402 h 67.89 c 3.53 0 6.403 2.872 6.403 6.402 v 6.753 c 0 1.105 -0.896 2 -2 2 s -2 -0.896 -2 -2 V 16.61 c 0 -1.324 -1.078 -2.402 -2.402 -2.402 H 6.4 c -1.324 0 -2.402 1.078 -2.402 2.402 v 46.924 c 0 1.324 1.078 2.401 2.402 2.401 h 33.945 c 1.105 0 2 0.896 2 2 S 41.45 69.936 40.345 69.936 z" style="stroke: none; stroke-width: 1; stroke-dasharray: none; stroke-linecap: butt; stroke-linejoin: miter; stroke-miterlimit: 10; fill: rgb(0,0,0); fill-rule: nonzero; opacity: 1;" transform=" matrix(1 0 0 1 0 0) " stroke-linecap="round"/>
            <path d="M 40.345 50.514 c -0.485 0 -0.97 -0.176 -1.352 -0.526 l -28.155 -25.83 c -0.814 -0.747 -0.869 -2.012 -0.122 -2.826 c 0.747 -0.814 2.013 -0.868 2.826 -0.122 l 26.803 24.589 L 67.148 21.21 c 0.816 -0.748 2.08 -0.692 2.826 0.122 c 0.747 0.814 0.692 2.079 -0.121 2.826 l -28.155 25.83 C 41.315 50.338 40.83 50.514 40.345 50.514 z" style="stroke: none; stroke-width: 1; stroke-dasharray: none; stroke-linecap: butt; stroke-linejoin: miter; stroke-miterlimit: 10; fill: rgb(0,0,0); fill-rule: nonzero; opacity: 1;" transform=" matrix(1 0 0 1 0 0) " stroke-linecap="round"/>
            <path d="M 12.191 61.711 c -0.541 0 -1.08 -0.218 -1.474 -0.648 c -0.747 -0.814 -0.692 -2.079 0.122 -2.825 l 20.18 -18.513 c 0.814 -0.747 2.079 -0.692 2.826 0.122 c 0.747 0.814 0.692 2.079 -0.122 2.826 l -20.18 18.513 C 13.159 61.537 12.674 61.711 12.191 61.711 z" style="stroke: none; stroke-width: 1; stroke-dasharray: none; stroke-linecap: butt; stroke-linejoin: miter; stroke-miterlimit: 10; fill: rgb(0,0,0); fill-rule: nonzero; opacity: 1;" transform=" matrix(1 0 0 1 0 0) " stroke-linecap="round"/>
            <path d="M 54.017 48.424 c -0.482 0 -0.967 -0.174 -1.351 -0.526 l -5.698 -5.226 c -0.814 -0.747 -0.869 -2.012 -0.122 -2.826 c 0.746 -0.813 2.012 -0.87 2.825 -0.122 l 5.698 5.226 c 0.814 0.747 0.869 2.012 0.122 2.825 C 55.097 48.206 54.558 48.424 54.017 48.424 z" style="stroke: none; stroke-width: 1; stroke-dasharray: none; stroke-linecap: butt; stroke-linejoin: miter; stroke-miterlimit: 10; fill: rgb(0,0,0); fill-rule: nonzero; opacity: 1;" transform=" matrix(1 0 0 1 0 0) " stroke-linecap="round"/>
            <path d="M 86.966 30.116 c -1.801 -1.593 -4.121 -2.397 -6.511 -2.241 c -2.4 0.146 -4.597 1.219 -6.189 3.019 L 48.298 60.249 c -0.058 0.065 -0.103 0.138 -0.151 0.21 c -0.021 0.03 -0.045 0.057 -0.064 0.088 c -0.078 0.13 -0.139 0.268 -0.186 0.411 c -0.003 0.009 -0.009 0.017 -0.012 0.026 L 42.88 77.202 c -0.231 0.751 -0.002 1.567 0.586 2.088 c 0.373 0.33 0.846 0.502 1.326 0.502 c 0.277 0 0.556 -0.058 0.818 -0.175 l 15.476 -6.941 c 0 0 0.001 0 0.001 0 l 0.01 -0.005 c 0.013 -0.006 0.024 -0.016 0.037 -0.023 c 0.125 -0.059 0.244 -0.131 0.356 -0.217 c 0.046 -0.035 0.084 -0.076 0.126 -0.115 c 0.053 -0.049 0.111 -0.09 0.16 -0.145 l 25.968 -29.355 C 91.03 39.099 90.682 33.402 86.966 30.116 z M 48.006 74.158 l 2.787 -9.031 l 2.919 2.582 l 2.919 2.582 L 48.006 74.158 z M 84.748 40.166 L 60.105 68.023 l -3.743 -3.311 l -3.743 -3.311 l 24.643 -27.857 c 0.884 -1 2.105 -1.595 3.437 -1.677 c 1.322 -0.082 2.616 0.36 3.616 1.245 C 86.379 34.938 86.573 38.102 84.748 40.166 z" style="stroke: none; stroke-width: 1; stroke-dasharray: none; stroke-linecap: butt; stroke-linejoin: miter; stroke-miterlimit: 10; fill: rgb(0,0,0); fill-rule: nonzero; opacity: 1;" transform=" matrix(1 0 0 1 0 0) " stroke-linecap="round"/>
          </g>
        </svg>
        Ký gửi: <span id="totalConsignments">0</span> hồ sơ
      </div>
    </div>

    <!-- KHỐI THANH BỘ LỌC TÙY BIẾN ĐỘNG (CUSTOM DROPDOWNS TƯƠNG TỰ POSTS) -->
    <div class="bg-white p-6 rounded-[1.5rem] shadow-sm border border-slate-100 mb-6 grid grid-cols-1 md:grid-cols-3 gap-4">
      
      <!-- Dropdown Loại hình (Bán / Thuê) -->
      <div class="relative dropdown-container" id="drop-type">
        <label class="text-[10px] font-bold text-slate-400 uppercase ml-2 mb-1 block">Hình thức ký gửi</label>
        <button type="button" class="drop-btn w-full px-4 py-2.5 bg-slate-50 border border-transparent rounded-xl flex items-center justify-between text-sm font-medium hover:bg-slate-100 transition-all outline-none cursor-pointer">
          <span class="selected-text">Tất cả hình thức</span>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
        </button>
        <input type="hidden" id="filterType" value="all">
        <div class="drop-menu absolute z-50 w-full mt-2 bg-white rounded-2xl shadow-2xl border border-slate-100 opacity-0 invisible -translate-y-2 transition-all duration-300">
          <div class="p-2 space-y-1">
            <div data-value="all" class="option-item px-4 py-2 rounded-lg hover:bg-orange-50 hover:text-orange-600 cursor-pointer text-sm font-bold text-slate-700">Tất cả hình thức</div>
            <div data-value="ban" class="option-item px-4 py-2 rounded-lg hover:bg-orange-50 hover:text-orange-600 cursor-pointer text-sm font-bold text-slate-700">💰 Ký gửi Bán</div>
            <div data-value="cho_thue" class="option-item px-4 py-2 rounded-lg hover:bg-orange-50 hover:text-orange-600 cursor-pointer text-sm font-bold text-slate-700">🔑 Cho thuê</div>
          </div>
        </div>
      </div>

      <!-- Dropdown Trạng thái duyệt hàng -->
      <div class="relative dropdown-container" id="drop-status">
        <label class="text-[10px] font-bold text-slate-400 uppercase ml-2 mb-1 block">Trạng thái giỏ hàng</label>
        <button type="button" class="drop-btn w-full px-4 py-2.5 bg-slate-50 border border-transparent rounded-xl flex items-center justify-between text-sm font-medium hover:bg-slate-100 transition-all outline-none cursor-pointer">
          <span class="selected-text">Tất cả trạng thái</span>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
        </button>
        <input type="hidden" id="filterStatus" value="all">
        <div class="drop-menu absolute z-50 w-full mt-2 bg-white rounded-2xl shadow-2xl border border-slate-100 opacity-0 invisible -translate-y-2 transition-all duration-300">
          <div class="p-2 space-y-1">
            <div data-value="all" class="option-item px-4 py-2 rounded-lg hover:bg-orange-50 hover:text-orange-600 cursor-pointer text-sm font-bold text-slate-700">Tất cả trạng thái</div>
            <div data-value="moi" class="option-item px-4 py-2 rounded-lg hover:bg-orange-50 hover:text-orange-600 cursor-pointer text-sm font-bold text-slate-700">🔵 Mới tiếp nhận</div>
            <div data-value="dang_ra_hang" class="option-item px-4 py-2 rounded-lg hover:bg-orange-50 hover:text-orange-600 cursor-pointer text-sm font-bold text-slate-700">⏳ Đang ra hàng</div>
            <div data-value="da_chot" class="option-item px-4 py-2 rounded-lg hover:bg-orange-50 hover:text-orange-600 cursor-pointer text-sm font-bold text-slate-700">✅ Đã giao dịch thành công</div>
            <div data-value="huy" class="option-item px-4 py-2 rounded-lg hover:bg-orange-50 hover:text-orange-600 cursor-pointer text-sm font-bold text-slate-700">❌ Hủy / Đóng tin</div>
          </div>
        </div>
      </div>

      <!-- Ô Tìm kiếm nhanh -->
      <div>
        <label class="text-[10px] font-bold text-slate-400 uppercase ml-2 mb-1 block">Tìm kiếm thông tin căn</label>
        <input type="text" id="searchInput" placeholder="Tên chủ nhà, SĐT hoặc mã căn..." class="w-full px-4 py-2.5 bg-slate-50 border border-transparent rounded-xl text-sm font-bold focus:bg-white focus:border-orange-500 outline-none transition-all" />
      </div>
    </div>

    <!-- BẢNG THEO DÕI DATA KÝ GỬI CHUẨN LỚP NỀN UI -->
    <div class="bg-white rounded-3xl shadow-sm border border-slate-200 overflow-hidden">
        <table class="w-full text-left">
          <thead class="bg-slate-50 border-b border-slate-200">
            <tr>
              <th class="px-6 py-4 font-bold text-slate-600 text-sm">Chủ sở hữu</th>
              <th class="px-6 py-4 font-bold text-slate-600 text-sm">Dự án & Mã căn</th>
              <th class="px-6 py-4 font-bold text-slate-600 text-sm text-center">Hình thức</th>
              <th class="px-6 py-4 font-bold text-slate-600 text-sm text-center">Giá mong muốn</th>
              <th class="px-6 py-4 font-bold text-slate-600 text-sm text-center">Trạng thái</th>
              <th class="px-6 py-5 font-bold text-slate-600 text-sm text-right">Thao tác</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100" id="consignmentTableBody">
            <tr>
                <td colspan="6" class="p-20 text-center text-slate-400 italic font-medium animate-pulse">Đang kết nối cổng dữ liệu ký gửi Bcons...</td>
            </tr>
          </tbody>
        </table>
        <div id="noResults" class="hidden p-20 text-center text-slate-400 italic bg-white font-medium">
          Không tìm thấy hồ sơ ký gửi nào khớp với bộ lọc điều kiện.
        </div>
    </div>
</AdminLayout>

<style>
  .dropdown-container.active .drop-menu { opacity: 1; visibility: visible; transform: translateY(0); }
  .dropdown-container.active .drop-btn svg { transform: rotate(180deg); }
  .dropdown-container.active .drop-btn { border-color: #ea580c; background-color: #fff; }
</style>

<script>
  import Swal from 'sweetalert2';
  import { checkAdminAuth } from '../../../lib/auth';

  checkAdminAuth();

  const API_BASE = import.meta.env.PUBLIC_API_BASE || 'http://localhost:8000';

  const escapeHTML = (val: any): string => {
    if (val === null || val === undefined) return '';
    return String(val).replace(/[&<>"']/g, (m) => ({'&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;'}[m] || m));
  };

  async function initPage() {
    const tbody = document.getElementById('consignmentTableBody');
    if (!tbody) return;

    const token = (localStorage.getItem('admin_token') || '').replace(/['"]+/g, '').trim();

    try {
      const res = await fetch(`${API_BASE}/api/admin/consignments`, {
          headers: { 'Authorization': `Bearer ${token}`, 'Accept': 'application/json' }
      });
      
      if (res.status === 401) { window.location.href = '/admin'; return; }
      if (!res.ok) throw new Error("Server Consignment Error");
      
      const data = await res.json();

      const totalCountEl = document.getElementById('totalConsignments');
      if (totalCountEl) totalCountEl.innerText = data.length;

      if (!data || data.length === 0) {
        tbody.innerHTML = '<tr><td colspan="6" class="p-20 text-center text-slate-400 italic font-medium">Hiện tại chưa nhận hồ sơ ký gửi nào từ Website.</td></tr>';
        return;
      }

      renderTable(data);
      setupFilters();

    } catch (err) {
      tbody.innerHTML = '<tr><td colspan="6" class="p-20 text-center text-red-500 font-bold italic underline">Lỗi sập cổng kết nối API Laravel. Vui lòng kiểm tra lại.</td></tr>';
    }
  }

  function renderTable(data: any[]) {
    const tbody = document.getElementById('consignmentTableBody');
    if (!tbody) return;

    tbody.innerHTML = data.map((item: any) => {
        const name = item.name || 'Ẩn danh';
        const phone = item.phone || 'Không có số';
        const project = item.project || 'Bcons';
        const code = item.apartment_code || 'N/A';
        const type = item.type || 'ban';
        const price = item.price || 'Thỏa thuận';
        const status = item.status || 'moi';
        const notes = item.notes ? item.notes : 'Không có ghi chú thêm.';

        return `
        <tr class="consignment-row group hover:bg-slate-50/50 transition-colors" 
            data-type="${escapeHTML(type)}" 
            data-status="${escapeHTML(status)}"
            data-search="${escapeHTML(name.toLowerCase())} ${escapeHTML(phone)} ${escapeHTML(project.toLowerCase())} ${escapeHTML(code.toLowerCase())}">
            <td class="px-6 py-5">
                <div class="font-bold text-slate-800">${escapeHTML(name)}</div>
                <a href="tel:${phone}" class="text-xs text-slate-400 hover:text-orange-600 font-mono block mt-0.5">📞 ${escapeHTML(phone)}</a>
            </td>
            <td class="px-6 py-5">
                <div class="font-bold text-slate-800">${escapeHTML(project)}</div>
                <div class="text-xs text-orange-600 font-black mt-0.5">📌 Mã căn: ${escapeHTML(code)}</div>
            </td>
            <td class="px-6 py-5 text-center">
                <span class="text-xs font-black ${type === 'ban' ? 'text-red-600' : 'text-blue-600'}">
                    ${type === 'ban' ? '💰 Cần bán' : '🔑 Cho thuê'}
                </span>
            </td>
            <td class="px-6 py-5 text-center font-extrabold text-slate-700 text-sm">
                ${escapeHTML(price)}
            </td>
            <td class="px-6 py-5 text-center">
                <span class="px-3 py-1 rounded-full text-[10px] font-black uppercase tracking-wider ${getStatusClass(status)}">
                    ${getStatusText(status)}
                </span>
            </td>
            <td class="px-6 py-5 text-right">
                <div class="flex justify-end gap-2">
                    <!-- Xem nhanh ghi chú nội thất -->
                    <button class="view-notes-btn p-2 bg-slate-100 text-slate-600 rounded-xl hover:bg-slate-800 hover:text-white transition-all shadow-sm cursor-pointer" data-notes="${escapeHTML(notes)}" data-code="${escapeHTML(code)}">
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" /></svg>
                    </button>
                    <!-- Đổi trạng thái -->
                    <button class="status-btn p-2 bg-blue-50 text-blue-600 rounded-xl hover:bg-blue-600 hover:text-white transition-all shadow-sm cursor-pointer" data-id="${item.id}" data-code="${escapeHTML(code)}" data-status="${escapeHTML(status)}">
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2.5 2.5 0 113.536 3.536L12 14.232H8V10.232l9.586-9.586z" /></svg>
                    </button>
                    <!-- Gỡ bỏ -->
                    <button class="delete-btn p-2 bg-red-50 text-red-600 rounded-xl hover:bg-red-600 hover:text-white transition-all shadow-sm cursor-pointer" data-id="${item.id}" data-code="${escapeHTML(code)}">
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" /></svg>
                    </button>
                </div>
            </td>
        </tr>`;
    }).join('');

    setupActionEvents();
  }

  function setupFilters() {
    ['drop-type', 'drop-status'].forEach(id => {
        const container = document.getElementById(id);
        if (!container) return;
        const btn = container.querySelector('.drop-btn') as HTMLButtonElement;
        const hiddenInput = container.querySelector('input[type="hidden"]') as HTMLInputElement;
        const selectedText = container.querySelector('.selected-text');

        btn.addEventListener('click', (e) => {
            e.stopPropagation();
            document.querySelectorAll('.dropdown-container').forEach(el => el !== container && el.classList.remove('active'));
            container.classList.toggle('active');
        });

        container.addEventListener('click', (e) => {
            const optionItem = (e.target as HTMLElement).closest('.option-item');
            if (optionItem) {
                const val = optionItem.getAttribute('data-value');
                if (val && hiddenInput) {
                    hiddenInput.value = val;
                    if (selectedText) selectedText.textContent = optionItem.textContent;
                    container.classList.remove('active');
                    filterData();
                }
            }
        });
    });

    document.getElementById('searchInput')?.addEventListener('input', filterData);
    window.addEventListener('click', () => {
        document.querySelectorAll('.dropdown-container').forEach(el => el.classList.remove('active'));
    });
  }

  function filterData() {
    const valType = (document.getElementById('filterType') as HTMLInputElement).value;
    const valStatus = (document.getElementById('filterStatus') as HTMLInputElement).value;
    const valSearch = (document.getElementById('searchInput') as HTMLInputElement).value.toLowerCase();

    const rows = document.querySelectorAll('.consignment-row');
    const noResults = document.getElementById('noResults');
    let visibleCount = 0;

    rows.forEach((row: any) => {
      const type = row.dataset.type;
      const status = row.dataset.status;
      const search = row.dataset.search;

      const passType = valType === 'all' || type === valType;
      const passStatus = valStatus === 'all' || status === valStatus;
      const passSearch = search.includes(valSearch);

      if (passType && passStatus && passSearch) {
        row.classList.remove('hidden');
        visibleCount++;
      } else {
        row.classList.add('hidden');
      }
    });

    if (visibleCount === 0) noResults?.classList.remove('hidden');
    else noResults?.classList.add('hidden');
  }

  function setupActionEvents() {
    const token = (localStorage.getItem('admin_token') || '').replace(/['"]+/g, '').trim();

    // 1. Popup xem nhanh chi tiết ghi chú căn hộ
    document.querySelectorAll('.view-notes-btn').forEach(btn => {
      btn.addEventListener('click', (e) => {
        const target = e.currentTarget as HTMLElement;
        Swal.fire({
          title: `Mô tả chi tiết căn: ${target.dataset.code}`,
          text: target.dataset.notes,
          icon: 'info',
          confirmButtonColor: '#ea580c'
        });
      });
    });

    // 2. Thay đổi trạng thái tiến độ qua Swal Select Box
    document.querySelectorAll('.status-btn').forEach(btn => {
        btn.addEventListener('click', async (e) => {
            const target = e.currentTarget as HTMLElement;
            const id = target.dataset.id;
            
            if (!id) return;

            const { value: newStatus } = await Swal.fire({
              title: 'Cập nhật trạng thái tin',
              text: `Thay đổi tiến độ căn hộ: ${target.dataset.code}`,
              input: 'select',
              inputOptions: {
                'moi': '🔵 Mới tiếp nhận',
                'dang_ra_hang': '⏳ Đang ra hàng',
                'da_chot': '✅ Đã giao dịch thành công',
                'huy': '❌ Hủy / Đóng tin'
              },
              inputValue: target.dataset.status,
              showCancelButton: true,
              confirmButtonColor: '#ea580c',
              confirmButtonText: 'Lưu thay đổi',
              cancelButtonText: 'Hủy'
            });

            if (newStatus && newStatus !== target.dataset.status) {
                try {
                    const res = await fetch(`${API_BASE}/api/admin/consignments/${id}/status`, {
                        method: 'PUT',
                        headers: { 'Authorization': `Bearer ${token}`, 'Content-Type': 'application/json', 'Accept': 'application/json' },
                        body: JSON.stringify({ status: newStatus })
                    });
                    const data = await res.json();
                    if (res.ok) {
                        await Swal.fire({ icon: 'success', title: 'Cập nhật thành công!', timer: 1000, showConfirmButton: false });
                        initPage();
                    } else { throw new Error(data.message); }
                } catch (err: any) { Swal.fire('Thất bại', err.message || 'Lỗi mạng', 'error'); }
            }
        });
    });

    // 3. Lệnh xóa vĩnh viễn hồ sơ ký gửi
    document.querySelectorAll('.delete-btn').forEach(btn => {
        btn.addEventListener('click', async (e) => {
            const target = e.currentTarget as HTMLElement;
            const id = target.dataset.id;
            if (!id) return;

            const confirm = await Swal.fire({ 
              title: 'Gỡ hồ sơ ký gửi?', 
              text: `Bạn muốn gỡ căn: "${target.dataset.code}" khỏi hệ thống?`, 
              icon: 'warning', 
              showCancelButton: true, 
              confirmButtonColor: '#ef4444',
              confirmButtonText: 'Đồng ý xóa',
              cancelButtonText: 'Hủy'
            });

            if (confirm.isConfirmed) {
                try {
                    const res = await fetch(`${API_BASE}/api/admin/consignments/${id}`, {
                        method: 'DELETE',
                        headers: { 'Authorization': `Bearer ${token}`, 'Accept': 'application/json' }
                    });
                    if (res.ok) {
                        await Swal.fire({ icon: 'success', title: 'Đã xóa hoàn tất!', timer: 1000, showConfirmButton: false });
                        initPage();
                    }
                } catch (err) { Swal.fire('Thất bại', 'Không thể xóa hồ sơ.', 'error'); }
            }
        });
    });
  }

  function getStatusClass(status: string) {
    switch(status) {
      case 'moi': return 'bg-blue-50 text-blue-600 border border-blue-100';
      case 'dang_ra_hang': return 'bg-amber-50 text-amber-600 border border-amber-100';
      case 'da_chot': return 'bg-green-50 text-green-600 border border-green-200 font-black';
      case 'huy': return 'bg-slate-100 text-slate-400';
      default: return 'bg-slate-100 text-slate-400';
    }
  }

  function getStatusText(status: string) {
    switch(status) {
      case 'moi': return '🔵 Mới nhận';
      case 'dang_ra_hang': return '⏳ Ra hàng';
      case 'da_chot': return '✅ Đã chốt';
      case 'huy': return '❌ Hủy bỏ';
      default: return status;
    }
  }

  initPage();
  document.addEventListener('astro:page-load', initPage);
</script>